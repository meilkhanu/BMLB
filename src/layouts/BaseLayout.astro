 		width: 12em;
 		height: 3.5em;
 		border-radius: 30em;
 		font-size: 14px;
 		font-weight: 600;
 		font-family: inherit;
 		border: none;
 		position: relative;
 		overflow: hidden;
 		z-index: 1;
 		cursor: pointer;
 		/* 亮色模式阴影 */
 		background: #FAFAFA;
 		box-shadow: 6px 6px 12px #d9d9d9, -6px -6px 12px #ffffff;
 		transition: all 0.3s ease;
 		color: #666;
 	}
 
 	.dark .annual-review-btn {
 		/* 暗色模式下减弱对比度，防止刺眼 */
 		background: #1A1A1A;
 		box-shadow: 4px 4px 10px #080808, -4px -4px 10px #252525;
 		color: #999;
 	}
 
 	.annual-review-btn::before {

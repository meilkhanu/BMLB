---
import { SITE_CONFIG } from '../config.ts';
import { env as cfEnv } from 'cloudflare:workers';
import SunIcon from '../components/icons/SunIcon.astro';
import MoonIcon from '../components/icons/MoonIcon.astro';
import SearchIcon from '../components/icons/SearchIcon.astro';
import UserIcon from '../components/icons/UserIcon.astro';
import HamburgerIcon from '../components/icons/HamburgerIcon.astro';

const { title = '贝谟拉比', description } = Astro.props;
const currentPath = Astro.url.pathname;
const navLinkClass = (path: string) => {
	const base = 'text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#666] dark:hover:text-[#999] pb-1';
	return currentPath === path ? `${base} border-b-2 border-[#8B7CB3]` : base;
};

let songs: any[] = [];
try {
	const db = (cfEnv as any)?.DB;
	if (db) {
		const { results } = await db.prepare("SELECT * FROM songs ORDER BY sort_order ASC, id ASC").all();
		songs = results || [];
	}
} catch {}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
	<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{title}</title>
	{description && <meta name="description" content={description} />}
	<script is:inline>
		(function() {
			const stored = localStorage.getItem('theme');
			const isDark = stored
				? stored === 'dark'
				: window.matchMedia('(prefers-color-scheme: dark)').matches;
			if (isDark) {
				document.documentElement.classList.add('dark');
			}
		})();
	</script>
</head>
<body class="bg-[#FAFAFA] dark:bg-[#0F0F0F] text-[#1A1A1A] dark:text-[#EAEAEA]">
	<!-- 模块1：导航栏 -->
	<nav id="site-nav" class="fixed top-0 left-0 w-full h-16 z-50 bg-white/70 dark:bg-[#0F0F0F]/70 backdrop-blur-2xl backdrop-saturate-150 border-b border-black/[0.06] dark:border-white/[0.06] transition-[background-color,box-shadow,border-color] duration-500">
		<div class="flex justify-between items-center px-6 h-full">
			<!-- 左侧站点名 -->
			<a href="/" class="text-xl font-bold tracking-tight text-[#1A1A1A] dark:text-[#EAEAEA]">
				{SITE_CONFIG.siteName}
			</a>

			<!-- 中间导航（PC only） -->
			<div class="hidden md:flex items-center gap-6">
				<a href="/" class={navLinkClass('/')}>主页</a>
				<a href="/archive" class={navLinkClass('/archive')}>归档</a>
				<a href="/about" class={navLinkClass('/about')}>关于</a>
				<a href="/now" class={navLinkClass('/now')}>/now</a>
				<a href="/colophon" class={navLinkClass('/colophon')}>/colophon</a>
				<a href="https://travel.moe/go.html?travel=on" target="_blank" class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#666] dark:hover:text-[#999] pb-1 transition-colors no-underline">异次元之旅</a>
			</div>

			<!-- 右侧图标区 -->
			<div class="flex items-center gap-1 md:gap-2">
				<div class="flex items-center focus-within:bg-black/5 focus-within:dark:bg-white/10 rounded-full transition-all duration-300">
				<button onclick="document.getElementById('search-input').focus()" class="w-9 h-9 flex items-center justify-center rounded-full bg-transparent hover:bg-black/5 dark:hover:bg-white/10 transition-all active:scale-95 text-[#1A1A1A] dark:text-[#EAEAEA] cursor-pointer border-none flex-shrink-0">
					<SearchIcon />
				</button>
				<input type="text" id="search-input" placeholder="Search..." class="w-0 focus:w-28 md:focus:w-40 bg-transparent border-none outline-none text-sm text-[#1A1A1A] dark:text-[#EAEAEA] placeholder-[#999] transition-all duration-300 px-0 focus:px-2 focus:mr-2" /></div>
				<button onclick="toggleDarkMode()" class="w-9 h-9 flex items-center justify-center rounded-full bg-transparent hover:bg-black/5 dark:hover:bg-white/10 transition-all active:scale-95 text-[#1A1A1A] dark:text-[#EAEAEA] cursor-pointer border-none flex-shrink-0">
				<span id="theme-sun"><SunIcon /></span>
				<span id="theme-moon" class="hidden"><MoonIcon /></span>
				</button>
				<a href="/admin" class="w-9 h-9 flex items-center justify-center rounded-full bg-transparent hover:bg-black/5 dark:hover:bg-white/10 transition-all active:scale-95 text-[#1A1A1A] dark:text-[#EAEAEA] cursor-pointer border-none flex-shrink-0" title="管理后台">
					<UserIcon />
				</a>
				<button onclick="toggleMobileMenu()" class="md:hidden w-9 h-9 flex items-center justify-center rounded-full bg-transparent hover:bg-black/5 dark:hover:bg-white/10 transition-all active:scale-95 text-[#1A1A1A] dark:text-[#EAEAEA] cursor-pointer border-none flex-shrink-0">
				<HamburgerIcon />
				</button>
			</div>
		</div>
	</nav>

	<!-- 移动端Hamburger菜单 -->
	<div id="mobile-menu" class="fixed inset-0 z-40 bg-white/80 dark:bg-black/80 backdrop-blur-2xl opacity-0 pointer-events-none transition-opacity duration-500 flex flex-col pt-24 pb-12 px-8">
  		<div class="flex flex-col gap-6 mt-8">
    		<a href="/" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]">主页</a>
    		<a href="/archive" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]" style="transition-delay: 50ms;">归档</a>
    		<a href="/about" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]" style="transition-delay: 100ms;">关于</a>
    		<a href="/now" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]" style="transition-delay: 150ms;">/now</a>
    		<a href="/colophon" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]" style="transition-delay: 200ms;">/colophon</a>
    		<a href="https://travel.moe/go.html?travel=on" target="_blank" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]" style="transition-delay: 250ms;">异次元之旅</a>
  		</div>
  	<div class="mt-auto border-t border-[#1A1A1A]/10 dark:border-white/10 pt-6 flex justify-between items-center opacity-0 translate-x-12 transition-all duration-500 delay-300" id="mobile-menu-footer">
    	<span class="text-xs font-bold text-[#8B7CB3] tracking-widest uppercase">贝谟拉比 BMLB</span>
    <div class="flex gap-4">
      	<a href="#" class="text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#8B7CB3]">
        	<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          	<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-6h2v6zm-1-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm5 7h-2v-3c0-.55-.45-1-1-1s-1 .45-1 1v3h-2v-6h2v1.5c.5-1.5 2.5-1.5 2.5 1.5V17z"/>
        	</svg>
      	</a>
      	<a href="#" class="text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#8B7CB3]">
        	<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          	<path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5C20.84 12.58 16.8 2 12 2zm-1.5 16h-2v-8h2v8zm-1-9.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm6.5 9.5h-2v-4.5c0-1.1-.9-2-2-2s-2 .9-2 2V18h-2v-8h2v1.5c.5-1.5 2.5-2.5 4-1.5 1.5 1 1.5 3 1.5 4.5V18z"/>
        </svg>
      	</a>
    </div>
  	</div>
</div>

	<main class="min-h-[calc(100vh-64px-200px)]">
		<slot />
	</main>

	<!-- 全局音频 + 歌曲数据 + 悬浮播放器（跨页面持久化） -->
	<audio id="global-audio" data-astro-transition-persist="global-audio" preload="none"></audio>
	<div id="global-songs-data" data-songs={JSON.stringify(songs)} class="hidden"></div>

	<aside id="draggable-player" data-astro-transition-persist="draggable-player" data-expanded="false"
		class="fixed z-[9999] cursor-grab active:cursor-grabbing rounded-full shadow-lg select-none transition-all duration-300 ease-out"
		style="width:48px;height:48px;bottom:24px;right:24px;background:linear-gradient(135deg,#8B7CB3,#B26A8B);">
		<!-- 收缩态：音乐图标 -->
		<div id="player-collapsed" class="absolute inset-0 flex items-center justify-center">
			<svg id="float-music-icon" class="w-5 h-5 text-white transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
				<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm0-5.5c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1z"/>
			</svg>
			<!-- 播放中呼吸光环 -->
			<div id="float-pulse-ring" class="absolute inset-[-4px] rounded-full border-2 border-white/40 opacity-0 pointer-events-none transition-opacity duration-300"></div>
		</div>

		<!-- 展开态：控制栏 -->
		<div id="player-expanded" class="absolute inset-0 flex items-center justify-between px-4 opacity-0 pointer-events-none">
			<div class="flex items-center gap-2">
				<button data-no-drag type="button" id="float-prev" class="w-7 h-7 flex items-center justify-center rounded-full hover:bg-white/20 transition-colors cursor-pointer border-none bg-transparent text-white">
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
				</button>
				<button data-no-drag type="button" id="float-play" class="w-8 h-8 flex items-center justify-center rounded-full bg-white text-[#8B7CB3] hover:scale-105 active:scale-95 transition-all cursor-pointer border-none shadow-md">
					<svg id="float-icon-play" class="w-4 h-4 translate-x-[1px]" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
					<svg id="float-icon-pause" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
				</button>
				<button data-no-drag type="button" id="float-next" class="w-7 h-7 flex items-center justify-center rounded-full hover:bg-white/20 transition-colors cursor-pointer border-none bg-transparent text-white">
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
				</button>
				<button data-no-drag type="button" id="float-mode" class="w-7 h-7 flex items-center justify-center rounded-full hover:bg-white/20 transition-colors cursor-pointer border-none bg-transparent text-white text-[10px] font-bold" title="列表循环">🔁</button>
				<button data-no-drag type="button" id="float-list" class="w-7 h-7 flex items-center justify-center rounded-full hover:bg-white/20 transition-colors cursor-pointer border-none bg-transparent text-white">
					<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M3 15h18v-2H3v2zm0 4h18v-2H3v2zm0-8h18V9H3v2zm0-6v2h18V5H3z"/></svg>
				</button>
			</div>
			<span id="float-title" class="text-sm font-bold text-white truncate max-w-[120px] ml-2">暂无音乐</span>
		</div>

		<!-- 迷你播放列表面板 -->
		<div id="float-playlist" class="hidden absolute left-0 right-0 bottom-full mb-3 bg-white/95 dark:bg-[#1A1A1A]/95 backdrop-blur-xl rounded-2xl border border-white/20 dark:border-white/10 shadow-xl p-3 max-h-[240px] overflow-y-auto z-50">
			<div class="flex items-center justify-between mb-2 px-1">
				<span class="text-[10px] font-bold text-[#8B7CB3] tracking-widest uppercase">Playlist</span>
				<button id="float-playlist-close" data-no-drag class="text-[#999] hover:text-[#1A1A1A] dark:hover:text-[#EAEAEA] transition-colors cursor-pointer border-none bg-transparent">
					<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>
			<div id="float-playlist-items" class="space-y-1"></div>
		</div>
	</aside>

	<!-- 模块4：页脚 -->
	<footer id="site-footer" class="relative w-full bg-[#111111] py-12 px-6 mt-12 overflow-hidden">
		
		<canvas id="footer-canvas" class="absolute inset-0 z-0 pointer-events-none"></canvas>

		<div class="absolute top-0 left-0 w-full h-16 z-[1] pointer-events-none bg-gradient-to-b from-[#111111] to-transparent opacity-90"></div>

		<div class="relative z-10 flex flex-col items-center gap-1 text-xs text-[#888] leading-relaxed">
			<div>
				<span>© 2026 {SITE_CONFIG.siteName}</span>
				<span class="mx-2">/</span>
				<a href="/rss" class="hover:text-[#CCC] transition-colors no-underline">RSS</a>
				<span class="mx-2">/</span>
				<a href="/sitemap" class="hover:text-[#CCC] transition-colors no-underline">Sitemap</a>
				<span class="mx-2">/</span>
				<a href="/colophon" class="hover:text-[#CCC] transition-colors no-underline">/colophon</a>
			</div>
			<div><span id="site-runtime">--</span></div>
			<div>Powered by Astro & Cloudflare Pages / <a href="https://icp.gov.moe/?keyword=20269732" target="_blank" class="hover:text-[#CCC] transition-colors no-underline">萌ICP备20269732号</a></div>
		</div>
	</footer>

	<script is:inline>
		function toggleDarkMode() {
			document.documentElement.classList.toggle('dark');
			const isDark = document.documentElement.classList.contains('dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
			updateThemeIcon(isDark);
		}

		function updateThemeIcon(isDark) {
			const sun = document.getElementById('theme-sun');
			const moon = document.getElementById('theme-moon');
			if (sun && moon) {
				if (isDark) {
					sun.classList.add('hidden');
					moon.classList.remove('hidden');
				} else {
					sun.classList.remove('hidden');
					moon.classList.add('hidden');
				}
			}
		}

		function initTheme() {
			const stored = localStorage.getItem('theme');
			const isDark = stored
				? stored === 'dark'
				: window.matchMedia('(prefers-color-scheme: dark)').matches;
			if (isDark) {
				document.documentElement.classList.add('dark');
				updateThemeIcon(true);
			} else {
				document.documentElement.classList.remove('dark');
				updateThemeIcon(false);
			}
		}

		// 初始加载时执行
		initTheme();

		// View Transitions 交换前：确保 dark class 已应用于新文档，消除切换闪烁
		document.addEventListener('astro:before-swap', (ev) => {
			const stored = localStorage.getItem('theme');
			const isDark = stored
				? stored === 'dark'
				: window.matchMedia('(prefers-color-scheme: dark)').matches;
			if (isDark) {
				ev.newDocument.documentElement.classList.add('dark');
			}
		});

		// View Transitions 页面切换后重新同步主题图标
		document.addEventListener('astro:page-load', initTheme);

		// 导航栏滚动效果（简化版：只控制阴影深浅）
		const nav = document.getElementById('site-nav');
		function handleScroll() {
			if (window.scrollY > 100) {
				nav.classList.add('scrolled');
			} else {
				nav.classList.remove('scrolled');
			}
		}
		window.addEventListener('scroll', handleScroll);
		handleScroll();

		// 页脚 Canvas 星月粒子背景
		let footerCanvasAnimId = null;
		let footerCanvasResizeHandler = null;
		let footerCanvasVisHandler = null;

		function initFooterCanvas() {
			const canvas = document.getElementById('footer-canvas');
			const footer = document.getElementById('site-footer');
			if (!canvas || !footer) return;

			// 清理旧动画和监听器
			if (footerCanvasAnimId) {
				cancelAnimationFrame(footerCanvasAnimId);
				footerCanvasAnimId = null;
			}
			if (footerCanvasResizeHandler) {
				window.removeEventListener('resize', footerCanvasResizeHandler);
			}
			if (footerCanvasVisHandler) {
				document.removeEventListener('visibilitychange', footerCanvasVisHandler);
			}

			const ctx = canvas.getContext('2d');
			let width, height;
			let particles = [];

			function resize() {
				const rect = footer.getBoundingClientRect();
				width = rect.width;
				height = rect.height;
				const dpr = window.devicePixelRatio || 1;
				canvas.width = width * dpr;
				canvas.height = height * dpr;
				canvas.style.width = width + 'px';
				canvas.style.height = height + 'px';
				ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
			}

			function createParticles() {
				particles = [];
				const layers = [
					{ count: 18, sizeMin: 18, sizeMax: 28, speedMin: 0.15, speedMax: 0.35, opacityMin: 0.08, opacityMax: 0.14, glow: 20, colors: ['#FF6B9D'], types: ['moon', 'star'] },
					{ count: 32, sizeMin: 10, sizeMax: 18, speedMin: 0.35, speedMax: 0.6, opacityMin: 0.15, opacityMax: 0.22, glow: 14, colors: ['#f90275'], types: ['star', 'moon', 'cross'] },
					{ count: 28, sizeMin: 6, sizeMax: 12, speedMin: 0.5, speedMax: 0.9, opacityMin: 0.22, opacityMax: 0.32, glow: 10, colors: ['#FF6B9D', '#f90275'], types: ['cross', 'star'] }
				];

				layers.forEach(layer => {
					for (let i = 0; i < layer.count; i++) {
						particles.push({
							x: Math.random() * width,
							y: Math.random() * height,
							size: layer.sizeMin + Math.random() * (layer.sizeMax - layer.sizeMin),
							type: layer.types[Math.floor(Math.random() * layer.types.length)],
							color: layer.colors[Math.floor(Math.random() * layer.colors.length)],
							speed: layer.speedMin + Math.random() * (layer.speedMax - layer.speedMin),
							rotation: Math.random() * Math.PI * 2,
							rotationSpeed: (Math.random() - 0.5) * 0.015,
							opacity: layer.opacityMin + Math.random() * (layer.opacityMax - layer.opacityMin),
							glow: layer.glow + Math.random() * 4
						});
					}
				});
			}

			function drawStar(ctx, x, y, size, rotation) {
				ctx.save();
				ctx.translate(x, y);
				ctx.rotate(rotation);
				ctx.beginPath();
				const outer = size;
				const inner = size * 0.35;
				for (let i = 0; i < 8; i++) {
					const r = i % 2 === 0 ? outer : inner;
					const angle = (i * Math.PI) / 4 - Math.PI / 2;
					const px = Math.cos(angle) * r;
					const py = Math.sin(angle) * r;
					if (i === 0) ctx.moveTo(px, py);
					else ctx.lineTo(px, py);
				}
				ctx.closePath();
				ctx.fill();
				ctx.restore();
			}

			function drawMoon(ctx, x, y, size, rotation) {
				ctx.save();
				ctx.translate(x, y);
				ctx.rotate(rotation);
				ctx.beginPath();
				ctx.arc(0, 0, size, -Math.PI * 0.6, Math.PI * 0.6);
				ctx.bezierCurveTo(
					size * 0.15, size * 0.5,
					size * 0.15, -size * 0.5,
					size * Math.cos(-Math.PI * 0.6), size * Math.sin(-Math.PI * 0.6)
				);
				ctx.closePath();
				ctx.fill();
				ctx.restore();
			}

			function drawCross(ctx, x, y, size, rotation) {
				ctx.save();
				ctx.translate(x, y);
				ctx.rotate(rotation);
				const s = size * 0.22;
				const l = size;

				// top
				ctx.beginPath();
				ctx.moveTo(0, -l);
				ctx.lineTo(s, -l + s * 2.5);
				ctx.lineTo(0, -l + s * 4);
				ctx.lineTo(-s, -l + s * 2.5);
				ctx.closePath();
				ctx.fill();

				// bottom
				ctx.beginPath();
				ctx.moveTo(0, l);
				ctx.lineTo(s, l - s * 2.5);
				ctx.lineTo(0, l - s * 4);
				ctx.lineTo(-s, l - s * 2.5);
				ctx.closePath();
				ctx.fill();

				// left
				ctx.beginPath();
				ctx.moveTo(-l, 0);
				ctx.lineTo(-l + s * 2.5, s);
				ctx.lineTo(-l + s * 4, 0);
				ctx.lineTo(-l + s * 2.5, -s);
				ctx.closePath();
				ctx.fill();

				// right
				ctx.beginPath();
				ctx.moveTo(l, 0);
				ctx.lineTo(l - s * 2.5, s);
				ctx.lineTo(l - s * 4, 0);
				ctx.lineTo(l - s * 2.5, -s);
				ctx.closePath();
				ctx.fill();

				ctx.restore();
			}

			function draw() {
				ctx.clearRect(0, 0, width, height);

				particles.forEach(p => {
					ctx.save();
					ctx.globalAlpha = p.opacity;
					ctx.shadowBlur = p.glow;
					ctx.shadowColor = p.color;
					ctx.fillStyle = p.color;

					switch (p.type) {
						case 'star':
							drawStar(ctx, p.x, p.y, p.size, p.rotation);
							break;
						case 'moon':
							drawMoon(ctx, p.x, p.y, p.size, p.rotation);
							break;
						case 'cross':
							drawCross(ctx, p.x, p.y, p.size, p.rotation);
							break;
					}

					ctx.restore();
				});
			}

			function update() {
				particles.forEach(p => {
					const angle = -Math.PI / 4;
					p.x += Math.cos(angle) * p.speed;
					p.y += Math.sin(angle) * p.speed;
					p.rotation += p.rotationSpeed;

					const margin = 60;
					if (p.x > width + margin) p.x = -margin;
					if (p.y < -margin) p.y = height + margin;
				});
			}

			function animate() {
				update();
				draw();
				footerCanvasAnimId = requestAnimationFrame(animate);
			}

			resize();
			createParticles();
			animate();

			footerCanvasResizeHandler = () => {
				resize();
				createParticles();
			};
			window.addEventListener('resize', footerCanvasResizeHandler);

			footerCanvasVisHandler = () => {
				if (document.hidden) {
					cancelAnimationFrame(footerCanvasAnimId);
				} else {
					animate();
				}
			};
			document.addEventListener('visibilitychange', footerCanvasVisHandler);
		}

		initFooterCanvas();
		document.addEventListener('astro:page-load', initFooterCanvas);

		// 移动端全屏菜单控制逻辑
		let isMobileMenuOpen = false;
		function toggleMobileMenu() {
			const menu = document.getElementById('mobile-menu');
			const links = document.querySelectorAll('.mobile-nav-link');
			const footer = document.getElementById('mobile-menu-footer');
			
			isMobileMenuOpen = !isMobileMenuOpen;

			if (isMobileMenuOpen) {
				menu.classList.remove('opacity-0', 'pointer-events-none');
				document.body.style.overflow = 'hidden';
				
				setTimeout(() => {
					links.forEach(link => {
						link.classList.remove('translate-x-12', 'opacity-0');
					});
					footer.classList.remove('translate-x-12', 'opacity-0');
				}, 50);
			} else {
				menu.classList.add('opacity-0', 'pointer-events-none');
				document.body.style.overflow = '';
				
				links.forEach(link => {
					link.classList.add('translate-x-12', 'opacity-0');
				});
				footer.classList.add('translate-x-12', 'opacity-0');
			}
		}

		function updateRuntime() {
			const start = new Date('2026-04-26T00:00:00');
			const now = new Date();
			const diff = now - start;
			const months = Math.floor(diff / (1000 * 60 * 60 * 24 * 30));
			const days = Math.floor((diff % (1000 * 60 * 60 * 24 * 30)) / (1000 * 60 * 60 * 24));
			const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
			let parts = [];
			if (months > 0) parts.push(months + '个月');
			if (days > 0) parts.push(days + '天');
			if (hours > 0 || (months === 0 && days === 0)) parts.push(hours + '小时');
			const el = document.getElementById('site-runtime');
			if (el) el.textContent = '本站已运行 ' + parts.join('');
		}
	updateRuntime();
	setInterval(updateRuntime, 1000);
	</script>

	<!-- 全局播放器脚本 -->
	<script is:inline>
		(function () {
			// ============================================================
			// 全局播放器状态
			// ============================================================
			if (!window.playerState) {
				window.playerState = {
					currentIndex: 0,
					songs: [],
					isPlaying: false,
					playMode: 'loop',
					initialized: false,
				};
			}

			const state = window.playerState;
			const audio = document.getElementById('global-audio');
			const player = document.getElementById('draggable-player');
			const collapsed = document.getElementById('player-collapsed');
			const expanded = document.getElementById('player-expanded');
			const floatTitle = document.getElementById('float-title');
			const floatPlayBtn = document.getElementById('float-play');
			const floatIconPlay = document.getElementById('float-icon-play');
			const floatIconPause = document.getElementById('float-icon-pause');
			const floatModeBtn = document.getElementById('float-mode');
			const floatListBtn = document.getElementById('float-list');
			const floatPlaylist = document.getElementById('float-playlist');
			const floatPlaylistItems = document.getElementById('float-playlist-items');
			const floatPlaylistClose = document.getElementById('float-playlist-close');

			// 从全局隐藏元素加载歌曲
			if (!state.initialized) {
				const globalSongsEl = document.getElementById('global-songs-data');
				if (globalSongsEl) {
					try {
						const songs = JSON.parse(globalSongsEl.dataset.songs || '[]');
						if (songs.length > 0) {
							state.songs = songs;
							state.initialized = true;
						}
					} catch {}
				}
			}

			// ============================================================
			// UI 同步
			// ============================================================
			function setExpanded(exp) {
				player.dataset.expanded = exp ? 'true' : 'false';
			}

			function updateFloatPlaylistUI() {
				if (!floatPlaylistItems) return;
				floatPlaylistItems.innerHTML = state.songs.map((s, i) =>
					'<div class="flex items-center gap-2 p-2 rounded-xl cursor-pointer transition-colors ' + (i === state.currentIndex ? 'bg-[#8B7CB3]/10' : 'hover:bg-black/5 dark:hover:bg-white/5') + '" data-play-index="' + i + '">' +
						'<div class="w-7 h-7 rounded-lg bg-gradient-to-tr from-[#8B7CB3] to-[#C9BAE5] dark:to-[#4A3B73] flex items-center justify-center text-white shrink-0 text-[10px] font-bold">' + (i + 1) + '</div>' +
						'<div class="flex-1 min-w-0">' +
							'<div class="text-xs font-bold text-[#1A1A1A] dark:text-[#EAEAEA] truncate">' + s.title + '</div>' +
							'<div class="text-[10px] text-[#999] truncate">' + (s.artist || '') + '</div>' +
						'</div>' +
						(i === state.currentIndex && state.isPlaying ? '<div class="flex items-end gap-[1px] h-3"><div class="w-[2px] bg-[#8B7CB3] rounded-full h-[60%] animate-pulse"></div><div class="w-[2px] bg-[#8B7CB3] rounded-full h-[100%] animate-pulse" style="animation-delay:0.1s"></div></div>' : '') +
					'</div>'
				).join('');

				floatPlaylistItems.querySelectorAll('[data-play-index]').forEach(el => {
					el.addEventListener('click', () => {
						const idx = parseInt(el.dataset.playIndex);
						window.playerPlayIndex(idx);
					});
				});
			}

			function updateFloatUI() {
				if (!state.songs || state.songs.length === 0) {
					floatTitle.textContent = '暂无音乐';
					player.classList.remove('is-playing');
					return;
				}
				const song = state.songs[state.currentIndex];
				if (song) {
					floatTitle.textContent = song.title || '未知歌曲';
				}
				if (state.isPlaying) {
					floatIconPlay.classList.add('hidden');
					floatIconPause.classList.remove('hidden');
					player.classList.add('is-playing');
				} else {
					floatIconPlay.classList.remove('hidden');
					floatIconPause.classList.add('hidden');
					player.classList.remove('is-playing');
				}
				const modeMap = { loop: '🔁', single: '🔂', shuffle: '🔀' };
				if (floatModeBtn) floatModeBtn.textContent = modeMap[state.playMode] || '🔁';
			}

			// ============================================================
			// 音频事件监听（全局唯一）
			// ============================================================
			audio.addEventListener('play', () => {
				state.isPlaying = true;
				updateFloatUI();
				setExpanded(true);
			});

			audio.addEventListener('pause', () => {
				state.isPlaying = false;
				updateFloatUI();
			});

			audio.addEventListener('ended', () => {
				if (state.playMode === 'single') {
					audio.currentTime = 0;
					audio.play().catch(() => {});
				} else {
					playNext();
				}
			});

			// ============================================================
			// 播放控制
			// ============================================================
			function ensureSongLoaded() {
				if (!audio.src && state.songs.length > 0) {
					const song = state.songs[state.currentIndex];
					if (song) audio.src = song.audio_url;
				}
			}

			window.playerToggle = function () {
				if (!state.songs.length) return;
				ensureSongLoaded();
				if (audio.paused) {
					audio.play().catch(() => {});
				} else {
					audio.pause();
				}
			};

			function playNext() {
				if (!state.songs.length) return;
				if (state.playMode === 'shuffle') {
					state.currentIndex = Math.floor(Math.random() * state.songs.length);
				} else {
					state.currentIndex = (state.currentIndex + 1) % state.songs.length;
				}
				loadCurrentSong();
				if (!state.isPlaying) {
					audio.play().catch(() => {});
				}
			}

			function playPrev() {
				if (!state.songs.length) return;
				if (state.playMode === 'shuffle') {
					state.currentIndex = Math.floor(Math.random() * state.songs.length);
				} else {
					state.currentIndex = (state.currentIndex - 1 + state.songs.length) % state.songs.length;
				}
				loadCurrentSong();
				if (!state.isPlaying) {
					audio.play().catch(() => {});
				}
			}

			function loadCurrentSong() {
				const song = state.songs[state.currentIndex];
				if (!song) return;
				audio.src = song.audio_url;
				updateFloatUI();
				updateFloatPlaylistUI();
				window.dispatchEvent(new CustomEvent('player-song-change', { detail: song }));
			}

			function switchMode() {
				const modes = ['loop', 'single', 'shuffle'];
				const idx = modes.indexOf(state.playMode);
				state.playMode = modes[(idx + 1) % 3];
				updateFloatUI();
				window.dispatchEvent(new CustomEvent('player-mode-change', { detail: state.playMode }));
			}

			window.playerPlayIndex = function (index) {
				state.currentIndex = index;
				const song = state.songs[index];
				if (song) {
					audio.src = song.audio_url;
					audio.play().catch(() => {});
					updateFloatUI();
					updateFloatPlaylistUI();
				}
			};

			// ============================================================
			// 悬浮按钮事件
			// ============================================================
			floatPlayBtn.addEventListener('click', () => window.playerToggle());
			document.getElementById('float-prev').addEventListener('click', playPrev);
			document.getElementById('float-next').addEventListener('click', playNext);
			floatModeBtn.addEventListener('click', switchMode);

			// 播放列表切换
			if (floatListBtn) {
				floatListBtn.addEventListener('click', (e) => {
					e.stopPropagation();
					floatPlaylist.classList.toggle('hidden');
					if (!floatPlaylist.classList.contains('hidden')) updateFloatPlaylistUI();
				});
			}
			if (floatPlaylistClose) {
				floatPlaylistClose.addEventListener('click', (e) => {
					e.stopPropagation();
					floatPlaylist.classList.add('hidden');
				});
			}

			// 点击收缩态：始终展开
			collapsed.addEventListener('click', (e) => {
				if (e.target.hasAttribute('data-no-drag') || e.target.closest('[data-no-drag]')) return;
				setExpanded(true);
			});

			// 点击展开态空白区域：收起
			expanded.addEventListener('click', (e) => {
				if (e.target.hasAttribute('data-no-drag') || e.target.closest('[data-no-drag]')) return;
				if (e.target === expanded) setExpanded(false);
			});

			// ============================================================
			// 拖拽逻辑
			// ============================================================
			let dragging = false;
			let dragStartX, dragStartY, playerStartX, playerStartY;

			function clamp(val, min, max) { return Math.max(min, Math.min(max, val)); }

			function getSavedPos() {
				try {
					const pos = JSON.parse(localStorage.getItem('player-pos') || 'null');
					if (pos && typeof pos.x === 'number' && typeof pos.y === 'number') return pos;
				} catch {}
				return null;
			}

			function savePos(x, y) {
				localStorage.setItem('player-pos', JSON.stringify({ x, y }));
			}

			const saved = getSavedPos();
			if (saved) {
				player.style.left = saved.x + 'px';
				player.style.top = saved.y + 'px';
				player.style.bottom = 'auto';
				player.style.right = 'auto';
			}

			player.addEventListener('pointerdown', (e) => {
				if (e.target.hasAttribute('data-no-drag') || e.target.closest('[data-no-drag]')) return;
				dragging = true;
				dragStartX = e.clientX;
				dragStartY = e.clientY;
				const rect = player.getBoundingClientRect();
				playerStartX = rect.left;
				playerStartY = rect.top;
				player.setPointerCapture(e.pointerId);
				player.style.transition = 'none';
			});

			player.addEventListener('pointermove', (e) => {
				if (!dragging) return;
				const dx = e.clientX - dragStartX;
				const dy = e.clientY - dragStartY;
				const maxX = window.innerWidth - player.offsetWidth;
				const maxY = window.innerHeight - player.offsetHeight;
				const x = clamp(playerStartX + dx, 0, maxX);
				const y = clamp(playerStartY + dy, 0, maxY);
				player.style.left = x + 'px';
				player.style.top = y + 'px';
				player.style.bottom = 'auto';
				player.style.right = 'auto';
			});

			player.addEventListener('pointerup', () => {
				if (!dragging) return;
				dragging = false;
				player.style.transition = '';
				const rect = player.getBoundingClientRect();
				savePos(rect.left, rect.top);
			});

			// ============================================================
			// astro:page-load — 同步 UI
			// ============================================================
			function onPageLoad() {
				// 重新从全局元素加载歌曲（页面切换后 DOM 更新）
				if (!state.initialized || state.songs.length === 0) {
					const globalSongsEl = document.getElementById('global-songs-data');
					if (globalSongsEl) {
						try {
							const songs = JSON.parse(globalSongsEl.dataset.songs || '[]');
							if (songs.length > 0) {
								state.songs = songs;
								state.initialized = true;
							}
						} catch {}
					}
				}
				updateFloatUI();
				if (state.isPlaying) setExpanded(true);
				window.dispatchEvent(new CustomEvent('player-state-sync', {
					detail: {
						currentIndex: state.currentIndex,
						isPlaying: state.isPlaying,
						playMode: state.playMode,
						songs: state.songs,
					}
				}));
			}

			document.addEventListener('astro:page-load', onPageLoad);
			document.addEventListener('DOMContentLoaded', onPageLoad);

			updateFloatUI();
		})();
	</script>
</body>
</html>

<style is:global>
	/* 深色模式闪烁防护：
	   - view-transition-name 让 html 不参与 View Transitions 的 morph 动画
	   - color-scheme 确保浏览器原生元素（滚动条、表单等）使用正确配色 */
	html {
		view-transition-name: root;
	}
	:root {
		color-scheme: light dark;
	}
	body {
		font-family: 'Inter', 'PingFang SC', 'Microsoft YaHei', 'Noto Sans SC', sans-serif;
	}
	.hide-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.hide-scrollbar::-webkit-scrollbar {
		display: none;
	}


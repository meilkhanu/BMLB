 	}
	/* --- 流光进度条动画 --- */
  	@keyframes gradient-x {
  		0%, 100% { background-position: 0% 50%; }
  		50% { background-position: 100% 50%; }
  	}
   	.animate-gradient-x {
  		animation: gradient-x 3s ease infinite;
  	}
  
  	/* --- 标签扫光动画 --- */
	@keyframes sweep {
		0% { left: -100%; }
		100% { left: 200%; }
	}
	.animate-sweep {
		animation: sweep 1.5s ease-in-out infinite;
	} 
	/* --- 元素淡入上浮动画 --- */
	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in-up {
		/* 加上 forwards，让元素在动画结束后停留在 opacity: 1 的状态，不再消失！ */
		animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}
	/* --- 悬浮播放器 --- */
	#draggable-player[data-expanded="true"] {
		width: 320px !important;
		border-radius: 9999px;
	}
	#draggable-player[data-expanded="true"] #player-collapsed {
		opacity: 0;
		pointer-events: none;
	}
	#draggable-player[data-expanded="true"] #player-expanded {
		opacity: 1;
		pointer-events: auto;
	}
	/* 收缩态播放中呼吸动画 */
	#draggable-player.is-playing #float-music-icon {
		animation: float-icon-spin 3s linear infinite;
	}
	#draggable-player.is-playing #float-pulse-ring {
		opacity: 1;
		animation: float-pulse 2s ease-in-out infinite;
	}
	@keyframes float-icon-spin {
		0% { transform: rotate(0deg); }
		100% { transform: rotate(360deg); }
	}
	@keyframes float-pulse {
		0%, 100% { transform: scale(1); opacity: 0.4; }
		50% { transform: scale(1.15); opacity: 0.15; }
	}
</style>

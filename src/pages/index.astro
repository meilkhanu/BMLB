---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../config.ts';
import CalendarIcon from '../components/icons/CalendarIcon.astro';
import { env as cfEnv } from 'cloudflare:workers';

// —— 服务端获取全部已发布文章 ——
interface ApiPost {
  id: number;
  slug: string;
  title: string;
  content: string;
  excerpt: string;
  categoryId: string;
  tags: string[];
  coverImage: string;
  publishedAt: string;
  createdAt: string;
  updatedAt: string;
  status: string;
}

let allPosts: ApiPost[] = [];
try {
  const apiUrl = new URL('/api/posts?limit=50', Astro.url);
  const res = await fetch(apiUrl.toString());
  if (res.ok) {
    allPosts = await res.json();
    allPosts.sort((a, b) => (b.publishedAt || '').localeCompare(a.publishedAt || ''));
  } else {
    const errText = await res.text().catch(() => '无法读取响应');
    console.error('[index] GET /api/posts 返回非 OK:', res.status, errText.slice(0, 200));
  }
} catch (e: any) {
  console.error('[index] GET /api/posts 请求失败:', e?.message || e);
}

// —— 服务端获取歌曲列表 ——
interface Song {
  id: number;
  title: string;
  artist: string;
  album: string;
  cover_url: string;
  audio_url: string;
  duration: number;
  sort_order: number;
}

let songs: Song[] = [];
try {
  const songsRes = await fetch(new URL('/api/songs', Astro.url).toString());
  if (songsRes.ok) {
    songs = await songsRes.json();
  }
} catch (e: any) {
  console.error('[index] GET /api/songs 请求失败:', e?.message || e);
}

// —— 获取最后活动时间（含草稿，回退到已发布文章）——
let lastActiveTime = '';
try {
  const runtimeEnv = cfEnv as any;
  if (runtimeEnv?.DB) {
    const row = await runtimeEnv.DB.prepare(
      "SELECT MAX(updated_at) as last_active FROM posts"
    ).first();
    if (row?.last_active) {
      lastActiveTime = row.last_active as string;
    }
  }
} catch (e: any) {
  console.error('[index] 获取最后活动时间失败:', e?.message || e);
}
if (!lastActiveTime && allPosts.length > 0) {
  lastActiveTime = allPosts[0].updatedAt || allPosts[0].publishedAt || '';
}

// —— 按分类分组 ——
const postsByCategory: Record<string, ApiPost[]> = {};
allPosts.forEach(p => {
  const cid = p.categoryId || 'notes';
  if (!postsByCategory[cid]) postsByCategory[cid] = [];
  postsByCategory[cid].push(p);
});

// —— 工具函数 ——
const POSTS_PER_PAGE = 6;

function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

// 分类映射直接通过 SITE_CONFIG.categories 遍历获取，无需额外变量
---

<BaseLayout title="贝谟拉比">
	<!-- 模块2：Hero区 -->
	<section class="relative w-full h-[45vh] md:h-[60vh] min-h-[400px] overflow-hidden border-[#EAEAEA] dark:border-[#1A1A1A]">
		<img src="/images/hero-bg.avif" alt="" class="absolute inset-0 w-full h-full object-cover object-[center_40%]" />
		<div class="absolute inset-0 bg-black/10 dark:bg-black/40"></div>
		<!-- 梦幻星尘 Canvas：上沿覆盖 Hero，粒子从图片区就开始出现 -->
		<canvas id="hero-dust-canvas" class="absolute bottom-0 left-0 w-full h-[180px] md:h-[260px] z-[5] pointer-events-none"></canvas>
		<!-- 过渡区：高度与渐变位置不变 -->
		<div class="absolute -bottom-[1px] left-0 w-full h-[80px] md:h-[120px] overflow-hidden z-10 pointer-events-none">
			<!-- 底部融合遮罩：粒子柔和溶入页面背景 -->
			<div class="absolute inset-x-0 bottom-0 h-full bg-gradient-to-t from-[#FAFAFA] via-[#FAFAFA]/60 dark:from-[#0F0F0F] dark:via-[#0F0F0F]/60 to-transparent pointer-events-none"></div>
		</div>
	</section>

	<!-- 模块3：个人锚点区 -->
	<div class="max-w-[1200px] xl:max-w-[1400px] 2xl:max-w-[1600px] mx-auto px-4 md:px-6 lg:px-10 xl:px-12">
		<!-- 顶部行：头像 + Tab栏 -->
		<div class="flex md:grid md:grid-cols-[260px_1fr] xl:grid-cols-[280px_1fr] gap-4 md:gap-6 items-end relative z-10">
			<!-- 3.1 头像 -->
			<div class="w-[160px] md:w-full aspect-square rounded-[20px] bg-[#E8913A] md:-mt-[130px] xl:-mt-[140px] ring-4 ring-white dark:ring-[#0F0F0F] flex-shrink-0 overflow-hidden relative cursor-pointer transition-all duration-300 hover:shadow-xl hover:-translate-y-1.5 group">
				<img
					src={SITE_CONFIG.images.avatar}
					alt="头像"
					class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
					onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
				/>
				<div class="absolute inset-0 hidden items-center justify-center text-white font-bold">
					贝谟
				</div>
			</div>

			<!-- 3.2 PC Tab 长条栏 -->
			<div class="hidden md:flex flex-1 h-14 items-center px-6 rounded-full bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 shadow-sm hover:shadow-md transition-all duration-300">
				<span class="text-sm font-medium text-[#999] dark:text-[#666] border-r border-black/5 dark:border-white/10 pr-4 mr-4">分类</span>
				<div class="relative flex gap-1 z-0">
					<div id="pc-tab-slider" class="absolute top-0 bottom-0 left-0 rounded-full bg-white/80 dark:bg-[#2A2A2A]/80 backdrop-blur-md shadow-[0_2px_10px_-3px_rgba(0,0,0,0.05)] border border-white/50 dark:border-white/5 transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] z-[-1]"></div>
					{SITE_CONFIG.categories.map((cat, idx) => (
						<button
							data-tab={cat.id}
							data-active={idx === 0 ? 'true' : 'false'}
							class="relative z-10 px-5 py-1.5 text-sm font-medium transition-colors duration-300 outline-none select-none active:scale-95 text-[#999] hover:text-[#666] dark:text-[#666] dark:hover:text-[#EAEAEA] data-[active=true]:text-[#8B7CB3] data-[active=true]:dark:text-[#8B7CB3]"
						>
							{cat.name}
						</button>
					))}
				</div>
				<div class="ml-auto flex items-center gap-2 text-sm font-medium text-[#999]">
					<CalendarIcon />
					<span id="tab-datetime">--/--</span>
				</div>
			</div>

			<!-- 3.3 移动端 Tab 胶囊栏 -->
			<div class="flex md:hidden flex-1 h-12 items-center px-2 rounded-full bg-white/40 dark:bg-black/40 backdrop-blur-md shadow-sm border border-white/20 dark:border-white/5 overflow-hidden">
				<div class="relative flex gap-1 overflow-x-auto hide-scrollbar w-full items-center z-0">
					<div id="mobile-tab-slider" class="absolute top-0 bottom-0 left-0 rounded-full bg-[#8B7CB3] shadow-md transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] z-[-1]"></div>
					{SITE_CONFIG.categories.map((cat, idx) => (
						<button
							data-tab={cat.id}
							data-active={idx === 0 ? 'true' : 'false'}
							class="relative z-10 px-4 py-1.5 text-sm font-medium whitespace-nowrap transition-colors duration-300 outline-none select-none active:scale-95 text-[#666] dark:text-[#999] hover:text-[#1A1A1A] dark:hover:text-[#EAEAEA] data-[active=true]:text-white"
						>
							{cat.name}
						</button>
					))}
				</div>
			</div>
		</div>

		<!-- 内容行 -->
		<div class="mt-6 grid grid-cols-1 md:grid-cols-[260px_1fr] xl:grid-cols-[280px_1fr] gap-6">
			<!-- 3.4 左侧盒子区（PC only） -->
			<div class="hidden md:flex flex-col gap-4">
				<div id="sidebar-box-1" class="w-full min-h-[160px] rounded-[2rem] bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-5 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500 flex flex-col">
					<div class="flex justify-between items-center mb-4">
						<span id="calendar-title" class="text-xs font-bold text-[#8B7CB3] tracking-widest"></span>
						<div class="flex gap-1">
							<button onclick="console.log('prev month')" class="text-[#999] hover:text-[#8B7CB3] bg-transparent border-none cursor-pointer transition-colors p-1 flex items-center justify-center">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
							</button>
							<button onclick="console.log('next month')" class="text-[#999] hover:text-[#8B7CB3] bg-transparent border-none cursor-pointer transition-colors p-1 flex items-center justify-center">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
							</button>
						</div>
					</div>

					<div class="flex justify-between mb-2 px-1">
						<span class="text-[10px] font-medium text-[#999] w-full text-center">一</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">二</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">三</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">四</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">五</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">六</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">日</span>
					</div>

					<div id="calendar-grid" class="grid grid-cols-7 gap-1 flex-1 px-1"></div>

					<div class="border-t border-[#E0E0E0] dark:border-[#2A2A2A] mt-3 pt-3 flex justify-between items-center px-1">
						<div class="flex items-center gap-1.5 text-[#1A1A1A] dark:text-[#EAEAEA]">
							<svg class="w-3.5 h-3.5 text-[#8B7CB3]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
							<span class="text-[10px] font-bold">Today</span>
						</div>
						<span id="calendar-footer-date" class="text-[10px] font-mono font-medium text-[#8B7CB3] bg-[#8B7CB3]/10 px-2 py-0.5 rounded-md">--/--</span>
					</div>
				</div>
				<div id="sidebar-box-2" class="w-full rounded-[2rem] bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-5 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500 relative">
					<div class="flex items-center justify-between mb-4">
						<div class="flex items-center gap-2">
							<span class="text-[10px] font-bold text-[#8B7CB3] tracking-widest uppercase">Now Playing</span>
						</div>
						<div id="player-visualizer" class="flex items-end gap-[2px] h-3">
							<div class="w-[3px] bg-[#8B7CB3] rounded-full h-[60%] animate-pulse"></div>
							<div class="w-[3px] bg-[#8B7CB3] rounded-full h-[100%] animate-pulse" style="animation-delay: 0.2s"></div>
							<div class="w-[3px] bg-[#8B7CB3] rounded-full h-[40%] animate-pulse" style="animation-delay: 0.4s"></div>
							<div class="w-[3px] bg-[#8B7CB3] rounded-full h-[80%] animate-pulse" style="animation-delay: 0.1s"></div>
						</div>
					</div>

					<div class="flex gap-3 items-center">
						<div class="relative w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 bg-gradient-to-tr from-[#8B7CB3] to-[#C9BAE5] dark:to-[#4A3B73] shadow-inner">
							<img id="player-cover" src="" alt="cover" class="w-full h-full object-cover hidden" />
							<div id="player-cover-fallback" class="absolute inset-0 flex items-center justify-center text-white/60">
								<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm0-5.5c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1z"/></svg>
							</div>
						</div>
						
						<div class="flex-1 min-w-0 flex flex-col justify-center">
							<h4 id="player-title" class="text-[15px] font-bold text-[#1A1A1A] dark:text-[#EAEAEA] truncate tracking-tight">暂无音乐</h4>
							<p id="player-artist" class="text-xs text-[#666] dark:text-[#999] mt-0.5 truncate">-</p>
						</div>
					</div>

					<div class="mt-4 flex flex-col gap-1.5">
						<div class="relative w-full h-1.5 bg-[#E0E0E0] dark:bg-[#2A2A2A] rounded-full overflow-hidden cursor-pointer group/progress" id="player-progress-bar">
							<div id="player-progress" class="absolute top-0 left-0 h-full bg-[#8B7CB3] w-0 rounded-full group-hover/progress:bg-[#7A6BA2] transition-colors relative">
								<div class="absolute right-0 top-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full shadow opacity-0 group-hover/progress:opacity-100 transition-opacity"></div>
							</div>
						</div>
						<div class="flex justify-between items-center text-[10px] font-medium text-[#999] font-mono">
							<span id="player-current">0:00</span>
							<span id="player-duration">0:00</span>
						</div>
					</div>

					<div class="mt-1 flex justify-between items-center px-1">
						<button id="player-mode-btn" class="text-[#999] hover:text-[#8B7CB3] transition-colors" title="列表循环">
							<svg id="mode-icon-loop" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/></svg>
							<svg id="mode-icon-single" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M7 7h10v3l4-4-4-4v3H5v6h2V7z"/><circle cx="12" cy="15" r="2"/></svg>
							<svg id="mode-icon-shuffle" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/></svg>
						</button>
						
						<div class="flex items-center gap-4">
							<button id="player-prev" class="text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3] transition-colors">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
							</button>
							
							<button id="player-play" class="w-10 h-10 flex items-center justify-center rounded-full bg-[#1A1A1A] dark:bg-[#EAEAEA] text-white dark:text-[#1A1A1A] hover:bg-[#8B7CB3] dark:hover:bg-[#8B7CB3] hover:scale-105 active:scale-95 transition-all shadow-md">
								<svg id="icon-play" class="w-5 h-5 translate-x-[1px]" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
								<svg id="icon-pause" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
							</button>
							
							<button id="player-next" class="text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3] transition-colors">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
							</button>
						</div>

						<button id="player-list-btn" class="text-[#999] hover:text-[#8B7CB3] transition-colors relative">
							<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 15h18v-2H3v2zm0 4h18v-2H3v2zm0-8h18V9H3v2zm0-6v2h18V5H3z"/></svg>
						</button>
					</div>

					<!-- 播放列表弹窗 -->
					<div id="player-playlist" class="hidden absolute left-0 right-0 bottom-full mb-2 bg-white/90 dark:bg-[#1A1A1A]/90 backdrop-blur-xl rounded-2xl border border-white/20 dark:border-white/10 shadow-xl p-3 max-h-[280px] overflow-y-auto z-50">
						<div class="flex items-center justify-between mb-2 px-1">
							<span class="text-[10px] font-bold text-[#8B7CB3] tracking-widest uppercase">Playlist</span>
							<button id="playlist-close" class="text-[#999] hover:text-[#1A1A1A] dark:hover:text-[#EAEAEA] transition-colors cursor-pointer border-none bg-transparent">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
							</button>
						</div>
						<div id="playlist-items" class="space-y-1"></div>
					</div>

				<div id="songs-data" data-songs={JSON.stringify(songs)} class="hidden"></div>
				</div>
				<div id="sidebar-box-3" class="w-full rounded-[2rem] bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-5 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500">
					<div class="flex items-center justify-between mb-4">
						<span class="text-[10px] font-bold text-[#8B7CB3] tracking-widest uppercase">System Status</span>
						<div class="flex items-center gap-1.5">
							<span class="relative flex h-2 w-2">
								<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#7CB38B] opacity-75"></span>
								<span class="relative inline-flex rounded-full h-2 w-2 bg-[#7CB38B]"></span>
							</span>
							<span class="text-[10px] font-bold text-[#7CB38B] tracking-wide">运行中</span>
						</div>
					</div>

					<div class="grid grid-cols-2 gap-3">
						<div class="flex flex-col bg-white/40 dark:bg-[#1A1A1A]/40 backdrop-blur-sm p-3 rounded-2xl shadow-[0_2px_8px_-4px_rgba(0,0,0,0.05)] border border-white/20 dark:border-white/5 hover:border-[#8B7CB3]/30 transition-all duration-300 group">
							<div class="text-[#999] group-hover:text-[#8B7CB3] transition-colors mb-2">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
							</div>
							<div id="stat-runtime" class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] tracking-tight">--</div>
							<div class="text-[10px] text-[#999] mt-0.5">运行时间</div>
						</div>

						<div class="flex flex-col bg-white/40 dark:bg-[#1A1A1A]/40 backdrop-blur-sm p-3 rounded-2xl shadow-[0_2px_8px_-4px_rgba(0,0,0,0.05)] border border-white/20 dark:border-white/5 hover:border-[#8B7CB3]/30 transition-all duration-300 group">
							<div class="text-[#999] group-hover:text-[#8B7CB3] transition-colors mb-2">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
							</div>
							<div id="stat-last-active" data-last-active={lastActiveTime} class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] tracking-tight">--</div>
							<div class="text-[10px] text-[#999] mt-0.5">最后活动</div>
						</div>

						<div class="flex flex-col bg-white/40 dark:bg-[#1A1A1A]/40 backdrop-blur-sm p-3 rounded-2xl shadow-[0_2px_8px_-4px_rgba(0,0,0,0.05)] border border-white/20 dark:border-white/5 hover:border-[#8B7CB3]/30 transition-all duration-300 group">
							<div class="text-[#999] group-hover:text-[#8B7CB3] transition-colors mb-2">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
							</div>
							<div id="stat-categories" class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] tracking-tight">{SITE_CONFIG.categories.length}个</div>
							<div class="text-[10px] text-[#999] mt-0.5">站点分类</div>
						</div>

						<div class="flex flex-col bg-white/40 dark:bg-[#1A1A1A]/40 backdrop-blur-sm p-3 rounded-2xl shadow-[0_2px_8px_-4px_rgba(0,0,0,0.05)] border border-white/20 dark:border-white/5 hover:border-[#8B7CB3]/30 transition-all duration-300 group">
							<div class="text-[#999] group-hover:text-[#8B7CB3] transition-colors mb-2">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
							</div>
							<div id="stat-posts" class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] tracking-tight">{allPosts.length}篇</div>
							<div class="text-[10px] text-[#999] mt-0.5">已发文章</div>
						</div>
					</div>
				</div>
			</div>

			<!-- 3.5 右侧主容器区 —— 服务端渲染文章卡片 -->
			<div id="tab-panel-container" class="flex-1 min-h-[400px] w-full mt-4 md:mt-0">
				{SITE_CONFIG.categories.map(cat => {
					const catPosts = postsByCategory[cat.id] || [];
					const hasMore = catPosts.length > POSTS_PER_PAGE;
					return (
						<div class={`panel-${cat.id}`} data-panel={cat.id} style={`display: ${cat.id === 'notes' ? 'block' : 'none'}`}>
							<div id={`posts-${cat.id}`} class="flex flex-col gap-6">
								{catPosts.map((p, idx) => {
									const date = formatDate(p.publishedAt);
									const excerpt = p.excerpt || '';
									return (
										<a
											href={`/blog/${encodeURIComponent(p.slug)}`}
											class={`block no-underline post-card-item ${idx >= POSTS_PER_PAGE ? 'hidden post-card-hidden' : ''}`}
											data-cat={cat.id}
										>
											<article class="group relative bg-white dark:bg-[#1A1A1A] rounded-3xl p-5 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 flex flex-col-reverse md:flex-row gap-6 border border-transparent hover:border-[#8B7CB3]/20 overflow-hidden">
												<div class="flex-1 flex flex-col justify-center">
													<div class="flex items-center gap-3 mb-3">
														<span class="px-2.5 py-1 rounded-lg text-[10px] font-bold tracking-widest uppercase" style={`background-color:${cat.color}18;color:${cat.color}`}>
															{cat.name}
														</span>
														<span class="text-xs font-medium text-[#999] flex items-center gap-1.5">
															<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
															{date}
														</span>
													</div>

													<h3 class="text-xl font-bold text-[#1A1A1A] dark:text-[#EAEAEA] mb-3 group-hover:text-[#8B7CB3] transition-colors leading-snug">
														{p.title}
													</h3>
													{excerpt && (
														<p class="text-sm text-[#666] dark:text-[#888] leading-relaxed line-clamp-2 mb-4">
															{excerpt}
														</p>
													)}

													<div class="mt-auto flex items-center text-[#8B7CB3] text-sm font-bold opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
														Read Article
														<svg class="w-4 h-4 ml-1 mt-[1px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
													</div>
												</div>
												<div class="w-full md:w-[260px] shrink-0 aspect-video md:aspect-auto md:h-[180px] rounded-2xl overflow-hidden bg-[#F5F5F5] dark:bg-[#252525] relative">
													{p.coverImage ? (
														<img src={p.coverImage} alt="" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
													) : (
														<div class="absolute inset-0 flex items-center justify-center text-[#CCC] dark:text-[#444] transition-transform duration-700 group-hover:scale-110">
															<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
														</div>
													)}
												</div>
											</article>
										</a>
									);
								})}
							</div>

							{catPosts.length === 0 && (
								<div id={`empty-${cat.id}`} class="w-full min-h-[300px] rounded-3xl border-2 border-dashed border-[#E0E0E0] dark:border-[#2A2A2A] flex items-center justify-center text-[#999] text-sm">
									暂无文章
								</div>
							)}

							{hasMore && (
								<div id={`load-more-${cat.id}`} class="w-full flex justify-center mt-8 mb-4">
									<button
										class="load-more-btn group relative px-6 py-2.5 rounded-full bg-white dark:bg-[#252525] shadow-[0_2px_10px_-3px_rgba(0,0,0,0.05)] hover:shadow-md border border-transparent hover:border-[#8B7CB3]/20 transition-all duration-300 active:scale-95 overflow-hidden flex items-center gap-2 cursor-pointer outline-none"
										data-cat={cat.id}
									>
										<svg class="w-4 h-4 text-[#999] group-hover:text-[#8B7CB3] transition-all duration-300 group-hover:translate-y-[2px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
										<span class="text-sm font-medium text-[#666] dark:text-[#999] group-hover:text-[#1A1A1A] group-hover:dark:text-[#EAEAEA] transition-colors">加载更多</span>
									</button>
								</div>
							)}
						</div>
					);
				})}
			</div>
		</div>
	</div>
</BaseLayout>

<script is:inline>
	// ============================================================
	// Tab 切换、果冻滑块、日历、运行时 —— 包在 page-load 确保 DOM 就绪
	// ============================================================
	document.addEventListener('astro:page-load', () => {
	const tabButtons = document.querySelectorAll('[data-tab]');
	const panelClasses = ['panel-notes', 'panel-critique', 'panel-stack', 'panel-body', 'panel-transit', 'panel-archive'];

	function syncSliders() {
		const activePcBtn = document.querySelector('.hidden.md\\:flex [data-tab][data-active="true"]');
		const pcSlider = document.getElementById('pc-tab-slider');
		if (activePcBtn && pcSlider) {
			pcSlider.style.transform = `translateX(${activePcBtn.offsetLeft}px)`;
			pcSlider.style.width = `${activePcBtn.offsetWidth}px`;
		}

		const activeMobileBtn = document.querySelector('.md\\:hidden [data-tab][data-active="true"]');
		const mobileSlider = document.getElementById('mobile-tab-slider');
		if (activeMobileBtn && mobileSlider) {
			mobileSlider.style.transform = `translateX(${activeMobileBtn.offsetLeft}px)`;
			mobileSlider.style.width = `${activeMobileBtn.offsetWidth}px`;
		}
	}

	tabButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			const tabId = btn.dataset.tab;

			tabButtons.forEach(b => {
				b.dataset.active = (b.dataset.tab === tabId) ? "true" : "false";
			});

			syncSliders();

			// 切换面板
			panelClasses.forEach(cls => {
				const panel = document.querySelector('.' + cls);
				if (panel) panel.style.display = 'none';
			});

			const target = document.querySelector('.panel-' + tabId);
			if (target) {
				target.style.display = 'block';
				target.animate([
					{ opacity: 0, transform: 'translateY(10px)' },
					{ opacity: 1, transform: 'translateY(0)' }
				], {
					duration: 400,
					easing: 'cubic-bezier(0.16, 1, 0.3, 1)'
				});
			}
		});
	});

	// "加载更多"按钮事件 —— 显示隐藏的卡片
	const POSTS_PER_PAGE = 6;
	document.querySelectorAll('.load-more-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const catId = btn.dataset.cat;
			if (!catId) return;

			const hiddenCards = document.querySelectorAll(`.post-card-hidden[data-cat="${catId}"]`);
			const toShow = Math.min(hiddenCards.length, POSTS_PER_PAGE);

			for (let i = 0; i < toShow; i++) {
				hiddenCards[i].classList.remove('hidden', 'post-card-hidden');
			}

			// 如果已全部显示，隐藏"加载更多"按钮
			const remaining = document.querySelectorAll(`.post-card-hidden[data-cat="${catId}"]`).length;
			if (remaining === 0) {
				btn.closest('[id^="load-more-"]')?.classList.add('hidden');
			}
		});
	});

	window.addEventListener('resize', syncSliders);
	document.addEventListener('DOMContentLoaded', () => {
		setTimeout(syncSliders, 50);
	});

	// 日期时间更新
	function updateDateTime() {
		const now = new Date();
		const year = now.getFullYear();
		const month = now.getMonth() + 1;
		const day = now.getDate();
		const hours = String(now.getHours()).padStart(2, '0');
		const minutes = String(now.getMinutes()).padStart(2, '0');
		const el = document.getElementById('tab-datetime');
		if (el) el.textContent = `${year}-${month}-${day} ${hours}:${minutes}`;
		const footerDateEl = document.getElementById('calendar-footer-date');
		if (footerDateEl) footerDateEl.textContent = `${month}-${day}`;
	}
	updateDateTime();
	setInterval(updateDateTime, 60000);

	function renderCalendar(year, month) {
		const titleEl = document.getElementById('calendar-title');
		const gridEl = document.getElementById('calendar-grid');
		if (!titleEl || !gridEl) return;

		titleEl.textContent = `${year}年 ${month + 1}月`;

		const today = new Date();
		const daysInMonth = new Date(year, month + 1, 0).getDate();
		const firstDay = new Date(year, month, 1).getDay();
		const startOffset = (firstDay + 6) % 7;
		const prevMonthDays = new Date(year, month, 0).getDate();

		let html = '';

		for (let i = startOffset - 1; i >= 0; i--) {
			const d = prevMonthDays - i;
			html += `<div class="text-xs w-full aspect-square flex items-center justify-center rounded-full text-[#CCC] dark:text-[#555]">${d}</div>`;
		}

		for (let d = 1; d <= daysInMonth; d++) {
			const isToday = year === today.getFullYear() && month === today.getMonth() && d === today.getDate();
			if (isToday) {
				html += `<div class="text-xs w-full aspect-square flex items-center justify-center rounded-full border border-[#8B7CB3] text-[#8B7CB3] font-medium">${d}</div>`;
			} else {
				html += `<div class="text-xs w-full aspect-square flex items-center justify-center rounded-full text-[#666] dark:text-[#999]">${d}</div>`;
			}
		}

		const totalCells = startOffset + daysInMonth;
		const rows = totalCells <= 35 ? 35 : 42;
		const remaining = rows - totalCells;
		for (let d = 1; d <= remaining; d++) {
			html += `<div class="text-xs w-full aspect-square flex items-center justify-center rounded-full text-[#CCC] dark:text-[#555]">${d}</div>`;
		}

		gridEl.innerHTML = html;
	}

	renderCalendar(new Date().getFullYear(), new Date().getMonth());

	const siteStart = new Date('2026-04-26');
	const now = new Date();
	const runtimeDays = Math.floor((now - siteStart) / (1000 * 60 * 60 * 24));
	const runtimeEl = document.getElementById('stat-runtime');
	if (runtimeEl) runtimeEl.textContent = runtimeDays + '天';

	const lastActiveEl = document.getElementById('stat-last-active');
	if (lastActiveEl) {
		const lastActiveStr = lastActiveEl.dataset.lastActive;
		if (lastActiveStr) {
			const lastActiveDate = new Date(lastActiveStr);
			const diffMs = now - lastActiveDate;
			if (diffMs < 0) {
				lastActiveEl.textContent = '未来';
			} else {
				const diffSec = Math.floor(diffMs / 1000);
				const diffMin = Math.floor(diffSec / 60);
				const diffHour = Math.floor(diffMin / 60);
				const diffDay = Math.floor(diffHour / 24);
				const diffMonth = Math.floor(diffDay / 30);
				const diffYear = Math.floor(diffDay / 365);
				let text = '刚刚';
				if (diffYear > 0) text = diffYear + '年前';
				else if (diffMonth > 0) text = diffMonth + '个月前';
				else if (diffDay > 0) text = diffDay + '天前';
				else if (diffHour > 0) text = diffHour + '小时前';
				else if (diffMin > 0) text = diffMin + '分钟前';
				lastActiveEl.textContent = text;
			}
		} else {
			lastActiveEl.textContent = '暂无';
		}
	}
	}); // end astro:page-load
</script>

<script is:inline>
	// —— 首页播放器：从全局状态加载歌曲 & 同步 Sidebar UI ——
	document.addEventListener('astro:page-load', () => {
		const state = window.playerState;
		if (!state) return;

		// 初次加载：从隐藏元素读取歌曲数据
		if (!state.initialized) {
			const songsEl = document.getElementById('songs-data');
			if (songsEl) {
				try {
					const songs = JSON.parse(songsEl.dataset.songs || '[]');
					if (songs.length > 0) {
						state.songs = songs;
						state.initialized = true;
					}
				} catch {}
			}
		}

		const audio = document.getElementById('global-audio');
		if (!audio) return;

		// DOM 引用
		const playBtn = document.getElementById('player-play');
		const prevBtn = document.getElementById('player-prev');
		const nextBtn = document.getElementById('player-next');
		const modeBtn = document.getElementById('player-mode-btn');
		const listBtn = document.getElementById('player-list-btn');
		const playlistEl = document.getElementById('player-playlist');
		const playlistClose = document.getElementById('playlist-close');
		const playlistItems = document.getElementById('playlist-items');
		const progressBar = document.getElementById('player-progress-bar');
		const progressEl = document.getElementById('player-progress');
		const currentEl = document.getElementById('player-current');
		const durationEl = document.getElementById('player-duration');
		const titleEl = document.getElementById('player-title');
		const artistEl = document.getElementById('player-artist');
		const coverEl = document.getElementById('player-cover');
		const coverFallback = document.getElementById('player-cover-fallback');
		const iconPlay = document.getElementById('icon-play');
		const iconPause = document.getElementById('icon-pause');
		const modeIconLoop = document.getElementById('mode-icon-loop');
		const modeIconSingle = document.getElementById('mode-icon-single');
		const modeIconShuffle = document.getElementById('mode-icon-shuffle');
		const visualizer = document.getElementById('player-visualizer');

		function formatTime(sec) {
			if (!sec || isNaN(sec)) return '0:00';
			const m = Math.floor(sec / 60);
			const s = Math.floor(sec % 60);
			return m + ':' + String(s).padStart(2, '0');
		}

		function updateSidebarSongUI() {
			if (!state.songs.length) return;
			const song = state.songs[state.currentIndex];
			if (!song) return;
			titleEl.textContent = song.title || '未知歌曲';
			artistEl.textContent = (song.artist || '') + (song.album ? ' · ' + song.album : '');
			durationEl.textContent = formatTime(song.duration);
			if (song.cover_url) {
				coverEl.src = song.cover_url;
				coverEl.classList.remove('hidden');
				coverFallback.classList.add('hidden');
			} else {
				coverEl.classList.add('hidden');
				coverFallback.classList.remove('hidden');
			}
		}

		function updateSidebarPlayUI() {
			if (state.isPlaying) {
				iconPlay.classList.add('hidden');
				iconPause.classList.remove('hidden');
				visualizer.classList.remove('opacity-30');
			} else {
				iconPlay.classList.remove('hidden');
				iconPause.classList.add('hidden');
				visualizer.classList.add('opacity-30');
			}
		}

		function updateModeUI() {
			modeIconLoop.classList.add('hidden');
			modeIconSingle.classList.add('hidden');
			modeIconShuffle.classList.add('hidden');
			if (state.playMode === 'single') {
				modeIconSingle.classList.remove('hidden');
				modeBtn.title = '单曲循环';
			} else if (state.playMode === 'shuffle') {
				modeIconShuffle.classList.remove('hidden');
				modeBtn.title = '随机播放';
			} else {
				modeIconLoop.classList.remove('hidden');
				modeBtn.title = '列表循环';
			}
		}

		function updatePlaylistUI() {
			if (!playlistItems) return;
			playlistItems.innerHTML = state.songs.map((s, i) =>
				'<div class="flex items-center gap-2 p-2 rounded-xl cursor-pointer transition-colors ' + (i === state.currentIndex ? 'bg-[#8B7CB3]/10' : 'hover:bg-black/5 dark:hover:bg-white/5') + '" onclick="window.playerPlayIndex(' + i + ')">' +
					'<div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-[#8B7CB3] to-[#C9BAE5] dark:to-[#4A3B73] flex items-center justify-center text-white shrink-0 text-[10px] font-bold">' + (i + 1) + '</div>' +
					'<div class="flex-1 min-w-0">' +
						'<div class="text-xs font-bold text-[#1A1A1A] dark:text-[#EAEAEA] truncate">' + s.title + '</div>' +
						'<div class="text-[10px] text-[#999] truncate">' + (s.artist || '') + '</div>' +
					'</div>' +
					(i === state.currentIndex && state.isPlaying ? '<div class="flex items-end gap-[1px] h-3"><div class="w-[2px] bg-[#8B7CB3] rounded-full h-[60%] animate-pulse"></div><div class="w-[2px] bg-[#8B7CB3] rounded-full h-[100%] animate-pulse" style="animation-delay:0.1s"></div><div class="w-[2px] bg-[#8B7CB3] rounded-full h-[40%] animate-pulse" style="animation-delay:0.2s"></div></div>' : '') +
				'</div>'
			).join('');
		}

		// 初始同步
		updateSidebarSongUI();
		updateSidebarPlayUI();
		updateModeUI();
		updatePlaylistUI();

		// 进度条
		audio.addEventListener('timeupdate', function onTime() {
			const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
			if (progressEl) progressEl.style.width = pct + '%';
			if (currentEl) currentEl.textContent = formatTime(audio.currentTime);
		});

		audio.addEventListener('loadedmetadata', function onMeta() {
			if (durationEl) durationEl.textContent = formatTime(audio.duration);
		});

		// 进度条点击
		if (progressBar) {
			progressBar.addEventListener('click', (e) => {
				const rect = progressBar.getBoundingClientRect();
				const pct = (e.clientX - rect.left) / rect.width;
				if (audio.duration) audio.currentTime = pct * audio.duration;
			});
		}

		// 按钮 → 全局状态/音频
		if (playBtn) playBtn.addEventListener('click', () => window.playerToggle && window.playerToggle());
		if (prevBtn) prevBtn.addEventListener('click', () => {
			const s = window.playerState;
			if (!s || !s.songs.length) return;
			if (s.playMode === 'shuffle') s.currentIndex = Math.floor(Math.random() * s.songs.length);
			else s.currentIndex = (s.currentIndex - 1 + s.songs.length) % s.songs.length;
			const song = s.songs[s.currentIndex];
			if (song) { audio.src = song.audio_url; audio.play().catch(() => {}); }
		});
		if (nextBtn) nextBtn.addEventListener('click', () => {
			const s = window.playerState;
			if (!s || !s.songs.length) return;
			if (s.playMode === 'shuffle') s.currentIndex = Math.floor(Math.random() * s.songs.length);
			else s.currentIndex = (s.currentIndex + 1) % s.songs.length;
			const song = s.songs[s.currentIndex];
			if (song) { audio.src = song.audio_url; audio.play().catch(() => {}); }
		});
		if (modeBtn) modeBtn.addEventListener('click', () => {
			const modes = ['loop', 'single', 'shuffle'];
			const idx = modes.indexOf(state.playMode);
			state.playMode = modes[(idx + 1) % 3];
			updateModeUI();
		});

		// 播放列表
		if (listBtn) listBtn.addEventListener('click', () => {
			playlistEl.classList.toggle('hidden');
			if (!playlistEl.classList.contains('hidden')) updatePlaylistUI();
		});
		if (playlistClose) playlistClose.addEventListener('click', () => playlistEl.classList.add('hidden'));

		window.playerPlayIndex = (index) => {
			state.currentIndex = index;
			const song = state.songs[index];
			if (song) {
				audio.src = song.audio_url;
				audio.play().catch(() => {});
			}
		};

		// 监听全局歌曲变化事件
		window.addEventListener('player-song-change', (e) => {
			updateSidebarSongUI();
			updatePlaylistUI();
		});

		window.addEventListener('player-state-sync', (e) => {
			updateSidebarSongUI();
			updateSidebarPlayUI();
			updateModeUI();
			updatePlaylistUI();
		});

		window.addEventListener('player-mode-change', () => updateModeUI());

		// 初始化视觉
		visualizer && state.songs.length && !state.isPlaying && visualizer.classList.add('opacity-30');

		// Hero 过渡区梦幻星尘 Canvas（流星划过版）
		let heroDustAnimId = null;
		let heroDustResizeHandler = null;
		let heroDustVisHandler = null;

		function initHeroDustCanvas() {
			const canvas = document.getElementById('hero-dust-canvas');
			if (!canvas) return;

			if (heroDustAnimId) {
				cancelAnimationFrame(heroDustAnimId);
				heroDustAnimId = null;
			}
			if (heroDustResizeHandler) {
				window.removeEventListener('resize', heroDustResizeHandler);
			}
			if (heroDustVisHandler) {
				document.removeEventListener('visibilitychange', heroDustVisHandler);
			}

			const ctx = canvas.getContext('2d');
			let width, height;
			let particles = [];

			function resize() {
				const rect = canvas.getBoundingClientRect();
				width = rect.width;
				height = rect.height;
				const dpr = window.devicePixelRatio || 1;
				canvas.width = width * dpr;
				canvas.height = height * dpr;
				canvas.style.width = width + 'px';
				canvas.style.height = height + 'px';
				ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
			}

			function createParticles() {
				particles = [];
				const layers = [
					{ count: 24, sizeMin: 3, sizeMax: 7, speedMin: 0.6, speedMax: 1.4, opacityMin: 0.15, opacityMax: 0.4, glow: 8, colors: ['#FF6B9D', '#f90275', '#8B7CB3'], types: ['star', 'cross'] },
					{ count: 20, sizeMin: 5, sizeMax: 10, speedMin: 0.4, speedMax: 1.0, opacityMin: 0.1, opacityMax: 0.25, glow: 12, colors: ['#FF6B9D', '#39C5BB'], types: ['moon', 'star'] },
					{ count: 16, sizeMin: 2, sizeMax: 4, speedMin: 0.8, speedMax: 1.8, opacityMin: 0.2, opacityMax: 0.45, glow: 6, colors: ['#f90275', '#FF1A4D', '#8B7CB3'], types: ['cross', 'star'] }
				];

				layers.forEach(layer => {
					for (let i = 0; i < layer.count; i++) {
						const speed = layer.speedMin + Math.random() * (layer.speedMax - layer.speedMin);
						const angle = Math.PI / 4 + (Math.random() - 0.5) * 0.15;
						let x, y, life;
						const spawnZone = Math.random();
						if (spawnZone > 0.5) {
							// 已在画布内：正在划过
							x = Math.random() * width;
							y = Math.random() * height;
							life = Math.floor(Math.random() * 120);
						} else if (spawnZone > 0.25) {
							// 从左侧边缘外准备进入
							x = -Math.random() * 40;
							y = Math.random() * height;
							life = 0;
						} else {
							// 从顶部边缘外准备进入
							x = Math.random() * width;
							y = -Math.random() * 40;
							life = 0;
						}
						particles.push({
							x, y,
							size: layer.sizeMin + Math.random() * (layer.sizeMax - layer.sizeMin),
							type: layer.types[Math.floor(Math.random() * layer.types.length)],
							color: layer.colors[Math.floor(Math.random() * layer.colors.length)],
							speedX: speed * Math.cos(angle),
							speedY: speed * Math.sin(angle),
							rotation: Math.random() * Math.PI * 2,
							rotationSpeed: (Math.random() - 0.5) * 0.02,
							baseOpacity: layer.opacityMin + Math.random() * (layer.opacityMax - layer.opacityMin),
							glow: layer.glow + Math.random() * 4,
							life
						});
					}
				});
			}

			function drawStar(c, x, y, size, rotation) {
				c.save();
				c.translate(x, y);
				c.rotate(rotation);
				c.beginPath();
				const outer = size;
				const inner = size * 0.35;
				for (let i = 0; i < 8; i++) {
					const r = i % 2 === 0 ? outer : inner;
					const angle = (i * Math.PI) / 4 - Math.PI / 2;
					const px = Math.cos(angle) * r;
					const py = Math.sin(angle) * r;
					if (i === 0) c.moveTo(px, py);
					else c.lineTo(px, py);
				}
				c.closePath();
				c.fill();
				c.restore();
			}

			function drawMoon(c, x, y, size, rotation) {
				c.save();
				c.translate(x, y);
				c.rotate(rotation);
				c.beginPath();
				c.arc(0, 0, size, -Math.PI * 0.6, Math.PI * 0.6);
				c.bezierCurveTo(size * 0.15, size * 0.5, size * 0.15, -size * 0.5, size * Math.cos(-Math.PI * 0.6), size * Math.sin(-Math.PI * 0.6));
				c.closePath();
				c.fill();
				c.restore();
			}

			function drawCross(c, x, y, size, rotation) {
				c.save();
				c.translate(x, y);
				c.rotate(rotation);
				const s = size * 0.22;
				const l = size;
				c.beginPath();
				c.moveTo(0, -l); c.lineTo(s, -l + s * 2.5); c.lineTo(0, -l + s * 4); c.lineTo(-s, -l + s * 2.5); c.closePath(); c.fill();
				c.beginPath();
				c.moveTo(0, l); c.lineTo(s, l - s * 2.5); c.lineTo(0, l - s * 4); c.lineTo(-s, l - s * 2.5); c.closePath(); c.fill();
				c.beginPath();
				c.moveTo(-l, 0); c.lineTo(-l + s * 2.5, s); c.lineTo(-l + s * 4, 0); c.lineTo(-l + s * 2.5, -s); c.closePath(); c.fill();
				c.beginPath();
				c.moveTo(l, 0); c.lineTo(l - s * 2.5, s); c.lineTo(l - s * 4, 0); c.lineTo(l - s * 2.5, -s); c.closePath(); c.fill();
				c.restore();
			}

			function draw() {
				ctx.clearRect(0, 0, width, height);
				particles.forEach(p => {
					let alpha = p.baseOpacity;
					const fadeInFrames = 30;
					// 淡入
					if (p.life < fadeInFrames) {
						alpha *= (p.life / fadeInFrames);
					}
					// 接近右下边界时淡出，避免截断感
					const distToEdge = Math.min(width + 40 - p.x, height + 40 - p.y);
					if (distToEdge < 50) {
						alpha *= Math.max(0, distToEdge / 50);
					}

					ctx.save();
					ctx.globalAlpha = Math.max(0, alpha);
					ctx.shadowBlur = p.glow;
					ctx.shadowColor = p.color;
					ctx.fillStyle = p.color;
					switch (p.type) {
						case 'star': drawStar(ctx, p.x, p.y, p.size, p.rotation); break;
						case 'moon': drawMoon(ctx, p.x, p.y, p.size, p.rotation); break;
						case 'cross': drawCross(ctx, p.x, p.y, p.size, p.rotation); break;
					}
					ctx.restore();
				});
			}

			function update() {
				particles.forEach(p => {
					p.life++;
					p.x += p.speedX;
					p.y += p.speedY;
					p.rotation += p.rotationSpeed;

					// 飞出边界后从左上边缘重新进入，循环不息
					if (p.x > width + 40 || p.y > height + 40) {
						if (Math.random() > 0.5) {
							p.x = -Math.random() * 40;
							p.y = Math.random() * height;
						} else {
							p.x = Math.random() * width;
							p.y = -Math.random() * 40;
						}
						p.life = 0;
					}
				});
			}

			function animate() {
				update();
				draw();
				heroDustAnimId = requestAnimationFrame(animate);
			}

			resize();
			createParticles();
			animate();

			heroDustResizeHandler = () => { resize(); createParticles(); };
			window.addEventListener('resize', heroDustResizeHandler);

			heroDustVisHandler = () => {
				if (document.hidden) {
					cancelAnimationFrame(heroDustAnimId);
				} else {
					animate();
				}
			};
			document.addEventListener('visibilitychange', heroDustVisHandler);
		}

		initHeroDustCanvas();
		document.addEventListener('astro:page-load', initHeroDustCanvas);
	});
</script>



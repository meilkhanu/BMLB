	<script is:inline>
		function toggleDarkMode() {
			document.documentElement.classList.toggle('dark');
			const isDark = document.documentElement.classList.contains('dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
			updateThemeIcon(isDark);
		}

		function updateThemeIcon(isDark) {
			const sun = document.getElementById('theme-sun');
			const moon = document.getElementById('theme-moon');
			if (sun && moon) {
				if (isDark) {
					sun.classList.add('hidden');
					moon.classList.remove('hidden');
				} else {
					sun.classList.remove('hidden');
					moon.classList.add('hidden');
				}
			}
		}

		// 初始化暗色模式
		const savedTheme = localStorage.getItem('theme');
		if (savedTheme === 'dark') {
			document.documentElement.classList.add('dark');
			updateThemeIcon(true);
		} else {
			updateThemeIcon(false);
		}

		function toggleMobileMenu() {
			console.log('menu');
		}

		// Tab 切换、果冻滑块与面板动画
		const tabButtons = document.querySelectorAll('[data-tab]');
		const panelClasses = ['panel-notes', 'panel-critique', 'panel-stack', 'panel-body', 'panel-transit', 'panel-archive'];

		// 果冻滑块引擎：精准捕获激活状态按钮的 X 轴偏移量和宽度
		function syncSliders() {
			const activePcBtn = document.querySelector('.hidden.md\\:flex [data-tab][data-active="true"]');
			const pcSlider = document.getElementById('pc-tab-slider');
			if(activePcBtn && pcSlider) {
				pcSlider.style.transform = `translateX(${activePcBtn.offsetLeft}px)`;
				pcSlider.style.width = `${activePcBtn.offsetWidth}px`;
			}
			
			const activeMobileBtn = document.querySelector('.md\\:hidden [data-tab][data-active="true"]');
			const mobileSlider = document.getElementById('mobile-tab-slider');
			if(activeMobileBtn && mobileSlider) {
				mobileSlider.style.transform = `translateX(${activeMobileBtn.offsetLeft}px)`;
				mobileSlider.style.width = `${activeMobileBtn.offsetWidth}px`;
			}
		}

		tabButtons.forEach(btn => {
			btn.addEventListener('click', () => {
				const tabId = btn.dataset.tab;

				// 1. 同步所有按钮的数据状态
				tabButtons.forEach(b => {
					b.dataset.active = (b.dataset.tab === tabId) ? "true" : "false";
				});

				// 2. 触发滑块追随动画
				syncSliders();

				// 3. 面板动画逻辑保持不变
				panelClasses.forEach(cls => {
					const panel = document.querySelector('.' + cls);
					if (panel) panel.style.display = 'none';
				});

				const target = document.querySelector('.panel-' + tabId);
				if (target) {
					target.style.display = 'block';
					target.animate([
						{ opacity: 0, transform: 'translateY(10px)' }, 
						{ opacity: 1, transform: 'translateY(0)' }
					], { 
						duration: 400, 
						easing: 'cubic-bezier(0.16, 1, 0.3, 1)' 
					});
				}
			});
		});

		// 页面尺寸变动或初次加载完成时，进行物理坐标矫正
		window.addEventListener('resize', syncSliders);
		document.addEventListener('DOMContentLoaded', () => {
			// 增加一点小延迟，确保特殊字体加载完毕，算出的宽度才是最准确的
			setTimeout(syncSliders, 50); 
		});

		// 导航栏滚动效果（简化版：只控制阴影深浅）
		const nav = document.getElementById('site-nav');
		function handleScroll() {
			if (window.scrollY > 100) {
				nav.classList.add('scrolled');
			} else {
				nav.classList.remove('scrolled');
			}
		}
		window.addEventListener('scroll', handleScroll);
		handleScroll();

		//日期时间更新
		function updateDateTime() {
			const now = new Date();
			const year = now.getFullYear();
			const month = now.getMonth() + 1;
			const day = now.getDate();
			const hours = String(now.getHours()).padStart(2, '0');
			const minutes = String(now.getMinutes()).padStart(2, '0');
			//更新顶部Tab栏日期时间显示
			const el = document.getElementById('tab-datetime');
			if (el) el.textContent = `${year}-${month}-${day} ${hours}:${minutes}`;
			// 更新日历底部 Today 胶囊
			const footerDateEl = document.getElementById('calendar-footer-date');
			if (footerDateEl) footerDateEl.textContent = `${month}-${day}`;
		}
		updateDateTime();
		setInterval(updateDateTime, 60000);

		function renderCalendar(year, month) {
			const titleEl = document.getElementById('calendar-title');
			const gridEl = document.getElementById('calendar-grid');
			if (!titleEl || !gridEl) return;

			titleEl.textContent = `${year}年 ${month + 1}月`;

			const today = new Date();
			const daysInMonth = new Date(year, month + 1, 0).getDate();
			const firstDay = new Date(year, month, 1).getDay();
			const startOffset = (firstDay + 6) % 7;
			const prevMonthDays = new Date(year, month, 0).getDate();

			let html = '';

			for (let i = startOffset - 1; i >= 0; i--) {
				const d = prevMonthDays - i;
				html += `<div class="text-xs w-full aspect-square flex items-center justify-center rounded-full text-[#CCC] dark:text-[#555]">${d}</div>`;
			}

			for (let d = 1; d <= daysInMonth; d++) {
				const isToday = year === today.getFullYear() && month === today.getMonth() && d === today.getDate();
				if (isToday) {
					html += `<div class="text-xs w-full aspect-square flex items-center justify-center rounded-full border border-[#8B7CB3] text-[#8B7CB3] font-medium">${d}</div>`;
				} else {
					html += `<div class="text-xs w-full aspect-square flex items-center justify-center rounded-full text-[#666] dark:text-[#999]">${d}</div>`;
				}
			}

			const totalCells = startOffset + daysInMonth;
			const rows = totalCells <= 35 ? 35 : 42;
			const remaining = rows - totalCells;
			for (let d = 1; d <= remaining; d++) {
				html += `<div class="text-xs w-full aspect-square flex items-center justify-center rounded-full text-[#CCC] dark:text-[#555]">${d}</div>`;
			}

			gridEl.innerHTML = html;
		}

		renderCalendar(new Date().getFullYear(), new Date().getMonth());

		function togglePlay() {
			console.log('play');
		}

		const siteStart = new Date('2026-04-26');
		const now = new Date();
		const runtimeDays = Math.floor((now - siteStart) / (1000 * 60 * 60 * 24));
		const runtimeEl = document.getElementById('stat-runtime');
		if (runtimeEl) runtimeEl.textContent = runtimeDays + '天';

		function updateRuntime() {
			const start = new Date('2026-04-26T00:00:00');
			const now = new Date();
			const diff = now - start;
			const months = Math.floor(diff / (1000 * 60 * 60 * 24 * 30));
			const days = Math.floor((diff % (1000 * 60 * 60 * 24 * 30)) / (1000 * 60 * 60 * 24));
			const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
			let parts = [];
			if (months > 0) parts.push(months + '个月');
			if (days > 0) parts.push(days + '天');
			if (hours > 0 || (months === 0 && days === 0)) parts.push(hours + '小时');
			const el = document.getElementById('site-runtime');
			if (el) el.textContent = '本站已运行 ' + parts.join('');
		}
		updateRuntime();
		setInterval(updateRuntime, 1000);
    
    // 监听暗黑模式 class 切换，确保无缝平滑过渡
    const observer = new MutationObserver(() => {
        // 仅仅是触发重新评估 isDark，下一帧 animate 就会自动更新颜色
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
	// 页脚星空鼠标视差交互 (全屏无缝监听版)
		const footerPattern = document.getElementById('footer-pattern');

		if (footerPattern) {
			// 将监听器挂载到 window 上，无论鼠标在网页哪个角落，星空都会呼应
			window.addEventListener('mousemove', (e) => {
				// 以整个浏览器窗口宽度/高度为基准，计算 -0.5 到 +0.5 的相对比例
				const x = e.clientX / window.innerWidth - 0.5;
				const y = e.clientY / window.innerHeight - 0.5;
				
				// 保持 200px 的大幅度拉扯感
				const moveX = x * -200; 
				const moveY = y * -200;

				requestAnimationFrame(() => {
					footerPattern.style.transform = `translate(${moveX}px, ${moveY}px)`;
				});
			});
			// （彻底移除了 mouseleave 事件，消灭鼠标移出时的回弹割裂感）
		}
	// 移动端全屏菜单控制逻辑
		let isMobileMenuOpen = false;
		function toggleMobileMenu() {
			const menu = document.getElementById('mobile-menu');
			const links = document.querySelectorAll('.mobile-nav-link');
			const footer = document.getElementById('mobile-menu-footer');
			
			isMobileMenuOpen = !isMobileMenuOpen;

			if (isMobileMenuOpen) {
				// 1. 展开遮罩，阻止背景滚动
				menu.classList.remove('opacity-0', 'pointer-events-none');
				document.body.style.overflow = 'hidden';
				
				// 2. 触发文字错落上浮动画
				setTimeout(() => {
					links.forEach(link => {
						link.classList.remove('translate-x-12', 'opacity-0');
					});
					footer.classList.remove('translate-x-12', 'opacity-0');
				}, 50); // 微小延迟确保 CSS Transition 能捕捉到变化
			} else {
				// 1. 撤去遮罩，恢复滚动
				menu.classList.add('opacity-0', 'pointer-events-none');
				document.body.style.overflow = '';
				
				// 2. 文字瞬间归位，为下一次展开做准备
				links.forEach(link => {
					link.classList.add('translate-x-12', 'opacity-0');
				});
				footer.classList.add('translate-x-12', 'opacity-0');
			}
		}
	</script>
</body>
</html>


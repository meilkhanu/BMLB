---
import { SITE_CONFIG } from '../config.ts';
import SunIcon from '../components/icons/SunIcon.astro';
import MoonIcon from '../components/icons/MoonIcon.astro';
import SearchIcon from '../components/icons/SearchIcon.astro';
import UserIcon from '../components/icons/UserIcon.astro';
import HamburgerIcon from '../components/icons/HamburgerIcon.astro';
import CalendarIcon from '../components/icons/CalendarIcon.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
	<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{SITE_CONFIG.siteName}</title>
</head>
<body class="bg-[#FAFAFA] dark:bg-[#0F0F0F]">
	<!-- 模块1：导航栏 -->
	<nav id="site-nav" class="fixed top-0 left-0 w-full h-16 z-50 bg-[rgba(250,250,250,0.85)] dark:bg-[rgba(15,15,15,0.85)] backdrop-blur-[12px] shadow-sm transition-all duration-300">
		<div class="flex justify-between items-center px-6 h-full">
			<!-- 左侧站点名 -->
			<a href="/" class="text-xl font-bold tracking-tight text-[#1A1A1A] dark:text-[#EAEAEA]">
				{SITE_CONFIG.siteName}
			</a>

			<!-- 中间导航（PC only） -->
			<div class="hidden md:flex items-center gap-6">
				<a href="/" class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#666] dark:hover:text-[#999] border-b-2 border-[#8B7CB3] pb-1">主页</a>
				<a href="/archive" class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#666] dark:hover:text-[#999]">归档</a>
				<a href="/about" class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#666] dark:hover:text-[#999]">关于</a>
				<a href="/now" class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#666] dark:hover:text-[#999]">/now</a>
				<a href="/colophon" class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#666] dark:hover:text-[#999]">/colophon</a>
			</div>

			<!-- 右侧图标区 -->
			<div class="flex items-center gap-1 md:gap-2">
				<div class="flex items-center focus-within:bg-black/5 focus-within:dark:bg-white/10 rounded-full transition-all duration-300">
				<button onclick="document.getElementById('search-input').focus()" class="w-9 h-9 flex items-center justify-center rounded-full bg-transparent hover:bg-black/5 dark:hover:bg-white/10 transition-all active:scale-95 text-[#1A1A1A] dark:text-[#EAEAEA] cursor-pointer border-none flex-shrink-0">
					<SearchIcon />
				</button>
				<input type="text" id="search-input" placeholder="Search..." class="w-0 focus:w-28 md:focus:w-40 bg-transparent border-none outline-none text-sm text-[#1A1A1A] dark:text-[#EAEAEA] placeholder-[#999] transition-all duration-300 px-0 focus:px-2 focus:mr-2" /></div>
				<button onclick="toggleDarkMode()" class="w-9 h-9 flex items-center justify-center rounded-full bg-transparent hover:bg-black/5 dark:hover:bg-white/10 transition-all active:scale-95 text-[#1A1A1A] dark:text-[#EAEAEA] cursor-pointer border-none flex-shrink-0">
				<span id="theme-sun"><SunIcon /></span>
				<span id="theme-moon" class="hidden"><MoonIcon /></span>
				</button>
				<a href="/user" class="w-9 h-9 flex items-center justify-center rounded-full bg-transparent hover:bg-black/5 dark:hover:bg-white/10 transition-all active:scale-95 text-[#1A1A1A] dark:text-[#EAEAEA] cursor-pointer border-none flex-shrink-0">
					<UserIcon />
				</a>
				<button onclick="toggleMobileMenu()" class="md:hidden w-9 h-9 flex items-center justify-center rounded-full bg-transparent hover:bg-black/5 dark:hover:bg-white/10 transition-all active:scale-95 text-[#1A1A1A] dark:text-[#EAEAEA] cursor-pointer border-none flex-shrink-0">
				<HamburgerIcon />
				</button>
			</div>
		</div>
	</nav>

	<!-- 移动端Hamburger菜单 -->
	<div id="mobile-menu" class="fixed inset-0 z-40 bg-white/80 dark:bg-black/80 backdrop-blur-2xl opacity-0 pointer-events-none transition-opacity duration-500 flex flex-col pt-24 pb-12 px-8">
  		<div class="flex flex-col gap-6 mt-8">
    		<a href="/" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]">主页</a>
    		<a href="/archive" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]" style="transition-delay: 50ms;">归档</a>
    		<a href="/about" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]" style="transition-delay: 100ms;">关于</a>
    		<a href="/now" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]" style="transition-delay: 150ms;">/now</a>
    		<a href="/colophon" class="mobile-nav-link text-4xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] no-underline translate-x-12 opacity-0 transition-all duration-500 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3]" style="transition-delay: 200ms;">/colophon</a>
  		</div>
  	<div class="mt-auto border-t border-[#1A1A1A]/10 dark:border-white/10 pt-6 flex justify-between items-center opacity-0 translate-x-12 transition-all duration-500 delay-300" id="mobile-menu-footer">
    	<span class="text-xs font-bold text-[#8B7CB3] tracking-widest uppercase">贝谟拉比 BMLB</span>
    <div class="flex gap-4">
      	<a href="#" class="text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#8B7CB3]">
        	<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          	<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-6h2v6zm-1-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm5 7h-2v-3c0-.55-.45-1-1-1s-1 .45-1 1v3h-2v-6h2v1.5c.5-1.5 2.5-1.5 2.5 1.5V17z"/>
        	</svg>
      	</a>
      	<a href="#" class="text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#8B7CB3]">
        	<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          	<path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5C20.84 12.58 16.8 2 12 2zm-1.5 16h-2v-8h2v8zm-1-9.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm6.5 9.5h-2v-4.5c0-1.1-.9-2-2-2s-2 .9-2 2V18h-2v-8h2v1.5c.5-1.5 2.5-2.5 4-1.5 1.5 1 1.5 3 1.5 4.5V18z"/>
        </svg>
      	</a>
    </div>
  	</div>
</div>

	<!-- 模块2：Hero区 -->
	<section class="relative w-full h-[45vh] md:h-[60vh] min-h-[400px] overflow-hidden border-[#EAEAEA] dark:border-[#1A1A1A]">
		<img src="/images/hero-bg.jpg" alt="" class="absolute inset-0 w-full h-full object-cover object-[center_40%]" />
		<div class="absolute inset-0 bg-black/10 dark:bg-black/40"></div>
		<div class="absolute -bottom-[1px] left-0 w-full h-[40px] md:h-[70px] overflow-hidden z-10 pointer-events-none">
			<svg class="absolute bottom-0 left-0 w-[200%] h-full animate-wave-1" viewBox="0 0 2000 100" preserveAspectRatio="none">
				<path d="M0,40 C150,100 350,100 500,40 C650,-20 850,-20 1000,40 C1150,100 1350,100 1500,40 C1650,-20 1850,-20 2000,40 V100 H0 Z" class="opacity-30 fill-[#FAFAFA] dark:fill-[#0F0F0F]"></path>
			</svg>
			<svg class="absolute bottom-0 left-0 w-[200%] h-full animate-wave-2" viewBox="0 0 2000 100" preserveAspectRatio="none">
				<path d="M0,60 C150,20 350,20 500,60 C650,100 850,100 1000,60 C1150,20 1350,20 1500,60 C1650,100 1850,100 2000,60 V100 H0 Z" class="opacity-60 fill-[#FAFAFA] dark:fill-[#0F0F0F]"></path>
			</svg>
			<svg class="absolute bottom-0 left-0 w-[200%] h-full animate-wave-3" viewBox="0 0 2000 100" preserveAspectRatio="none">
				<path d="M0,70 C150,120 350,120 500,70 C650,20 850,20 1000,70 C1150,120 1350,120 1500,70 C1650,20 1850,20 2000,70 V100 H0 Z" class="fill-[#FAFAFA] dark:fill-[#0F0F0F]"></path>
			</svg>
		</div>
	</section>

	<!-- 模块3：个人锚点区 -->
	<div class="max-w-[1200px] xl:max-w-[1400px] 2xl:max-w-[1600px] mx-auto px-4 md:px-6 lg:px-10 xl:px-12">
		<!-- 顶部行：头像 + Tab栏 -->
		<div class="flex md:grid md:grid-cols-[260px_1fr] xl:grid-cols-[280px_1fr] gap-4 md:gap-6 items-end relative z-10">
			<!-- 3.1 头像 -->
			<div class="w-[160px] md:w-full aspect-square rounded-[20px] bg-[#E8913A] md:-mt-[130px] xl:-mt-[140px] ring-4 ring-white dark:ring-[#0F0F0F] flex-shrink-0 overflow-hidden relative cursor-pointer transition-all duration-300 hover:shadow-xl hover:-translate-y-1.5 group">
				<img
					src={SITE_CONFIG.images.avatar}
					alt="头像"
					class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
					onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
				/>
				<div class="absolute inset-0 hidden items-center justify-center text-white font-bold">
					贝谟
				</div>
			</div>

			<!-- 3.2 PC Tab 长条栏 -->
			<div class="hidden md:flex flex-1 h-14 items-center px-6 rounded-2xl bg-[#F0F0F0] dark:bg-[#1A1A1A] shadow-sm hover:shadow-md transition-all duration-300">
				<span class="text-sm font-medium text-[#999] dark:text-[#666] border-r border-[#E0E0E0] dark:border-[#2A2A2A] pr-4 mr-4">分类</span>
				<div class="relative flex gap-2 z-0">
					<div id="pc-tab-slider" class="absolute top-0 bottom-0 left-0 rounded-xl bg-white dark:bg-[#252525] shadow-[0_2px_10px_-3px_rgba(0,0,0,0.08)] transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] z-[-1]"></div>
					{SITE_CONFIG.categories.map((cat, idx) => (
						<button
							data-tab={cat.id}
							data-active={idx === 0 ? 'true' : 'false'}
							class="relative z-10 px-4 py-1.5 text-sm font-medium transition-colors duration-300 outline-none select-none active:scale-95 text-[#999] hover:text-[#666] dark:text-[#666] dark:hover:text-[#EAEAEA] data-[active=true]:text-[#8B7CB3] data-[active=true]:dark:text-[#8B7CB3]"
						>
							{cat.name}
						</button>
					))}
				</div>
				<div class="ml-auto flex items-center gap-2 text-sm font-medium text-[#999]">
					<CalendarIcon />
					<span id="tab-datetime">--/--</span>
				</div>
			</div>

			<!-- 3.3 移动端 Tab 胶囊栏 -->
			<div class="flex md:hidden flex-1 h-12 items-center px-2 rounded-full bg-white/40 dark:bg-black/40 backdrop-blur-md shadow-sm border border-white/20 dark:border-white/5 overflow-hidden">
				<div class="relative flex gap-1 overflow-x-auto hide-scrollbar w-full items-center z-0">
					<div id="mobile-tab-slider" class="absolute top-0 bottom-0 left-0 rounded-full bg-[#8B7CB3] shadow-md transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] z-[-1]"></div>
					{SITE_CONFIG.categories.map((cat, idx) => (
						<button
							data-tab={cat.id}
							data-active={idx === 0 ? 'true' : 'false'}
							class="relative z-10 px-4 py-1.5 text-sm font-medium whitespace-nowrap transition-colors duration-300 outline-none select-none active:scale-95 text-[#666] dark:text-[#999] hover:text-[#1A1A1A] dark:hover:text-[#EAEAEA] data-[active=true]:text-white"
						>
							{cat.name}
						</button>
					))}
				</div>
			</div>
		</div>

		<!-- 内容行 -->
		<div class="mt-6 grid grid-cols-1 md:grid-cols-[260px_1fr] xl:grid-cols-[280px_1fr] gap-6">
			<!-- 3.4 左侧盒子区（PC only） -->
			<div class="hidden md:flex flex-col gap-4">
				<div id="sidebar-box-1" class="w-full min-h-[160px] rounded-3xl bg-[#F0F0F0] dark:bg-[#1A1A1A] p-5 shadow-sm hover:shadow-lg hover:-translate-y-1.5 transition-all duration-300 flex flex-col">
					<div class="flex justify-between items-center mb-4">
						<span id="calendar-title" class="text-xs font-bold text-[#8B7CB3] tracking-widest"></span>
						<div class="flex gap-1">
							<button onclick="console.log('prev month')" class="text-[#999] hover:text-[#8B7CB3] bg-transparent border-none cursor-pointer transition-colors p-1 flex items-center justify-center">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
							</button>
							<button onclick="console.log('next month')" class="text-[#999] hover:text-[#8B7CB3] bg-transparent border-none cursor-pointer transition-colors p-1 flex items-center justify-center">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
							</button>
						</div>
					</div>

					<div class="flex justify-between mb-2 px-1">
						<span class="text-[10px] font-medium text-[#999] w-full text-center">一</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">二</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">三</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">四</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">五</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">六</span>
						<span class="text-[10px] font-medium text-[#999] w-full text-center">日</span>
					</div>

					<div id="calendar-grid" class="grid grid-cols-7 gap-1 flex-1 px-1"></div>

					<div class="border-t border-[#E0E0E0] dark:border-[#2A2A2A] mt-3 pt-3 flex justify-between items-center px-1">
						<div class="flex items-center gap-1.5 text-[#1A1A1A] dark:text-[#EAEAEA]">
							<svg class="w-3.5 h-3.5 text-[#8B7CB3]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
							<span class="text-[10px] font-bold">Today</span>
						</div>
						<span id="calendar-footer-date" class="text-[10px] font-mono font-medium text-[#8B7CB3] bg-[#8B7CB3]/10 px-2 py-0.5 rounded-md">--/--</span>
					</div>
				</div>
				<div id="sidebar-box-2" class="w-full rounded-3xl bg-[#F0F0F0] dark:bg-[#1A1A1A] p-5 shadow-sm hover:shadow-lg hover:-translate-y-1.5 transition-all duration-300">
					<div class="flex items-center justify-between mb-4">
						<div class="flex items-center gap-2">
							<span class="text-[10px] font-bold text-[#8B7CB3] tracking-widest uppercase">Now Playing</span>
						</div>
						<div class="flex items-end gap-[2px] h-3">
							<div class="w-[3px] bg-[#8B7CB3] rounded-full h-[60%] animate-pulse"></div>
							<div class="w-[3px] bg-[#8B7CB3] rounded-full h-[100%] animate-pulse" style="animation-delay: 0.2s"></div>
							<div class="w-[3px] bg-[#8B7CB3] rounded-full h-[40%] animate-pulse" style="animation-delay: 0.4s"></div>
							<div class="w-[3px] bg-[#8B7CB3] rounded-full h-[80%] animate-pulse" style="animation-delay: 0.1s"></div>
						</div>
					</div>

					<div class="flex gap-3 items-center">
						<div class="relative w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 bg-gradient-to-tr from-[#8B7CB3] to-[#C9BAE5] dark:to-[#4A3B73] shadow-inner group cursor-pointer">
							<div class="absolute inset-0 flex items-center justify-center text-white/60 group-hover:scale-110 group-hover:text-white transition-all duration-500">
								<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm0-5.5c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1z"/></svg>
							</div>
						</div>
						
						<div class="flex-1 min-w-0 flex flex-col justify-center">
							<h4 class="text-[15px] font-bold text-[#1A1A1A] dark:text-[#EAEAEA] truncate tracking-tight">浮遊大陸アルジェス</h4>
							<p class="text-xs text-[#666] dark:text-[#999] mt-0.5 truncate">Falcom Sound Team J.D.K.</p>
						</div>
					</div>

					<div class="mt-4 flex flex-col gap-1.5">
						<div class="relative w-full h-1.5 bg-[#E0E0E0] dark:bg-[#2A2A2A] rounded-full overflow-hidden cursor-pointer group/progress">
							<div class="absolute top-0 left-0 h-full bg-[#8B7CB3] w-[35%] rounded-full group-hover/progress:bg-[#7A6BA2] transition-colors relative">
								<div class="absolute right-0 top-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full shadow opacity-0 group-hover/progress:opacity-100 transition-opacity"></div>
							</div>
						</div>
						<div class="flex justify-between items-center text-[10px] font-medium text-[#999] font-mono">
							<span>1:06</span>
							<span>3:10</span>
						</div>
					</div>

					<div class="mt-1 flex justify-between items-center px-1">
						<button onclick="console.log('loop')" class="text-[#999] hover:text-[#8B7CB3] transition-colors">
							<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/></svg>
						</button>
						
						<div class="flex items-center gap-4">
							<button onclick="console.log('prev')" class="text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3] transition-colors">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
							</button>
							
							<button onclick="togglePlay()" class="w-10 h-10 flex items-center justify-center rounded-full bg-[#1A1A1A] dark:bg-[#EAEAEA] text-white dark:text-[#1A1A1A] hover:bg-[#8B7CB3] dark:hover:bg-[#8B7CB3] hover:scale-105 active:scale-95 transition-all shadow-md">
								<svg class="w-5 h-5 translate-x-[1px]" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
							</button>
							
							<button onclick="console.log('next')" class="text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3] transition-colors">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
							</button>
						</div>

						<button onclick="console.log('list')" class="text-[#999] hover:text-[#8B7CB3] transition-colors">
							<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 15h18v-2H3v2zm0 4h18v-2H3v2zm0-8h18V9H3v2zm0-6v2h18V5H3z"/></svg>
						</button>
					</div>
				</div>
				<div id="sidebar-box-3" class="w-full rounded-3xl bg-[#F0F0F0] dark:bg-[#1A1A1A] p-5 shadow-sm hover:shadow-lg hover:-translate-y-1.5 transition-all duration-300">
					<div class="flex items-center justify-between mb-4">
						<span class="text-[10px] font-bold text-[#8B7CB3] tracking-widest uppercase">System Status</span>
						<div class="flex items-center gap-1.5">
							<span class="relative flex h-2 w-2">
								<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#7CB38B] opacity-75"></span>
								<span class="relative inline-flex rounded-full h-2 w-2 bg-[#7CB38B]"></span>
							</span>
							<span class="text-[10px] font-bold text-[#7CB38B] tracking-wide">运行中</span>
						</div>
					</div>

					<div class="grid grid-cols-2 gap-3">
						<div class="flex flex-col bg-white dark:bg-[#252525] p-3 rounded-2xl shadow-[0_2px_8px_-4px_rgba(0,0,0,0.05)] border border-transparent hover:border-[#8B7CB3]/30 transition-all duration-300 group">
							<div class="text-[#999] group-hover:text-[#8B7CB3] transition-colors mb-2">

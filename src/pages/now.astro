---
import BaseLayout from '../layouts/BaseLayout.astro';

// —— MD5 helper（Gravatar 用） ——
function md5(str: string): string {
  function r(n: number, c: number) { return (n << c) | (n >>> (32 - c)); }
  function q(n: number, c: number, t: number, b: number, x: number, s: number) {
    return r(n + c + t + b + x, s);
  }
  function a(i: number, a: number, b: number, c: number, d: number, s: number, t: number) {
    return q(b & c | ~b & d, a, b, i, t, s);
  }
  function m(i: number, a: number, b: number, c: number, d: number, s: number, t: number) {
    return q(b & d | c & ~d, a, b, i, t, s);
  }
  function p(i: number, a: number, b: number, c: number, d: number, s: number, t: number) {
    return q(b ^ c ^ d, a, b, i, t, s);
  }
  function s(i: number, a: number, b: number, c: number, d: number, s: number, t: number) {
    return q(c ^ (b | ~d), a, b, i, t, s);
  }
  const l = str.length;
  const w = [0];
  for (let i = 0; i < l; i++) w[i >> 2] |= str.charCodeAt(i) << ((i % 4) * 8);
  w[l >> 2] |= 0x80 << ((l % 4) * 8);
  w[((l + 8 >> 6) << 4) + 15] = l * 8;
  let va = 0x67452301, vb = 0xEFCDAB89, vc = 0x98BADCFE, vd = 0x10325476;
  for (let i = 0; i < w.length; i += 16) {
    let aa = va, bb = vb, cc = vc, dd = vd;
    for (let j = 0; j < 64; j++) {
      let f: number, g: number;
      if (j < 16) { f = a(w[i+j]||0, aa, bb, cc, dd, [7,12,17,22][j%4], [0xD76AA478,0xE8C7B756,0x242070DB,0xC1BDCEEE,0xF57C0FAF,0x4787C62A,0xA8304613,0xFD469501,0x698098D8,0x8B44F7AF,0xFFFF5BB1,0x895CD7BE,0x6B901122,0xFD987193,0xA679438E,0x49B40821][j]); g = j; }
      else if (j < 32) { f = m(w[i+((5*j+1)%16)]||0, aa, bb, cc, dd, [5,9,14,20][j%4], [0xF61E2562,0xC040B340,0x265E5A51,0xE9B6C7AA,0xD62F105D,0x02441453,0xD8A1E681,0xE7D3FBC8,0x21E1CDE6,0xC33707D6,0xF4D50D87,0x455A14ED,0xA9E3E905,0xFCEFA3F8,0x676F02D9,0x8D2A4C8A][j-16]); }
      else if (j < 48) { f = p(w[i+((3*j+5)%16)]||0, aa, bb, cc, dd, [4,11,16,23][j%4], [0xFFFA3942,0x8771F681,0x6D9D6122,0xFDE5380C,0xA4BEEA44,0x4BDECFA9,0xF6BB4B60,0xBEBFBC70,0x289B7EC6,0xEAA127FA,0xD4EF3085,0x04881D05,0xD9D4D039,0xE6DB99E5,0x1FA27CF8,0xC4AC5665][j-32]); }
      else { f = s(w[i+((7*j)%16)]||0, aa, bb, cc, dd, [6,10,15,21][j%4], [0xF4292244,0x432AFF97,0xAB9423A7,0xFC93A039,0x655B59C3,0x8F0CCC92,0xFFEFF47D,0x85845DD1,0x6FA87E4F,0xFE2CE6E0,0xA3014314,0x4E0811A1,0xF7537E82,0xBD3AF235,0x2AD7D2BB,0xEB86D391][j-48]); }
      const tmp = dd;
      dd = cc; cc = bb; bb = bb + r(aa + f, [7,12,17,22,5,9,14,20,4,11,16,23,6,10,15,21][j % 16]); aa = tmp;
    }
    va += aa; vb += bb; vc += cc; vd += dd;
  }
  function h(n: number) { return (n >>> 0).toString(16).padStart(8, '0'); }
  return h(va) + h(vb) + h(vc) + h(vd);
}

// —— 服务端获取 /now 状态面板数据 ——
interface NowStatus {
  id: number;
  startDate: string;
  endDate: string;
  phase: string;
  description: string;
  progress: number;
  badgeText: string;
  projectDescription: string;
  readingTitle: string;
  readingSubtitle: string;
  learningTitle: string;
  learningSubtitle: string;
  researchingTitle: string;
  researchingSubtitle: string;
  listeningTitle: string;
  listeningSubtitle: string;
  projectScreenshot: string;
  updatedAt: string;
}

interface NowActivityItem {
  id: number;
  content: string;
  activityDate: string;
}

let status: NowStatus = {
  id: 1,
  startDate: '2026-04-30',
  endDate: '2026-05-20',
  phase: 'Phase 2',
  description: '目前主要投入个人网站第二阶段建设，优化 /archive、/now、/about 页面，统一视觉系统，完善交互体验，建立长期运营内容框架。',
  progress: 72,
  badgeText: '高投入推进中',
  projectDescription: '目前处于高投入推进阶段，主要目标是完成第二阶段的功能开发和视觉优化，预计在 2026-05-20 前完成上线。',
  readingTitle: '《追忆似水年华》',
  readingSubtitle: '第三卷，缓慢推进中',
  learningTitle: 'Astro + CF 全栈',
  learningSubtitle: '进度 45%',
  researchingTitle: '半封闭水体碳汇',
  researchingSubtitle: '数据整理阶段',
  listeningTitle: '浮遊大陸アルジェス',
  listeningSubtitle: 'Falcom Sound Team',
  projectScreenshot: '',
  updatedAt: new Date().toISOString(),
};

try {
  const apiUrl = new URL('/api/now', Astro.url);
  const res = await fetch(apiUrl.toString());
  if (res.ok) {
    const data: any = await res.json();
    if (!data.error) {
      status = data as NowStatus;
    }
  } else {
    const errText = await res.text().catch(() => '无法读取响应');
    console.error('[now] GET /api/now 返回非 OK:', res.status, errText.slice(0, 200));
  }
} catch (e: any) {
  console.error('[now] GET /api/now 请求失败:', e?.message || e);
}

// —— 服务端获取微日志 ——
let activities: NowActivityItem[] = [
  { id: 0, content: '完成归档页设计',  activityDate: '04-30' },
  { id: 0, content: '优化首页卡片层级', activityDate: '04-29' },
  { id: 0, content: '构思 /now 页面结构', activityDate: '04-28' },
  { id: 0, content: '统一配色系统',     activityDate: '04-27' },
];

try {
  const apiUrl = new URL('/api/now/activity', Astro.url);
  const res = await fetch(apiUrl.toString());
  if (res.ok) {
    const data = await res.json();
    if (Array.isArray(data) && data.length > 0) {
      activities = data as NowActivityItem[];
    }
  }
} catch (e: any) {
  console.error('[now] GET /api/now/activity 请求失败:', e?.message || e);
}

// —— 服务端获取留言板 ——
interface NowMessage {
  id: number;
  author: string;
  email: string;
  content: string;
  createdAt: string;
}

let messages: NowMessage[] = [
  { id: 0, author: '访客', email: '', content: '页面很有生命力。', createdAt: '' },
  { id: 0, author: '访客', email: '', content: '期待正式上线。', createdAt: '' },
  { id: 0, author: '访客', email: '', content: '设计语言很统一。', createdAt: '' },
];

try {
  const apiUrl = new URL('/api/now/messages', Astro.url);
  const res = await fetch(apiUrl.toString());
  if (res.ok) {
    const data = await res.json();
    if (Array.isArray(data) && data.length > 0) {
      messages = data as NowMessage[];
    }
  }
} catch (e: any) {
  console.error('[now] GET /api/now/messages 请求失败:', e?.message || e);
}

const progressPercent = Math.max(0, Math.min(100, status.progress || 0));
---

<BaseLayout title="/now">
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 pt-[100px] pb-16 space-y-8">
    <!-- 第一行：状态面板 -->
    <div class="group bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md rounded-[32px] border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1.5 hover:shadow-xl transition-all duration-500 p-6 md:p-8 relative overflow-hidden">
			<!-- 装饰性光晕（在左上角放置环境光，与下方超大卡片的右上角光晕形成对角呼应） -->
      <div class="absolute -top-24 -left-24 w-64 h-64 bg-[#8B7CB3]/10 dark:bg-[#8B7CB3]/20 rounded-full blur-3xl pointer-events-none opacity-50 group-hover:opacity-100 transition-opacity duration-700 z-0"></div>
	  		<div class="flex flex-col md:flex-row gap-6 relative z-10">
        <!-- 左侧 35% 视觉文案 -->
        <div class="md:w-[35%] flex flex-col justify-center">
          <p class="text-xs font-medium text-[#999] uppercase tracking-widest mb-1">Now</p>
          <h1 class="text-2xl md:text-3xl font-bold text-[#1A1A1A] dark:text-[#EAEAEA]">目前把时间花在这里</h1>
          <p class="text-sm text-[#999] mt-2">Current Focus</p>
				  <h1 class="text-2xl md:text-3xl font-bold text-[#1A1A1A] dark:text-[#EAEAEA]">建设</h1>
          <p class="text-sm text-[#999]">Building</p>
				  <h1 class="text-2xl md:text-3xl font-bold text-[#1A1A1A] dark:text-[#EAEAEA]">ing</h1>
        </div>
        <!-- 中部 30% 时间河流 -->
        <div class="md:w-[30%]">
          <p class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest mb-3">The Flowing of Becoming</p>
          <div class="text-sm space-y-1">
            <!-- 给每一行数据增加 -mx-2 和 px-2，实现鼠标悬浮时行内高亮的微反馈 -->
            <div class="flex justify-between items-center px-2 py-1.5 -mx-2 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300">
              <span class="text-[#999]">开始时间</span>
              <span class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">{status.startDate}</span>
            </div>
            <div class="flex justify-between items-center px-2 py-1.5 -mx-2 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300">
              <span class="text-[#999]">已持续</span>
              <span id="now-running-time" class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">计算中...</span>
            </div>
            <div class="flex justify-between items-center px-2 py-1.5 -mx-2 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300">
              <span class="text-[#999]">预计结束</span>
              <span class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">{status.endDate}</span>
            </div>
            <div class="flex justify-between items-center px-2 py-1.5 -mx-2 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300">
              <span class="text-[#999]">已投入天数</span>
              <span class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]"><span id="now-days">...</span> 天</span>
            </div>
            <div class="flex justify-between items-center px-2 py-1.5 -mx-2 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300">
              <span class="text-[#999]">当前阶段</span>
              <span class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">{status.phase}</span>
            </div>
          </div>
        </div>
        <!-- 右侧 35% 事项描述 -->
        <div class="md:w-[35%]">
          <p class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest mb-3">事项描述</p>
          <p class="text-sm text-[#666] dark:text-[#888] group-hover:text-[#444] dark:group-hover:text-[#AAA] leading-relaxed transition-colors duration-500">
            {status.description}
          </p>
        </div>
      </div>
    </div>

    <!-- 第二行：并行卡片矩阵 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      
      <!-- 卡片 1：正在阅读 -->
      <div class="group relative overflow-hidden bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md rounded-3xl p-6 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1.5 hover:shadow-xl transition-all duration-500 cursor-pointer">
        <!-- 隐性交互：背景巨型模糊 Emoji -->
        <div class="absolute -right-2 -bottom-2 text-7xl opacity-5 dark:opacity-10 blur-sm group-hover:blur-2xl group-hover:opacity-30 group-hover:scale-150 transition-all duration-700 ease-out pointer-events-none select-none z-0">📖</div>
        <!-- 前景内容区 -->
        <div class="relative z-10">
          <div class="text-3xl mb-4 group-hover:scale-110 group-hover:-rotate-6 transition-transform duration-300 origin-bottom-left">📖</div>
          <h3 class="text-base font-bold mb-1 text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors">正在阅读</h3>
          <p class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA]">{status.readingTitle}</p>
          <p class="text-[11px] text-[#999] mt-1.5 tracking-wide">{status.readingSubtitle}</p>
        </div>
      </div>

      <!-- 卡片 2：正在学习 -->
      <div class="group relative overflow-hidden bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md rounded-3xl p-6 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1.5 hover:shadow-xl transition-all duration-500 cursor-pointer">
        <div class="absolute -right-2 -bottom-2 text-7xl opacity-5 dark:opacity-10 blur-sm group-hover:blur-2xl group-hover:opacity-30 group-hover:scale-150 transition-all duration-700 ease-out pointer-events-none select-none z-0">💻</div>
        <div class="relative z-10">
          <div class="text-3xl mb-4 group-hover:scale-110 group-hover:-rotate-6 transition-transform duration-300 origin-bottom-left">💻</div>
          <h3 class="text-base font-bold mb-1 text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors">正在学习</h3>
          <p class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA]">{status.learningTitle}</p>
          <p class="text-[11px] text-[#999] mt-1.5 tracking-wide">{status.learningSubtitle}</p>
        </div>
      </div>

      <!-- 卡片 3：正在研究 -->
      <div class="group relative overflow-hidden bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md rounded-3xl p-6 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1.5 hover:shadow-xl transition-all duration-500 cursor-pointer">
        <div class="absolute -right-2 -bottom-2 text-7xl opacity-5 dark:opacity-10 blur-sm group-hover:blur-2xl group-hover:opacity-30 group-hover:scale-150 transition-all duration-700 ease-out pointer-events-none select-none z-0">🔬</div>
        <div class="relative z-10">
          <div class="text-3xl mb-4 group-hover:scale-110 group-hover:-rotate-6 transition-transform duration-300 origin-bottom-left">🔬</div>
          <h3 class="text-base font-bold mb-1 text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors">正在研究</h3>
          <p class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA]">{status.researchingTitle}</p>
          <p class="text-[11px] text-[#999] mt-1.5 tracking-wide">{status.researchingSubtitle}</p>
        </div>
      </div>

      <!-- 卡片 4：正在听 -->
      <div class="group relative overflow-hidden bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md rounded-3xl p-6 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1.5 hover:shadow-xl transition-all duration-500 cursor-pointer">
        <div class="absolute -right-2 -bottom-2 text-7xl opacity-5 dark:opacity-10 blur-sm group-hover:blur-2xl group-hover:opacity-30 group-hover:scale-150 transition-all duration-700 ease-out pointer-events-none select-none z-0">🎵</div>
        <div class="relative z-10">
          <div class="text-3xl mb-4 group-hover:scale-110 group-hover:-rotate-6 transition-transform duration-300 origin-bottom-left">🎵</div>
          <h3 class="text-base font-bold mb-1 text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors">正在听</h3>
          <p class="text-sm font-medium text-[#1A1A1A] dark:text-[#EAEAEA]">{status.listeningTitle}</p>
          <p class="text-[11px] text-[#999] mt-1.5 tracking-wide">{status.listeningSubtitle}</p>
        </div>
      </div>
      
    </div>

    <!-- 第三行：Current Project 超大卡片 -->
    <div class="group bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md rounded-[32px] p-8 md:p-10 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1.5 hover:shadow-xl transition-all duration-500 relative overflow-hidden">
			<!-- 装饰性光晕（在卡片右上角微微发光，增加空间感） -->
			<div class="absolute -top-24 -right-24 w-64 h-64 bg-[#8B7CB3]/10 dark:bg-[#8B7CB3]/20 rounded-full blur-3xl pointer-events-none opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>
      		<div class="flex flex-col md:flex-row gap-8">
        <!-- 左侧 55% -->
        <div class="md:w-[55%]">
          <p class="text-xs text-[#999] uppercase tracking-widest mb-2">Current Project</p>
          <h2 class="text-2xl md:text-3xl font-bold mb-4 text-[#1A1A1A] dark:text-[#EAEAEA]">个人网站第二阶段开发</h2>
          <div class="grid grid-cols-2 gap-4 mb-4 text-sm">
            <div>
              <span class="text-[#999] block">Started</span>
              <span class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">{status.startDate}</span>
            </div>
            <div>
              <span class="text-[#999] block">Running</span>
              <span id="project-running" class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">...</span>
            </div>
            <div>
              <span class="text-[#999] block">ETA</span>
              <span class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">{status.endDate}</span>
            </div>
            <div>
              <span class="text-[#999] block">Progress</span>
              <span class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">{status.progress}%</span>
            </div>
          </div>
          <!-- 动态流光进度条（Animated Gradient + 头部发光点） -->
          <div class="w-full h-2.5 bg-[#E0E0E0]/80 dark:bg-[#2A2A2A] rounded-full overflow-visible mb-5 relative shadow-inner">
					<div class="absolute top-0 left-0 h-full rounded-full" style={`width: ${progressPercent}%;`}>
              <div class="h-full w-full bg-gradient-to-r from-[#8B7CB3] via-[#B26A8B] to-[#8B7CB3] bg-[length:200%_200%] animate-gradient-x shadow-[0_0_10px_rgba(139,124,179,0.5)] rounded-full">
							<!-- 进度条推进末端的发光点 -->
							<div class="absolute right-0 top-1/2 -translate-y-1/2 w-4 h-4 bg-white rounded-full shadow-[0_0_8px_rgba(139,124,179,0.8)] scale-0 group-hover:scale-100 transition-transform duration-500"></div>
						</div>
            </div>
          </div>
          <!-- 状态标签 -->
          <span class="px-3 py-1 rounded-full text-xs font-bold bg-[#8B7CB3]/10 text-[#8B7CB3] inline-block mb-4 border border-[#8B7CB3]/20 shadow-sm relative overflow-hidden group/tag cursor-default">
          <span class="relative z-10">{status.badgeText || '读取GG了'}</span>
			  <!-- 标签内的一道扫光 -->
			  <span class="absolute top-0 -left-[100%] w-1/2 h-full bg-gradient-to-r from-transparent via-white/40 dark:via-white/20 to-transparent skew-x-[-20deg] group-hover/tag:animate-sweep"></span>
			  </span>
			  <p class="text-sm text-[#666] dark:text-[#888] leading-relaxed">{status.projectDescription || `来到了没有数据的外太空`}</p>
        </div>
        <!-- 右侧 45%：项目截图 -->
        <div class="md:w-[45%]">
          <div class="w-full h-full min-h-[200px] rounded-[24px] bg-[#F5F5F5] dark:bg-[#111111] border border-black/5 dark:border-white/5 shadow-inner overflow-hidden relative">
            {status.projectScreenshot ? (
              <img src={status.projectScreenshot} alt="项目截图" class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-sm text-[#999]">项目截图占位</span>
              </div>
            )}
            <!-- 模拟屏幕玻璃反光 -->
            <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent dark:from-white/5 pointer-events-none z-10"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- 第四行：左右双栏 -->
    <div class="grid grid-cols-1 md:grid-cols-[30%_1fr] gap-6">
    <!-- 左侧：微日志 (Dashboard Activity Feed 风格) -->
        <div class="bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-sm rounded-3xl p-6 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1.5 hover:shadow-xl hover:border-[#8B7CB3]/20 transition-all duration-500 flex flex-col justify-between">
          <div class="flex items-center justify-between mb-5">
            <p class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest">Activity Feed</p>
            <span class="text-[9px] font-bold text-[#999] uppercase tracking-wider bg-black/5 dark:bg-white/5 px-2 py-1 rounded-md">Recent</span>
          </div>
  
          <div class="flex flex-col gap-2">
            {activities.map((item, idx) => {
              const isLatest = idx === 0;
              return (
                <div class={`group flex items-center justify-between p-3 rounded-2xl transition-all duration-300 hover:translate-x-1 cursor-default border ${
                  isLatest
                    ? 'bg-white/80 dark:bg-[#252525]/80 hover:bg-white dark:hover:bg-[#2A2A2A] shadow-sm hover:shadow-md border-white dark:border-white/5'
                    : 'bg-transparent hover:bg-white/50 dark:hover:bg-[#252525]/50 border-transparent hover:border-white/50 dark:hover:border-white/5'
                }`}>
                  <div class="flex items-center gap-3">
                    {isLatest ? (
                      <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#8B7CB3] opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-[#8B7CB3]"></span>
                      </span>
                    ) : (
                      <div class="w-1.5 h-1.5 rounded-full bg-[#D0D0D0] dark:bg-[#444] group-hover:bg-[#8B7CB3] transition-colors"></div>
                    )}
                    <span class={`text-sm transition-colors ${
                      isLatest
                        ? 'font-bold text-[#1A1A1A] dark:text-[#EAEAEA]'
                        : 'font-medium text-[#666] dark:text-[#888] group-hover:text-[#1A1A1A] dark:group-hover:text-[#EAEAEA]'
                    }`}>{item.content}</span>
                  </div>
                  <span class={`text-[10px] font-mono transition-colors px-2 py-1 rounded-lg ${
                    isLatest
                      ? 'font-bold text-[#8B7CB3] bg-[#8B7CB3]/10'
                      : 'text-[#999] bg-black/5 dark:bg-white/5 group-hover:text-[#8B7CB3] group-hover:bg-[#8B7CB3]/10'
                  }`}>{item.activityDate}</span>
                </div>
              );
            })}
          </div>
        </div>
      <!-- 右侧：留言板 -->
      <div class="bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-sm rounded-3xl p-6 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1.5 hover:shadow-xl hover:border-[#8B7CB3]/20 transition-all duration-500 flex flex-col h-full">
        <!-- 头部栏 -->
        <div class="flex items-center justify-between mb-5">
          <p class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest">Leave a Message</p>
          <span class="text-[10px] font-medium text-[#999] flex items-center gap-1.5">
            <span class="relative flex h-1.5 w-1.5"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span><span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span></span>
            Online
          </span>
        </div>

        <!-- 留言输入区 -->
        <div class="mb-6" id="messages-input-area">
          <!-- 昵称 + 邮箱行 -->
          <div class="grid grid-cols-2 gap-2 mb-2">
            <input type="text" id="msg-author" placeholder="昵称（选填）" maxlength="20"
              class="px-3 py-2 rounded-xl border border-[#ECECEC] dark:border-[#2B2B2B] bg-white/75 dark:bg-[#141414]/80 text-xs placeholder:text-[#B3B3B3] dark:placeholder:text-[#666] text-[#1A1A1A] dark:text-[#EAEAEA] outline-none focus:border-[#8B7CB3]/45 transition-all" />
            <input type="text" id="msg-email" placeholder="邮箱（选填，用于头像）"
              class="px-3 py-2 rounded-xl border border-[#ECECEC] dark:border-[#2B2B2B] bg-white/75 dark:bg-[#141414]/80 text-xs placeholder:text-[#B3B3B3] dark:placeholder:text-[#666] text-[#1A1A1A] dark:text-[#EAEAEA] outline-none focus:border-[#8B7CB3]/45 transition-all" />
          </div>
          <!-- 内容 + 发送行 -->
          <div class="group relative flex overflow-hidden rounded-2xl border border-[#ECECEC] bg-white/75 backdrop-blur-xl shadow-[0_8px_24px_rgba(0,0,0,.04)] transition-all duration-300 dark:border-[#2B2B2B] dark:bg-[#141414]/80 focus-within:border-[#8B7CB3]/45 focus-within:shadow-[0_10px_30px_rgba(139,124,179,.10)] focus-within:ring-4 focus-within:ring-[#8B7CB3]/8">
            <textarea id="msg-content" rows="2" maxlength="500" placeholder="给现在的我留句话..."
              class="flex-1 resize-none bg-transparent px-5 py-4 text-sm leading-6 text-[#1A1A1A] placeholder:text-[#B3B3B3] outline-none dark:text-[#EAEAEA] dark:placeholder:text-[#666]"></textarea>
            <div class="w-px self-stretch bg-[#EFEFEF] transition-colors duration-300 dark:bg-[#2F2F2F] group-focus-within:bg-[#8B7CB3]/25"></div>
            <button type="button" id="msg-send-btn"
              class="group/btn relative flex w-[78px] shrink-0 items-center justify-center overflow-hidden bg-[#8B7CB3]/8 text-[#8B7CB3] transition-all duration-300 hover:bg-[#8B7CB3] active:scale-[0.98] border-none cursor-pointer">
              <span class="absolute inset-0 overflow-hidden">
                <span class="animate-sweep absolute top-0 h-full w-10 -skew-x-12 bg-white/20"></span>
              </span>
              <span class="relative z-10 flex items-center gap-1.5 text-xs font-semibold tracking-wide transition-colors duration-300 group-hover/btn:text-white">
                发送
                <svg class="h-4 w-4 transition-transform duration-300 group-hover/btn:translate-x-0.5 group-hover/btn:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
                </svg>
              </span>
            </button>
          </div>
          <div class="mt-2 flex items-center justify-between px-1">
            <span id="msg-send-status" class="text-[11px] text-[#A0A0A0] dark:text-[#666]">留下此刻想说的话</span>
            <span class="text-[11px] text-[#A0A0A0] dark:text-[#666]">Ctrl + Enter 发送</span>
          </div>
        </div>

        <!-- 留言列表 -->
        <div class="space-y-4 flex-1 overflow-y-auto hide-scrollbar pr-1 pl-2 pt-2" id="messages-list">
          {messages.map((msg, idx) => {
            const name = msg.author || '访客';
            const initial = name.charAt(0).toUpperCase();
            const colors = ['#8B7CB3','#4A90D9','#7CB38B','#E8913A','#B26A8B','#5BC0BE'];
            let hash = 0;
            for (let i = 0; i < name.length; i++) hash = name.charCodeAt(i) + ((hash << 5) - hash);
            const color = colors[Math.abs(hash) % colors.length];
            const avatarClass = idx % 3 === 0 ? 'text-[#8B7CB3]' : idx % 3 === 1 ? 'text-blue-500' : 'text-emerald-500';
            const borderHover = idx % 3 === 0 ? 'group-hover:border-[#8B7CB3]/20' : idx % 3 === 1 ? 'group-hover:border-blue-500/20' : 'group-hover:border-emerald-500/20';
            const nameHover = idx % 3 === 0 ? 'group-hover:text-[#8B7CB3]' : idx % 3 === 1 ? 'group-hover:text-blue-500' : 'group-hover:text-emerald-500';
            return (
              <div class="group flex gap-3 cursor-default">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br flex items-center justify-center shrink-0 group-hover:scale-110 group-hover:shadow-sm transition-all duration-300 overflow-hidden" style={`background: linear-gradient(135deg, ${color}20, ${color}30)`}>
                  {msg.email ? (
                    <img src={`https://www.gravatar.com/avatar/${md5(msg.email.trim().toLowerCase())}?d=mp&s=64`} alt="" class="w-full h-full object-cover" loading="lazy" />
                  ) : (
                    <span class={`text-xs font-bold ${avatarClass}`}>{initial}</span>
                  )}
                </div>
                <div class="flex flex-col gap-1 w-full">
                  <div class="flex items-center justify-between pl-1">
                    <span class={`text-[11px] font-bold text-[#1A1A1A] dark:text-[#EAEAEA] ${nameHover} transition-colors duration-300`}>{name}</span>
                    <span class="text-[10px] text-[#999] opacity-0 group-hover:opacity-100 transition-opacity duration-300">{msg.createdAt ? new Date(msg.createdAt + 'Z').toLocaleString('zh-CN', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : ''}</span>
                  </div>
                  <div class={`bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md p-3 rounded-2xl rounded-tl-none text-sm text-[#666] dark:text-[#888] shadow-sm border border-white/20 dark:border-white/10 group-hover:-translate-y-1 group-hover:shadow-md ${borderHover} transition-all duration-300`}>
                    {msg.content}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    			</div>
  			</div>

  <script define:vars={{ startDate: status.startDate }}>
    (function () {
      // 如果有时间部分则直接使用 否则补 T00:00:00
      const hasTime = startDate.includes('T') || startDate.includes(' ');
      const start = new Date(hasTime ? startDate : startDate + 'T00:00:00');

      function formatDuration(ms) {
        const totalMinutes = Math.floor(ms / 60000);
        const days = Math.floor(totalMinutes / 1440);
        const hours = Math.floor((totalMinutes % 1440) / 60);
        const minutes = totalMinutes % 60;
        return days + '天 ' + hours + '小时 ' + minutes + '分钟';
      }

      function update() {
        const now = new Date();
        const diff = now - start;

        const runningText = diff >= 0 ? formatDuration(diff) : '0天 0小时 0分钟';
        const days = diff >= 0 ? Math.floor(diff / 86400000) : 0;

        const elRunning = document.getElementById('now-running-time');
        const elDays = document.getElementById('now-days');
        const elProject = document.getElementById('project-running');

        if (elRunning) elRunning.textContent = runningText;
        if (elDays) elDays.textContent = days;
        if (elProject) elProject.textContent = runningText;
      }

      update();
      setInterval(update, 1000);
    })();
  </script>

  <script is:inline>
    // —— 留言板交互 ——
    (function () {
      const authorEl = document.getElementById('msg-author');
      const contentEl = document.getElementById('msg-content');
      const sendBtn = document.getElementById('msg-send-btn');
      const statusEl = document.getElementById('msg-send-status');
      const listEl = document.getElementById('messages-list');
      const emailEl = document.getElementById('msg-email');

      // 简单 MD5（客户端 Gravatar 用）
      function md5(str) {
        function r(n, c) { return (n << c) | (n >>> (32 - c)); }
        function q(n, c, t, b, x, s) { return r(n + c + t + b + x, s); }
        function a(i, a, b, c, d, s, t) { return q(b & c | ~b & d, a, b, i, t, s); }
        function m(i, a, b, c, d, s, t) { return q(b & d | c & ~d, a, b, i, t, s); }
        function p(i, a, b, c, d, s, t) { return q(b ^ c ^ d, a, b, i, t, s); }
        function s(i, a, b, c, d, s, t) { return q(c ^ (b | ~d), a, b, i, t, s); }
        var l = str.length, w = [0];
        for (var i = 0; i < l; i++) w[i >> 2] |= str.charCodeAt(i) << ((i % 4) * 8);
        w[l >> 2] |= 0x80 << ((l % 4) * 8);
        w[((l + 8 >> 6) << 4) + 15] = l * 8;
        var va = 0x67452301, vb = 0xEFCDAB89, vc = 0x98BADCFE, vd = 0x10325476;
        for (var i = 0; i < w.length; i += 16) {
          var aa = va, bb = vb, cc = vc, dd = vd;
          for (var j = 0; j < 64; j++) {
            var f;
            if (j < 16) { f = a(w[i+j]||0, aa, bb, cc, dd, [7,12,17,22][j%4], [0xD76AA478,0xE8C7B756,0x242070DB,0xC1BDCEEE,0xF57C0FAF,0x4787C62A,0xA8304613,0xFD469501,0x698098D8,0x8B44F7AF,0xFFFF5BB1,0x895CD7BE,0x6B901122,0xFD987193,0xA679438E,0x49B40821][j]); }
            else if (j < 32) { f = m(w[i+((5*j+1)%16)]||0, aa, bb, cc, dd, [5,9,14,20][j%4], [0xF61E2562,0xC040B340,0x265E5A51,0xE9B6C7AA,0xD62F105D,0x02441453,0xD8A1E681,0xE7D3FBC8,0x21E1CDE6,0xC33707D6,0xF4D50D87,0x455A14ED,0xA9E3E905,0xFCEFA3F8,0x676F02D9,0x8D2A4C8A][j-16]); }
            else if (j < 48) { f = p(w[i+((3*j+5)%16)]||0, aa, bb, cc, dd, [4,11,16,23][j%4], [0xFFFA3942,0x8771F681,0x6D9D6122,0xFDE5380C,0xA4BEEA44,0x4BDECFA9,0xF6BB4B60,0xBEBFBC70,0x289B7EC6,0xEAA127FA,0xD4EF3085,0x04881D05,0xD9D4D039,0xE6DB99E5,0x1FA27CF8,0xC4AC5665][j-32]); }
            else { f = s(w[i+((7*j)%16)]||0, aa, bb, cc, dd, [6,10,15,21][j%4], [0xF4292244,0x432AFF97,0xAB9423A7,0xFC93A039,0x655B59C3,0x8F0CCC92,0xFFEFF47D,0x85845DD1,0x6FA87E4F,0xFE2CE6E0,0xA3014314,0x4E0811A1,0xF7537E82,0xBD3AF235,0x2AD7D2BB,0xEB86D391][j-48]); }
            var tmp = dd;
            dd = cc; cc = bb; bb = bb + r(aa + f, [7,12,17,22,5,9,14,20,4,11,16,23,6,10,15,21][j % 16]); aa = tmp;
          }
          va += aa; vb += bb; vc += cc; vd += dd;
        }
        function h(n) { return (n >>> 0).toString(16).padStart(8, '0'); }
        return h(va) + h(vb) + h(vc) + h(vd);
      }

      function getColor(name) {
        var colors = ['#8B7CB3','#4A90D9','#7CB38B','#E8913A','#B26A8B','#5BC0BE'];
        var hash = 0;
        for (var i = 0; i < name.length; i++) hash = name.charCodeAt(i) + ((hash << 5) - hash);
        return colors[Math.abs(hash) % colors.length];
      }

      function formatTime(isoStr) {
        if (!isoStr) return '';
        var d = new Date(isoStr + 'Z');
        var months = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
        return months[d.getMonth()] + d.getDate() + '日 ' + String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
      }

      function renderMessage(msg, idx) {
        var name = msg.author || '访客';
        var initial = name.charAt(0).toUpperCase();
        var color = getColor(name);
        var avatarClasses = ['text-[#8B7CB3]','text-blue-500','text-emerald-500'];
        var avatarClass = avatarClasses[idx % 3];
        var borderHover = ['group-hover:border-[#8B7CB3]/20','group-hover:border-blue-500/20','group-hover:border-emerald-500/20'][idx % 3];
        var nameHover = ['group-hover:text-[#8B7CB3]','group-hover:text-blue-500','group-hover:text-emerald-500'][idx % 3];
        var timeStr = formatTime(msg.createdAt);

        var avatarHtml = msg.email
          ? '<img src="https://www.gravatar.com/avatar/' + md5(msg.email.trim().toLowerCase()) + '?d=mp&s=64" alt="" class="w-full h-full object-cover" loading="lazy" />'
          : '<span class="text-xs font-bold ' + avatarClass + '">' + initial + '</span>';

        return '<div class="group flex gap-3 cursor-default">' +
          '<div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 group-hover:scale-110 group-hover:shadow-sm transition-all duration-300 overflow-hidden" style="background: linear-gradient(135deg, ' + color + '20, ' + color + '30)">' +
            avatarHtml +
          '</div>' +
          '<div class="flex flex-col gap-1 w-full">' +
            '<div class="flex items-center justify-between pl-1">' +
              '<span class="text-[11px] font-bold text-[#1A1A1A] dark:text-[#EAEAEA] ' + nameHover + ' transition-colors duration-300">' + name + '</span>' +
              (timeStr ? '<span class="text-[10px] text-[#999] opacity-0 group-hover:opacity-100 transition-opacity duration-300">' + timeStr + '</span>' : '') +
            '</div>' +
            '<div class="bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md p-3 rounded-2xl rounded-tl-none text-sm text-[#666] dark:text-[#888] shadow-sm border border-white/20 dark:border-white/10 group-hover:-translate-y-1 group-hover:shadow-md ' + borderHover + ' transition-all duration-300">' +
              msg.content +
            '</div>' +
          '</div>' +
        '</div>';
      }

      async function submitMessage() {
        var author = authorEl.value.trim();
        var email = emailEl.value.trim();
        var content = contentEl.value.trim();

        if (!content) {
          statusEl.textContent = '请输入留言内容';
          statusEl.className = 'text-[11px] text-red-500';
          return;
        }

        sendBtn.disabled = true;
        statusEl.textContent = '发送中...';
        statusEl.className = 'text-[11px] text-[#A0A0A0] dark:text-[#666]';

        try {
          var res = await fetch('/api/now/messages', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ author: author, email: email, content: content }),
          });
          var result = await res.json();
          if (result.error) {
            statusEl.textContent = result.error;
            statusEl.className = 'text-[11px] text-red-500';
          } else {
            contentEl.value = '';
            statusEl.textContent = '✓ 发送成功';
            statusEl.className = 'text-[11px] text-[#7CB38B]';
            await refreshMessages();
            setTimeout(function () {
              if (statusEl.textContent.indexOf('✓') === 0) {
                statusEl.textContent = '留下此刻想说的话';
                statusEl.className = 'text-[11px] text-[#A0A0A0] dark:text-[#666]';
              }
            }, 2000);
          }
        } catch (e) {
          statusEl.textContent = '网络错误，请重试';
          statusEl.className = 'text-[11px] text-red-500';
        } finally {
          sendBtn.disabled = false;
        }
      }

      async function refreshMessages() {
        try {
          var res = await fetch('/api/now/messages');
          var messages = await res.json();
          if (Array.isArray(messages) && messages.length > 0) {
            listEl.innerHTML = messages.map(function (msg, idx) {
              return renderMessage(msg, idx);
            }).join('');
          }
        } catch (e) {}
      }

      sendBtn.addEventListener('click', submitMessage);
      contentEl.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
          e.preventDefault();
          submitMessage();
        }
      });
    })();
  </script>
</BaseLayout>

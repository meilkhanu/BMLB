				<div class="absolute inset-0 bg-[linear-gradient(to_right,#8B7CB315_1px,transparent_1px),linear-gradient(to_bottom,#8B7CB315_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_20%,transparent_100%)] pointer-events-none z-0"></div>

				<div class="relative z-10 max-w-[1000px]">

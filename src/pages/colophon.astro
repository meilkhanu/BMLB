---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../config.ts';

// —— 服务端获取 /now 状态数据 ——
interface NowStatus {
  phase: string;
  progress: number;
  badgeText: string;
  updatedAt: string;
}

let status: NowStatus = {
  phase: 'Phase 2',
  progress: 72,
  badgeText: '高投入推进中',
  updatedAt: new Date().toISOString(),
};

try {
  const apiUrl = new URL('/api/now', Astro.url);
  const res = await fetch(apiUrl.toString());
  if (res.ok) {
    const data: any = await res.json();
    if (!data.error) {
      status = data as NowStatus;
    }
  }
} catch {}

const phaseLabel = status.phase || 'Phase 2';
const statusLabel = status.badgeText || '平滑推进中';

// 格式化 updatedAt
const updatedAtObj = new Date(status.updatedAt);
const lastBuildStr = isNaN(updatedAtObj.getTime())
  ? '—'
  : `${updatedAtObj.getFullYear()}-${String(updatedAtObj.getMonth()+1).padStart(2,'0')}-${String(updatedAtObj.getDate()).padStart(2,'0')} ${String(updatedAtObj.getHours()).padStart(2,'0')}:${String(updatedAtObj.getMinutes()).padStart(2,'0')}`;

// 计算相对时间
function relativeTime(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '—';
  const now = Date.now();
  const diff = now - d.getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return '刚刚';
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
}
const lastBuildRelative = relativeTime(status.updatedAt);
---

<BaseLayout title="/colophon — 站点说明">
	<!-- 整体容器：双栏布局 -->
	<div class="max-w-[1600px] w-full mx-auto px-6 md:px-10 lg:px-16 py-16 relative flex gap-12 lg:gap-24 xl:gap-32">

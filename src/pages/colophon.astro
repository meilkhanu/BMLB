  						</div>
  					</div>
  					<div>
  						<button data-target="system" class="nav-jump w-full text-left text-xs font-bold text-[#999] dark:text-[#666] tracking-widest uppercase mb-3 hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3] transition-colors cursor-pointer bg-transparent border-none p-0">System</button>
  						<div class="space-y-3 mt-2 pl-3">

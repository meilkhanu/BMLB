						</div>

						<!-- Tailwind -->
						<div class="group bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-sm rounded-2xl p-5 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-300">
							<div class="flex items-center gap-2 mb-1.5">
								<span class="w-1.5 h-1.5 rounded-full bg-[#E0E0E0] dark:bg-[#444] group-hover:bg-[#8B7CB3] transition-colors duration-300"></span>
								<div class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors duration-300">Tailwind</div>
							</div>
							<div class="text-xs text-[#999] dark:text-[#666] pl-3.5 group-hover:text-[#666] dark:group-hover:text-[#AAA] transition-colors duration-300">Utility-first styling</div>
						</div>

						<!-- Cloudflare -->
						<div class="group bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-sm rounded-2xl p-5 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-300">
							<div class="flex items-center gap-2 mb-1.5">

  							<button data-target="architecture" class="nav-jump w-full text-left text-xs text-[#666] dark:text-[#999] hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3] transition-colors cursor-pointer bg-transparent border-none p-0">Architecture</button>
  							<!-- 补充缺失的项 -->

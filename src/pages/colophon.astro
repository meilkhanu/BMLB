						<!-- 左侧：大标题 -->
						<div>
							<h2 class="text-4xl md:text-5xl font-bold tracking-tight text-[#1A1A1A] dark:text-[#EAEAEA]">
								贝谟拉比
							</h2>
						</div>

						<!-- 右侧：正文段落 (保持右对齐，加入悬浮变色过渡) -->

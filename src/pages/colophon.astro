  					</div>
  					<div>
  						<button data-target="final" class="nav-jump w-full text-left text-xs font-bold text-[#999] dark:text-[#666] tracking-widest uppercase hover:text-[#8B7CB3] dark:hover:text-[#8B7CB3] transition-colors cursor-pointer bg-transparent border-none p-0">End</button>
  					</div>
  				</div>
  			</nav>
 		</aside>

		<!-- 右侧：主内容区 -->
		<main class="flex-1 min-w-0">

					<div class="inline-flex items-center mb-6 h-[4rem] md:h-[6rem]">
						<h1 id="typewriter-text" class="text-5xl md:text-7xl font-bold tracking-tight text-[#1A1A1A] dark:text-[#EAEAEA]"></h1>
						<!-- 闪烁的光标 -->
						<span class="inline-block w-[3px] h-[3rem] md:h-[4.5rem] bg-[#8B7CB3] ml-1 animate-pulse"></span>
					</div>

					<!-- 文案：使用纯 Tailwind 过渡，JS 会负责移除透明度 -->

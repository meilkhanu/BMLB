---
import { SITE_CONFIG } from '../../config.ts';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>管理登录 — {SITE_CONFIG.siteName}</title>
</head>
<body class="bg-[#FAFAFA] dark:bg-[#0F0F0F] min-h-screen flex items-center justify-center p-4">

  <div class="w-full max-w-[380px]">
    <!-- 站点名 -->
    <a href="/" class="block text-center text-xl font-bold text-[#1A1A1A] dark:text-[#EAEAEA] no-underline mb-12 tracking-tight">
      {SITE_CONFIG.siteName}
    </a>

    <!-- 登录卡片 -->
    <div class="bg-white dark:bg-[#1A1A1A] rounded-3xl p-8 shadow-sm border border-[#EAEAEA] dark:border-[#2A2A2A]">
      <h1 id="login-title" class="text-lg font-bold text-[#1A1A1A] dark:text-[#EAEAEA] mb-2">管理登录</h1>
      <p id="login-desc" class="text-sm text-[#999] mb-6">请输入管理密码</p>

      <!-- 密码输入 -->
      <div class="mb-4">
        <input
          id="password-input"
          type="password"
          placeholder="密码"
          class="w-full px-4 py-3 rounded-2xl border border-[#E0E0E0] dark:border-[#333] bg-[#FAFAFA] dark:bg-[#252525] text-[#1A1A1A] dark:text-[#EAEAEA] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all"
        />
      </div>

      <!-- 错误提示 -->
      <div id="error-msg" class="hidden text-xs text-red-500 mb-4"></div>

      <!-- 提交按钮 -->
      <button
        id="submit-btn"
        class="w-full py-3 rounded-2xl bg-[#1A1A1A] dark:bg-[#EAEAEA] text-white dark:text-[#1A1A1A] text-sm font-bold hover:bg-[#8B7CB3] dark:hover:bg-[#8B7CB3] dark:hover:text-white active:scale-[0.98] transition-all cursor-pointer outline-none border-none"
      >
        登录
      </button>
    </div>

    <!-- 返回首页 -->
    <a href="/" class="block text-center text-xs text-[#999] hover:text-[#666] dark:hover:text-[#AAA] mt-6 no-underline transition-colors">
      ← 返回首页
    </a>
  </div>

  <script is:inline>
    const input = document.getElementById('password-input');
    const btn = document.getElementById('submit-btn');
    const error = document.getElementById('error-msg');
    const title = document.getElementById('login-title');
    const desc = document.getElementById('login-desc');

    // —— 检查是否为首次设置 ——
    async function checkSetup() {
      try {
        const res = await fetch('/api/auth');
        const data = await res.json();
        // 如果已登录，直接跳转管理主页
        if (data.logged_in) {
          window.location.href = '/admin';
          return;
        }
      } catch (e) {
        // 忽略网络错误
      }
    }
    checkSetup();

    // —— 提交 ——
    btn.addEventListener('click', async () => {
      const password = input.value.trim();
      if (!password || password.length < 4) {
        showError('密码至少 4 位');
        return;
      }

      btn.disabled = true;
      btn.textContent = '验证中...';
      hideError();

      try {
        const res = await fetch('/api/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password }),
        });
        const data = await res.json();

        if (data.success) {
          if (data.setup) {
            // 首次设置密码 —— 提示用户
            title.textContent = '密码已设置';
            desc.textContent = '这是你的管理员密码，请牢记。正在跳转...';
            btn.textContent = '✓ 完成';
            setTimeout(() => { window.location.href = '/admin'; }, 1500);
          } else {
            // 正常登录成功
            window.location.href = '/admin';
          }
        } else {
          showError(data.error || '登录失败');
          btn.disabled = false;
          btn.textContent = '登录';
          input.value = '';
          input.focus();
        }
      } catch (e) {
        showError('网络错误，请重试');
        btn.disabled = false;
        btn.textContent = '登录';
      }
    });

    // 回车提交
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') btn.click();
    });

    function showError(msg) {
      error.textContent = msg;
      error.classList.remove('hidden');
    }
    function hideError() {
      error.classList.add('hidden');
    }

    // 自动聚焦
    input.focus();
  </script>
</body>
</html>

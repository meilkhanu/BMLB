  </main>

  <script is:inline>
    // ============================================================
    // 全局状态
    // ============================================================
    let currentSlug = null;    // null = 新建模式，有值 = 编辑模式
    let tinymceReady = false;
    let deleteTarget = null;
    let nowStatusData = null;
    let currentMusicId = null;

    // ============================================================
    // /now 状态面板编辑器
    // ============================================================
    document.getElementById('edit-now-btn').addEventListener('click', () => openNowEditor());
    document.getElementById('now-back-btn').addEventListener('click', () => closeNowEditor());
    document.getElementById('save-now-btn').addEventListener('click', () => saveNowStatus());
    document.getElementById('now-screenshot-upload-btn').addEventListener('click', () => uploadNowScreenshot());
    document.getElementById('cover-upload-btn').addEventListener('click', () => uploadCoverImage());
    document.getElementById('field-coverImage').addEventListener('input', function() {
      updateCoverPreview(this.value.trim());
    });
    document.getElementById('music-btn').addEventListener('click', () => openMusicEditor());
    document.getElementById('music-back-btn').addEventListener('click', () => closeMusicEditor());
    document.getElementById('music-new-btn').addEventListener('click', () => showMusicForm());
    document.getElementById('music-save-btn').addEventListener('click', () => saveSong());
    document.getElementById('music-cancel-btn').addEventListener('click', () => hideMusicForm());
    document.getElementById('music-cover-upload-btn').addEventListener('click', () => uploadMusicCover());
    document.getElementById('music-audio-upload-btn').addEventListener('click', () => uploadMusicAudio());
    document.getElementById('music-cover-url').addEventListener('input', function() {
      updateMusicCoverPreview(this.value.trim());
    });
    document.getElementById('edit-activity-btn').addEventListener('click', () => openActivityEditor());
    document.getElementById('activity-back-btn').addEventListener('click', () => closeActivityEditor());
    document.getElementById('activity-add-btn').addEventListener('click', () => addActivity());

    // 实时预览
    ['now-start-date','now-end-date','now-phase','now-progress','now-description'].forEach(id => {
      document.getElementById(id).addEventListener('input', updateNowPreview);
    });

    async function openNowEditor() {
      document.getElementById('list-view').classList.add('hidden');
      document.getElementById('activity-editor-view').classList.add('hidden');
      document.getElementById('music-editor-view').classList.add('hidden');
      document.getElementById('now-editor-view').classList.remove('hidden');
      document.getElementById('save-status').textContent = '';
      await loadNowStatus();
    }

    function closeNowEditor() {
      document.getElementById('now-editor-view').classList.add('hidden');
      document.getElementById('activity-editor-view').classList.add('hidden');
      document.getElementById('music-editor-view').classList.add('hidden');
      document.getElementById('editor-view').classList.add('hidden');
      document.getElementById('list-view').classList.remove('hidden');
      loadPosts();
    }

    async function loadNowStatus() {
      try {
        const res = await fetch('/api/now');
        const data = await res.json();
        if (data.error) throw new Error(data.error);
        nowStatusData = data;
        document.getElementById('now-start-date').value = data.startDate || '';
        document.getElementById('now-end-date').value = data.endDate || '';
        document.getElementById('now-phase').value = data.phase || '';
        document.getElementById('now-progress').value = data.progress ?? '';
        document.getElementById('now-description').value = data.description || '';
        document.getElementById('now-badge-text').value = data.badgeText || '';
        document.getElementById('now-project-description').value = data.projectDescription || '';
        document.getElementById('now-reading-title').value = data.readingTitle || '';
        document.getElementById('now-reading-subtitle').value = data.readingSubtitle || '';
        document.getElementById('now-learning-title').value = data.learningTitle || '';
        document.getElementById('now-learning-subtitle').value = data.learningSubtitle || '';
        document.getElementById('now-researching-title').value = data.researchingTitle || '';
        document.getElementById('now-researching-subtitle').value = data.researchingSubtitle || '';
        document.getElementById('now-listening-title').value = data.listeningTitle || '';
        document.getElementById('now-listening-subtitle').value = data.listeningSubtitle || '';
        // 项目截图
        document.getElementById('now-screenshot-url').value = data.projectScreenshot || '';
        updateScreenshotPreview(data.projectScreenshot);
        updateNowPreview();
      } catch (e) {
        document.getElementById('now-save-status').textContent = '加载失败: ' + e.message;
        document.getElementById('now-save-status').className = 'text-xs text-red-500';
      }
    }

    function updateNowPreview() {
      document.getElementById('preview-start-date').textContent = document.getElementById('now-start-date').value || '...';
      document.getElementById('preview-end-date').textContent = document.getElementById('now-end-date').value || '...';
      document.getElementById('preview-phase').textContent = document.getElementById('now-phase').value || '...';
      const p = document.getElementById('now-progress').value;
      document.getElementById('preview-progress').textContent = (p !== '' ? p : '...') + '%';
      document.getElementById('preview-description').textContent = document.getElementById('now-description').value || '...';
    }

    // 项目截图上传统一方法
    async function uploadNowScreenshot() {
      const fileInput = document.getElementById('now-screenshot-file');
      const file = fileInput.files?.[0];
      if (!file) {
        document.getElementById('now-screenshot-upload-status').textContent = '请先选择图片文件';
        document.getElementById('now-screenshot-upload-status').className = 'text-[11px] text-red-500 mt-1.5 block';
        return;
      }

      const statusEl = document.getElementById('now-screenshot-upload-status');
      statusEl.textContent = '上传中...';
      statusEl.className = 'text-[11px] text-[#999] mt-1.5 block';

      const formData = new FormData();
      formData.append('file', file);

      try {
        const res = await fetch('/api/upload', { method: 'POST', body: formData });
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const result = await res.json();
        if (result.error) {
          statusEl.textContent = result.error;
          statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
        } else {
          document.getElementById('now-screenshot-url').value = result.url;
          updateScreenshotPreview(result.url);
          statusEl.textContent = '✓ 上传成功';
          statusEl.className = 'text-[11px] text-[#7CB38B] mt-1.5 block';
          fileInput.value = '';
          setTimeout(() => {
            if (statusEl.textContent.includes('✓')) statusEl.textContent = '';
          }, 3000);
        }
      } catch (e) {
        statusEl.textContent = '网络错误，请重试';
        statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
      }
    }

    function updateCoverPreview(url) {
      const placeholder = document.getElementById('cover-placeholder');
      const img = document.getElementById('cover-preview');
      if (url) {
        img.src = url;
        placeholder.classList.add('hidden');
        img.classList.remove('hidden');
      } else {
        img.src = '';
        placeholder.classList.remove('hidden');
        img.classList.add('hidden');
      }
    }

    async function uploadCoverImage() {
      const fileInput = document.getElementById('cover-file');
      const file = fileInput.files?.[0];
      if (!file) {
        const statusEl = document.getElementById('cover-upload-status');
        statusEl.textContent = '请先选择图片文件';
        statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
        return;
      }

      const statusEl = document.getElementById('cover-upload-status');
      statusEl.textContent = '上传中...';
      statusEl.className = 'text-[11px] text-[#999] mt-1.5 block';

      const formData = new FormData();
      formData.append('file', file);

      try {
        const res = await fetch('/api/upload', { method: 'POST', body: formData });
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const result = await res.json();
        if (result.error) {
          statusEl.textContent = result.error;
          statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
        } else {
          document.getElementById('field-coverImage').value = result.url;
          updateCoverPreview(result.url);
          statusEl.textContent = '✓ 上传成功';
          statusEl.className = 'text-[11px] text-[#7CB38B] mt-1.5 block';
          fileInput.value = '';
          setTimeout(() => {
            if (statusEl.textContent.includes('✓')) statusEl.textContent = '';
          }, 3000);
        }
      } catch (e) {
        statusEl.textContent = '上传失败，请重试';
        statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
      }
    }

    function updateScreenshotPreview(url) {
      const placeholder = document.getElementById('now-screenshot-placeholder');
      const img = document.getElementById('now-screenshot-preview');
      if (url) {
        img.src = url;
        placeholder.classList.add('hidden');
        img.classList.remove('hidden');

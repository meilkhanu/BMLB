    async function addActivity() {
      const content = document.getElementById('activity-new-content').value.trim();
      const activityDate = document.getElementById('activity-new-date').value.trim();
      const statusEl = document.getElementById('activity-add-status');

      if (!content || !activityDate) {
        statusEl.textContent = '请填写内容和日期';
        statusEl.className = 'text-[11px] text-red-500 block -mt-3 mb-4';
        return;
      }

      statusEl.textContent = '添加中...';
      statusEl.className = 'text-[11px] text-[#999] block -mt-3 mb-4';

      try {
        const res = await fetch('/api/now/activity', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content, activityDate }),
        });
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const result = await res.json();
        if (result.error) {
          statusEl.textContent = result.error;
          statusEl.className = 'text-[11px] text-red-500 block -mt-3 mb-4';
        } else {
          document.getElementById('activity-new-content').value = '';
          document.getElementById('activity-new-date').value = '';
          statusEl.textContent = '✓ 已添加';
          statusEl.className = 'text-[11px] text-[#7CB38B] block -mt-3 mb-4';
          await loadActivities();
          setTimeout(() => { if (statusEl.textContent.includes('✓')) statusEl.textContent = ''; }, 2000);
        }
      } catch (e) {
        statusEl.textContent = '网络错误，请重试';
        statusEl.className = 'text-[11px] text-red-500 block -mt-3 mb-4';
      }
    }

    async function _deleteActivity(id) {
      if (!confirm('确认删除这条日志？')) return;
      try {
        const res = await fetch(`/api/now/activity?id=${id}`, { method: 'DELETE' });
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        await loadActivities();
      } catch (e) {
        alert('删除失败，请重试');
      }
    }
    window._deleteActivity = _deleteActivity;


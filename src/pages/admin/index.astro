---
// src/pages/admin/index.astro
// 管理后台主页：文章列表 + 新建/编辑（TinyMCE）+ 删除
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>管理后台 — 贝谟拉比</title>
  <!-- TinyMCE 8 (API key, 需在 tiny.cloud 控制台注册域名) -->
  <script src="https://cdn.tiny.cloud/1/jyhfqudwd0zic9z9y1l31phs1jcg0pdb72q46rf9xpd56x0t/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
</head>
<body class="bg-[#FAFAFA] dark:bg-[#0F0F0F] text-[#1A1A1A] dark:text-[#EAEAEA]">

  <!-- ========== 顶部栏 ========== -->
  <header class="fixed top-0 left-0 w-full h-16 z-50 bg-[rgba(250,250,250,0.9)] dark:bg-[rgba(15,15,15,0.9)] backdrop-blur-md border-b border-[#EAEAEA] dark:border-[#222]">
    <div class="max-w-[1400px] mx-auto px-6 h-full flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/" class="text-lg font-bold no-underline text-[#1A1A1A] dark:text-[#EAEAEA] hover:text-[#8B7CB3] transition-colors">贝谟拉比</a>
        <span class="text-[10px] font-bold text-[#8B7CB3] bg-[#8B7CB3]/10 px-2 py-1 rounded-md tracking-widest uppercase">管理后台</span>
      </div>
      <div class="flex items-center gap-3">
        <button id="edit-now-btn" class="px-4 py-2 rounded-full bg-[#F5F5F5] dark:bg-[#252525] text-[#8B7CB3] text-sm font-bold hover:bg-[#8B7CB3] hover:text-white active:scale-95 transition-all cursor-pointer border-none">编辑 /now</button>
        <button id="edit-activity-btn" class="px-4 py-2 rounded-full bg-[#F5F5F5] dark:bg-[#252525] text-[#8B7CB3] text-sm font-bold hover:bg-[#8B7CB3] hover:text-white active:scale-95 transition-all cursor-pointer border-none">微日志</button>
        <button id="music-btn" class="px-4 py-2 rounded-full bg-[#F5F5F5] dark:bg-[#252525] text-[#8B7CB3] text-sm font-bold hover:bg-[#8B7CB3] hover:text-white active:scale-95 transition-all cursor-pointer border-none">音乐</button>
        <button id="new-post-btn" class="px-4 py-2 rounded-full bg-[#8B7CB3] text-white text-sm font-bold hover:bg-[#7A6BA2] active:scale-95 transition-all cursor-pointer border-none">+ 新建文章</button>
        <button id="logout-btn" class="px-4 py-2 rounded-full bg-transparent text-sm text-[#999] hover:text-red-500 transition-colors cursor-pointer border-none">登出</button>
      </div>
    </div>
  </header>

  <!-- ========== 主体区域 ========== -->
  <main class="pt-20 pb-12 px-6 max-w-[1400px] mx-auto">

    <!-- —— 文章列表 —— -->
    <div id="list-view">
      <!-- 加载状态 -->
      <div id="loading-state" class="text-center py-20 text-[#999] text-sm">加载中...</div>

      <!-- 错误状态 -->
      <div id="error-state" class="hidden text-center py-20">
        <p class="text-red-500 text-sm mb-4" id="error-msg-text"></p>
        <button onclick="location.reload()" class="px-4 py-2 rounded-full bg-white dark:bg-[#252525] text-sm border border-[#E0E0E0] dark:border-[#333] cursor-pointer">重试</button>
      </div>

      <!-- 空状态 -->
      <div id="empty-state" class="hidden text-center py-20">
        <p class="text-[#999] text-lg mb-2">还没有文章</p>
        <p class="text-[#999] text-sm mb-6">点击上方「+ 新建文章」开始写作</p>
      </div>

      <!-- 文章表格 -->
      <div id="posts-table" class="hidden">
        <div class="overflow-x-auto rounded-2xl border border-[#EAEAEA] dark:border-[#2A2A2A]">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-[#F5F5F5] dark:bg-[#1A1A1A] text-left">
                <th class="px-5 py-3 font-medium text-[#999] text-xs w-16">状态</th>
                <th class="px-5 py-3 font-medium text-[#999] text-xs">标题</th>
                <th class="px-5 py-3 font-medium text-[#999] text-xs w-20">分类</th>
                <th class="px-5 py-3 font-medium text-[#999] text-xs w-28">日期</th>
                <th class="px-5 py-3 font-medium text-[#999] text-xs w-36">操作</th>
              </tr>
            </thead>
            <tbody id="posts-tbody" class="divide-y divide-[#EAEAEA] dark:divide-[#2A2A2A]"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- —— 编辑器面板（隐藏） —— -->
    <div id="editor-view" class="hidden">
      <form id="editor-form" onsubmit="return false">
        <!-- 返回按钮 -->
        <button type="button" id="back-btn" class="flex items-center gap-1.5 text-sm text-[#999] hover:text-[#8B7CB3] transition-colors mb-6 bg-transparent border-none cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          返回列表
        </button>

        <!-- 字段区 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">标题 *</label>
            <input type="text" id="field-title" required class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
          </div>
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">Slug（URL标识）*</label>
            <input type="text" id="field-slug" required pattern="[a-z0-9\-]+" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm font-mono outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
          </div>
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">分类 *</label>
            <select id="field-category" required class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all cursor-pointer">
              <option value="notes">札记</option>
              <option value="critique">时评簿</option>
              <option value="stack">车间</option>
              <option value="body">体感</option>
              <option value="transit">行记</option>
              <option value="archive">底片</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">发布日期</label>
            <input type="text" id="field-publishedAt" placeholder="如 2026-05-04，留空则取今天" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">标签（逗号分隔）</label>
            <input type="text" id="field-tags" placeholder="建站, Astro" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
          </div>
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">状态</label>
            <select id="field-status" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all cursor-pointer">
              <option value="draft">草稿</option>
              <option value="published">发布</option>
            </select>
          </div>
        </div>

        <div class="mb-4">
          <label class="block text-xs font-medium text-[#999] mb-1.5">摘要</label>
          <textarea id="field-excerpt" rows="2" placeholder="留空则自动从正文截取..." class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all resize-none"></textarea>
        </div>

        <!-- 封面图：支持 URL 输入或本地上传 -->
        <div class="grid grid-cols-1 md:grid-cols-[1fr_200px] gap-4 mb-4">
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">封面图（可选）</label>
            <input type="text" id="field-coverImage" placeholder="https://... 或直接上传" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
            <div class="flex gap-2 mt-2">
              <input type="file" id="cover-file" accept="image/png,image/jpeg,image/webp,image/avif" class="flex-1 text-sm text-[#666] dark:text-[#999] file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-[#8B7CB3]/10 file:text-[#8B7CB3] hover:file:bg-[#8B7CB3]/20 file:transition-colors file:cursor-pointer" />
              <button type="button" id="cover-upload-btn" class="px-4 py-2 rounded-full bg-[#8B7CB3] text-white text-xs font-bold hover:bg-[#7A6BA2] active:scale-95 transition-all cursor-pointer border-none whitespace-nowrap">上传</button>
            </div>
            <span id="cover-upload-status" class="text-[11px] text-[#999] mt-1.5 block"></span>
          </div>
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">预览</label>
            <div id="cover-preview-container" class="w-full aspect-[16/9] rounded-xl bg-[#F5F5F5] dark:bg-[#1A1A1A] border border-[#E0E0E0] dark:border-[#333] flex items-center justify-center overflow-hidden">
              <span id="cover-placeholder" class="text-xs text-[#999]">暂无封面</span>
              <img id="cover-preview" src="" alt="封面预览" class="hidden w-full h-full object-cover" />
            </div>
          </div>
        </div>

        <div class="mb-4">
          <label class="block text-xs font-medium text-[#999] mb-1.5">正文 *</label>
          <textarea id="field-content" class="w-full min-h-[400px] px-4 py-3 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm font-mono outline-none focus:border-[#8B7CB3] resize-y"></textarea>
        </div>

        <!-- 操作按钮 -->
        <div class="flex items-center gap-3 pt-4 border-t border-[#EAEAEA] dark:border-[#2A2A2A]">
          <button type="button" id="save-draft-btn" class="px-6 py-2.5 rounded-full bg-[#F5F5F5] dark:bg-[#252525] text-sm font-medium text-[#666] dark:text-[#999] hover:bg-[#E0E0E0] dark:hover:bg-[#333] active:scale-95 transition-all cursor-pointer border-none">保存草稿</button>
          <button type="button" id="publish-btn" class="px-6 py-2.5 rounded-full bg-[#8B7CB3] text-white text-sm font-bold hover:bg-[#7A6BA2] active:scale-95 transition-all cursor-pointer border-none">发布</button>
          <span id="save-status" class="text-xs text-[#999] ml-2"></span>
        </div>
      </form>
    </div>

    <!-- —— /now 状态面板编辑器（隐藏） —— -->
    <div id="now-editor-view" class="hidden">
      <button type="button" id="now-back-btn" class="flex items-center gap-1.5 text-sm text-[#999] hover:text-[#8B7CB3] transition-colors mb-6 bg-transparent border-none cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        返回列表
      </button>

      <!-- 预览卡片：与 /now 页面状态面板同样式 -->
      <div class="group bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md rounded-[32px] border border-white/20 dark:border-white/10 shadow-sm p-6 md:p-8 relative overflow-hidden mb-8">
        <div class="absolute -top-24 -left-24 w-64 h-64 bg-[#8B7CB3]/10 dark:bg-[#8B7CB3]/20 rounded-full blur-3xl pointer-events-none opacity-50 z-0"></div>
        <div class="flex flex-col md:flex-row gap-6 relative z-10">
          <div class="md:w-[35%] flex flex-col justify-center">
            <p class="text-xs font-medium text-[#999] uppercase tracking-widest mb-1">Now</p>
            <h1 class="text-2xl md:text-3xl font-bold text-[#1A1A1A] dark:text-[#EAEAEA]">目前把时间花在这里</h1>
            <p class="text-sm text-[#999] mt-2">Current Focus</p>
            <h1 class="text-2xl md:text-3xl font-bold text-[#1A1A1A] dark:text-[#EAEAEA]">建设</h1>
            <p class="text-sm text-[#999]">Building</p>
            <h1 class="text-2xl md:text-3xl font-bold text-[#1A1A1A] dark:text-[#EAEAEA]">ing</h1>
          </div>
          <div class="md:w-[30%]">
            <p class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest mb-3">The Flowing of Becoming</p>
            <div class="text-sm space-y-1">
              <div class="flex justify-between items-center px-2 py-1.5 -mx-2 rounded-lg">
                <span class="text-[#999]">开始时间</span>
                <span id="preview-start-date" class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">...</span>
              </div>
              <div class="flex justify-between items-center px-2 py-1.5 -mx-2 rounded-lg">
                <span class="text-[#999]">预计结束</span>
                <span id="preview-end-date" class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">...</span>
              </div>
              <div class="flex justify-between items-center px-2 py-1.5 -mx-2 rounded-lg">
                <span class="text-[#999]">当前阶段</span>
                <span id="preview-phase" class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">...</span>
              </div>
              <div class="flex justify-between items-center px-2 py-1.5 -mx-2 rounded-lg">
                <span class="text-[#999]">进度</span>
                <span id="preview-progress" class="font-mono font-semibold text-[#1A1A1A] dark:text-[#EAEAEA]">...</span>
              </div>
            </div>
          </div>
          <div class="md:w-[35%]">
            <p class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest mb-3">事项描述</p>
            <p id="preview-description" class="text-sm text-[#666] dark:text-[#888] leading-relaxed">...</p>
          </div>
        </div>
      </div>

      <!-- 编辑表单 -->
      <div class="bg-white dark:bg-[#1A1A1A] rounded-3xl p-6 md:p-8 border border-[#EAEAEA] dark:border-[#2A2A2A] shadow-sm">
        <h3 class="text-lg font-bold mb-6">编辑 /now 状态面板</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">开始时间 *</label>
            <input type="text" id="now-start-date" required placeholder="如 2026-04-30" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
          </div>
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">预计结束 *</label>
            <input type="text" id="now-end-date" required placeholder="如 2026-05-20" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
          </div>
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">当前阶段 *</label>
            <input type="text" id="now-phase" required placeholder="如 Phase 2" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
          </div>
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">进度（0-100）</label>
            <input type="number" id="now-progress" min="0" max="100" placeholder="72" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
          </div>
        </div>
        <div class="mb-4">
          <label class="block text-xs font-medium text-[#999] mb-1.5">事项描述 *</label>
          <textarea id="now-description" rows="4" required placeholder="描述当前正在进行的事项..." class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all resize-none"></textarea>
        </div>

        <!-- Current Project 编辑 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-xs font-medium text-[#999] mb-1.5">状态标签文字</label>
            <input type="text" id="now-badge-text" placeholder="如 高投入推进中" class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all" />
          </div>
        </div>
        <div class="mb-4">
          <label class="block text-xs font-medium text-[#999] mb-1.5">项目描述</label>
            <textarea id="now-project-description" rows="3" placeholder="描述当前项目的推进状态..." class="w-full px-4 py-2.5 rounded-xl border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] focus:ring-2 focus:ring-[#8B7CB3]/20 transition-all resize-none"></textarea>
          </div>

          <!-- 项目截图上传 -->
          <div class="mb-4">
            <h4 class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] mb-4">项目截图</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <!-- 左侧：上传控件 -->
              <div>
                <label class="block text-xs font-medium text-[#999] mb-1.5">上传截图</label>
                <div class="flex gap-2">
                  <input type="file" id="now-screenshot-file" accept="image/png,image/jpeg,image/webp,image/avif" class="flex-1 text-sm text-[#666] dark:text-[#999] file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-[#8B7CB3]/10 file:text-[#8B7CB3] hover:file:bg-[#8B7CB3]/20 file:transition-colors file:cursor-pointer" />
                  <button type="button" id="now-screenshot-upload-btn" class="px-4 py-2 rounded-full bg-[#8B7CB3] text-white text-xs font-bold hover:bg-[#7A6BA2] active:scale-95 transition-all cursor-pointer border-none whitespace-nowrap">上传</button>
                </div>
                <span id="now-screenshot-upload-status" class="text-[11px] text-[#999] mt-1.5 block"></span>
                <input type="hidden" id="now-screenshot-url" />
              </div>
              <!-- 右侧：预览 -->
              <div>
                <label class="block text-xs font-medium text-[#999] mb-1.5">预览</label>
                <div id="now-screenshot-preview-container" class="w-full aspect-[21/9] rounded-xl bg-[#F5F5F5] dark:bg-[#1A1A1A] border border-[#E0E0E0] dark:border-[#333] flex items-center justify-center overflow-hidden">
                  <span id="now-screenshot-placeholder" class="text-xs text-[#999]">未上传截图</span>
                  <img id="now-screenshot-preview" src="" alt="项目截图预览" class="hidden w-full h-full object-cover" />
                </div>
              </div>
            </div>
          </div>

          <!-- 并行卡片矩阵编辑 -->
        <div class="mb-4">
          <h4 class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] mb-4">并行卡片矩阵</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- 正在阅读 -->
            <div class="bg-[#F5F5F5] dark:bg-[#1A1A1A] rounded-2xl p-4 border border-[#EAEAEA] dark:border-[#2A2A2A]">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-lg">📖</span>
                <span class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA]">正在阅读</span>
              </div>
              <div class="space-y-2">
                <input type="text" id="now-reading-title" placeholder="事项名称" class="w-full px-3 py-2 rounded-lg border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] transition-all" />
                <input type="text" id="now-reading-subtitle" placeholder="进度或副标题" class="w-full px-3 py-2 rounded-lg border border-[#E0E0E0] dark:border-[#333] bg-white dark:bg-[#252525] text-sm outline-none focus:border-[#8B7CB3] transition-all" />
              </div>

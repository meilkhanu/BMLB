    (async function init() {
      await checkAuth();
      await loadPosts();
    })();

    // 登录状态检查
    async function checkAuth() {
      try {
        const res = await fetch('/api/auth');
        const data = await res.json();
        if (!data.logged_in) {
          window.location.href = '/admin/login';
        }
      } catch (e) {
        window.location.href = '/admin/login';
      }
    }

    // ============================================================
    // 文章列表
    // ============================================================
    async function loadPosts() {
      showListState('loading');
      try {
        const res = await fetch('/api/posts?admin=1');
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const posts = await res.json();
        if (posts.error) throw new Error(posts.error);

        if (posts.length === 0) {
          showListState('empty');
        } else {
          renderTable(posts);
          showListState('table');
        }
      } catch (e) {
        showListState('error', e.message);
      }
    }

    function showListState(state, msg) {
      document.getElementById('loading-state').classList.toggle('hidden', state !== 'loading');
      document.getElementById('empty-state').classList.toggle('hidden', state !== 'empty');
      document.getElementById('error-state').classList.toggle('hidden', state !== 'error');
      document.getElementById('posts-table').classList.toggle('hidden', state !== 'table');
      if (state === 'error') {
        document.getElementById('error-msg-text').textContent = msg || '加载失败';
      }
    }

    function renderTable(posts) {
      const tbody = document.getElementById('posts-tbody');
      tbody.innerHTML = posts.map(p => {
        const statusClass = p.status === 'published'
          ? 'bg-[#7CB38B]/10 text-[#7CB38B]'
          : 'bg-[#E8913A]/10 text-[#E8913A]';
        const statusText = p.status === 'published' ? '已发布' : '草稿';
        const catMap = { notes:'札记', critique:'时评簿', stack:'车间', body:'体感', transit:'行记', archive:'底片' };
        const catName = catMap[p.categoryId] || p.categoryId;
        const date = p.publishedAt || '—';
        return `
          <tr class="hover:bg-[#F5F5F5] dark:hover:bg-[#1A1A1A] transition-colors">
            <td class="px-5 py-3"><span class="px-2 py-0.5 rounded-md text-[10px] font-bold ${statusClass}">${statusText}</span></td>
            <td class="px-5 py-3 font-medium">${escapeHtml(p.title)}</td>
            <td class="px-5 py-3 text-[#999] text-xs">${catName}</td>
            <td class="px-5 py-3 text-[#999] text-xs font-mono">${date}</td>
            <td class="px-5 py-3">
              <div class="flex gap-2">
                <button onclick="editPost('${p.slug}')" class="px-3 py-1 rounded-lg text-xs font-medium bg-[#F5F5F5] dark:bg-[#252525] hover:bg-[#8B7CB3] hover:text-white transition-colors cursor-pointer border-none">编辑</button>
                <button onclick="confirmDelete('${p.slug}', '${escapeJs(p.title)}')" class="px-3 py-1 rounded-lg text-xs font-medium bg-[#F5F5F5] dark:bg-[#252525] hover:bg-red-500 hover:text-white transition-colors cursor-pointer border-none">删除</button>
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }

    // ============================================================
    // 编辑器
    // ============================================================
    document.getElementById('new-post-btn').addEventListener('click', () => openEditor());
    document.getElementById('back-btn').addEventListener('click', () => closeEditor());

    async function openEditor(slug = null) {
      currentSlug = slug;

      // 切换视图
      document.getElementById('list-view').classList.add('hidden');
      document.getElementById('now-editor-view').classList.add('hidden');
      document.getElementById('activity-editor-view').classList.add('hidden');
      document.getElementById('music-editor-view').classList.add('hidden');
      document.getElementById('editor-view').classList.remove('hidden');
      document.getElementById('save-status').textContent = '';

      if (slug) {
        // 编辑模式：加载文章数据
        const res = await fetch(`/api/posts?slug=${slug}&admin=1`);
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const post = await res.json();
        if (post.error) { alert(post.error); closeEditor(); return; }
        populateForm(post);
      } else {
        // 新建模式：清空表单
        resetForm();
      }

      // 初始化 TinyMCE
      initTinyMCE();
    }

    function closeEditor() {
      if (tinymceReady) {
        tinymce.remove('#field-content');
        tinymceReady = false;
      }
      currentSlug = null;
      document.getElementById('editor-view').classList.add('hidden');
      document.getElementById('now-editor-view').classList.add('hidden');
      document.getElementById('activity-editor-view').classList.add('hidden');
      document.getElementById('music-editor-view').classList.add('hidden');
      document.getElementById('list-view').classList.remove('hidden');
      loadPosts();
    }

    // ============================================================
    // 音乐管理
    // ============================================================
    async function openMusicEditor() {
      document.getElementById('list-view').classList.add('hidden');
      document.getElementById('editor-view').classList.add('hidden');
      document.getElementById('now-editor-view').classList.add('hidden');
      document.getElementById('activity-editor-view').classList.add('hidden');
      document.getElementById('music-editor-view').classList.remove('hidden');
      hideMusicForm();
      await loadSongs();
    }

    function closeMusicEditor() {
      document.getElementById('music-editor-view').classList.add('hidden');
      document.getElementById('list-view').classList.remove('hidden');
    }

    async function loadSongs() {
      const listEl = document.getElementById('music-list');
      listEl.innerHTML = '<p class="text-sm text-[#999]">加载中...</p>';
      try {
        const res = await fetch('/api/songs');
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const songs = await res.json();
        if (!Array.isArray(songs) || songs.length === 0) {
          listEl.innerHTML = '<p class="text-sm text-[#999]">暂无歌曲，点击「添加歌曲」开始上传</p>';
          return;
        }
        listEl.innerHTML = songs.map(s => `
          <div class="flex items-center justify-between p-3 rounded-2xl bg-[#F5F5F5] dark:bg-[#1A1A1A] border border-[#EAEAEA] dark:border-[#2A2A2A]">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-10 h-10 rounded-lg bg-gradient-to-tr from-[#8B7CB3] to-[#C9BAE5] dark:to-[#4A3B73] flex items-center justify-center text-white shrink-0">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
              </div>
              <div class="min-w-0">
                <div class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] truncate">${escapeHtml(s.title)}</div>
                <div class="text-xs text-[#999] truncate">${escapeHtml(s.artist || '未知艺术家')} · ${escapeHtml(s.album || '未知专辑')}</div>
              </div>
            </div>
            <div class="flex gap-2 shrink-0 ml-2">
              <button onclick="editSong(${s.id})" class="px-3 py-1 rounded-lg text-xs font-medium bg-white dark:bg-[#252525] hover:bg-[#8B7CB3] hover:text-white transition-colors cursor-pointer border-none">编辑</button>
              <button onclick="confirmDeleteSong(${s.id}, '${escapeJs(s.title)}')" class="px-3 py-1 rounded-lg text-xs font-medium bg-white dark:bg-[#252525] hover:bg-red-500 hover:text-white transition-colors cursor-pointer border-none">删除</button>
            </div>
          </div>
        `).join('');
      } catch (e) {
        listEl.innerHTML = '<p class="text-sm text-red-500">加载失败</p>';
      }
    }

    function showMusicForm(song = null) {
      currentMusicId = song ? song.id : null;
      document.getElementById('music-form-title').textContent = song ? '编辑歌曲' : '添加歌曲';
      document.getElementById('music-id').value = song ? song.id : '';
      document.getElementById('music-title').value = song ? song.title : '';
      document.getElementById('music-artist').value = song ? (song.artist || '') : '';
      document.getElementById('music-album').value = song ? (song.album || '') : '';
      document.getElementById('music-cover-url').value = song ? (song.cover_url || '') : '';
      document.getElementById('music-audio-url').value = song ? (song.audio_url || '') : '';
      document.getElementById('music-sort').value = song ? (song.sort_order || 0) : '';
      document.getElementById('music-save-status').textContent = '';
      updateMusicCoverPreview(song ? (song.cover_url || '') : '');
      document.getElementById('music-form').classList.remove('hidden');
      document.getElementById('music-list').scrollTop = 0;
    }

    function hideMusicForm() {
      currentMusicId = null;
      document.getElementById('music-form').classList.add('hidden');
    }

    async function saveSong() {
      const data = {
        title: document.getElementById('music-title').value.trim(),
        artist: document.getElementById('music-artist').value.trim(),
        album: document.getElementById('music-album').value.trim(),
        coverUrl: document.getElementById('music-cover-url').value.trim(),
        audioUrl: document.getElementById('music-audio-url').value.trim(),
        sortOrder: parseInt(document.getElementById('music-sort').value) || 0,
      };

      if (!data.title || !data.audioUrl) {
        document.getElementById('music-save-status').textContent = '请填写歌曲标题和音频 URL';
        document.getElementById('music-save-status').className = 'text-xs text-red-500';
        return;
      }

      const statusEl = document.getElementById('music-save-status');
      statusEl.textContent = '保存中...';
      statusEl.className = 'text-xs text-[#999]';

      const url = '/api/songs' + (currentMusicId ? `?id=${currentMusicId}` : '');
      const method = currentMusicId ? 'PUT' : 'POST';

      try {
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const result = await res.json();
        if (result.error) {
          statusEl.textContent = result.error;
          statusEl.className = 'text-xs text-red-500';
        } else {
          statusEl.textContent = '✓ 保存成功';
          statusEl.className = 'text-xs text-[#7CB38B]';
          hideMusicForm();
          await loadSongs();
        }
      } catch (e) {
        statusEl.textContent = '保存失败，请重试';
        statusEl.className = 'text-xs text-red-500';
      }
    }

    async function uploadMusicCover() {
      const fileInput = document.getElementById('music-cover-file');
      const file = fileInput.files?.[0];
      if (!file) {
        const statusEl = document.getElementById('music-cover-status');
        statusEl.textContent = '请先选择图片文件';
        statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
        return;
      }
      const statusEl = document.getElementById('music-cover-status');
      statusEl.textContent = '上传中...';
      statusEl.className = 'text-[11px] text-[#999] mt-1.5 block';
      const formData = new FormData();
      formData.append('file', file);
      try {
        const res = await fetch('/api/upload', { method: 'POST', body: formData });
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const result = await res.json();
        if (result.error) {
          statusEl.textContent = result.error;
          statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
        } else {
          document.getElementById('music-cover-url').value = result.url;
          updateMusicCoverPreview(result.url);
          statusEl.textContent = '✓ 上传成功';
          statusEl.className = 'text-[11px] text-[#7CB38B] mt-1.5 block';
          fileInput.value = '';
          setTimeout(() => { if (statusEl.textContent.includes('✓')) statusEl.textContent = ''; }, 3000);
        }
      } catch (e) {
        statusEl.textContent = '上传失败，请重试';
        statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
      }
    }

    async function uploadMusicAudio() {
      const fileInput = document.getElementById('music-audio-file');
      const file = fileInput.files?.[0];
      if (!file) {
        const statusEl = document.getElementById('music-audio-status');
        statusEl.textContent = '请先选择音频文件';
        statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
        return;
      }
      const statusEl = document.getElementById('music-audio-status');
      statusEl.textContent = '上传中...';
      statusEl.className = 'text-[11px] text-[#999] mt-1.5 block';
      const formData = new FormData();
      formData.append('file', file);
      try {
        const res = await fetch('/api/upload', { method: 'POST', body: formData });
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        const result = await res.json();
        if (result.error) {
          statusEl.textContent = result.error;
          statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
        } else {
          document.getElementById('music-audio-url').value = result.url;
          statusEl.textContent = '✓ 上传成功';
          statusEl.className = 'text-[11px] text-[#7CB38B] mt-1.5 block';
          fileInput.value = '';
          setTimeout(() => { if (statusEl.textContent.includes('✓')) statusEl.textContent = ''; }, 3000);
        }
      } catch (e) {
        statusEl.textContent = '上传失败，请重试';
        statusEl.className = 'text-[11px] text-red-500 mt-1.5 block';
      }
    }

    function updateMusicCoverPreview(url) {
      const placeholder = document.getElementById('music-cover-placeholder');
      const img = document.getElementById('music-cover-preview');
      if (url) {
        img.src = url;
        placeholder.classList.add('hidden');
        img.classList.remove('hidden');
      } else {
        img.src = '';
        placeholder.classList.remove('hidden');
        img.classList.add('hidden');
      }
    }

    window.editSong = (id) => {
      fetch('/api/songs').then(r => r.json()).then(songs => {
        const song = songs.find(s => s.id === id);
        if (song) showMusicForm(song);
      });
    };

    window.confirmDeleteSong = (id, title) => {
      if (!confirm(`删除「${title}」？此操作不可撤销。`)) return;
      fetch(`/api/songs?id=${id}`, { method: 'DELETE' })
        .then(r => { if (r.status === 401) window.location.href = '/admin/login'; return r.json(); })
        .then(() => loadSongs())
        .catch(() => alert('删除失败，请重试'));
    };

    function resetForm() {
      document.getElementById('field-title').value = '';
      document.getElementById('field-slug').value = '';
      document.getElementById('field-category').value = 'notes';
      document.getElementById('field-publishedAt').value = '';
      document.getElementById('field-tags').value = '';
      document.getElementById('field-status').value = 'draft';
      document.getElementById('field-coverImage').value = '';
      document.getElementById('field-excerpt').value = '';
      document.getElementById('cover-file').value = '';
      document.getElementById('cover-upload-status').textContent = '';
      updateCoverPreview('');
    }

    function populateForm(post) {
      document.getElementById('field-title').value = post.title || '';
      document.getElementById('field-slug').value = post.slug || '';
      document.getElementById('field-category').value = post.categoryId || 'notes';
      document.getElementById('field-publishedAt').value = post.publishedAt || '';
      document.getElementById('field-tags').value = (post.tags || []).join(', ');
      document.getElementById('field-status').value = post.status || 'draft';
      document.getElementById('field-coverImage').value = post.coverImage || '';
      document.getElementById('field-excerpt').value = post.excerpt || '';
      updateCoverPreview(post.coverImage || '');
      // content 由 TinyMCE 填充
    }

    function initTinyMCE() {
      if (tinymceReady) {
        tinymce.remove('#field-content');
      }

      tinymce.init({
        selector: '#field-content',
        height: 600,
        plugins: 'anchor autolink charmap codesample emoticons image link lists searchreplace table visualblocks wordcount fullscreen code',
        toolbar: 'undo redo | blocks fontfamily fontsize | bold italic underline strikethrough forecolor backcolor | h2 h3 | bullist numlist | link image | blockquote codesample | table charmap | searchreplace | removeformat fullscreen',
        menubar: false,
        statusbar: true,
        content_style: 'body { font-family: Inter, PingFang SC, Microsoft YaHei, sans-serif; font-size: 16px; line-height: 1.8; color: #1a1a1a; padding: 1rem; max-width: 860px; margin: 0 auto; }',
        images_upload_handler: async (blobInfo, progress) => new Promise((resolve, reject) => {
          const formData = new FormData();
          formData.append('file', blobInfo.blob(), blobInfo.filename());

          const xhr = new XMLHttpRequest();
          xhr.open('POST', '/api/upload', true);

          xhr.upload.onprogress = (e) => {
            if (e.lengthComputable) {
              progress(e.loaded / e.total * 100);
            }
          };

          xhr.onload = () => {
            if (xhr.status === 401) {
              reject('登录已过期，请刷新页面重新登录');
              return;
            }
            if (xhr.status < 200 || xhr.status >= 300) {
              try {
                const err = JSON.parse(xhr.responseText);
                reject(err.error || '上传失败');
              } catch {
                reject('上传失败 (HTTP ' + xhr.status + ')');
              }
              return;
            }
            try {
              const result = JSON.parse(xhr.responseText);
              if (result.url) {
                resolve(result.url);
              } else {
                reject('上传响应缺少 URL');
              }
            } catch {
              reject('上传响应解析失败');
            }
          };

          xhr.onerror = () => reject('网络错误，上传失败');
          xhr.send(formData);
        }),
        setup: (editor) => {
          editor.on('init', () => {
            tinymceReady = true;
            // 编辑模式下填充正文内容
            if (currentSlug) {
              loadContentIntoEditor(editor);
            }
          });
        },
      });
    }

    async function loadContentIntoEditor(editor) {
      const res = await fetch(`/api/posts?slug=${currentSlug}&admin=1`);
      const post = await res.json();
      if (post.content && editor) {
        editor.setContent(post.content);
      }
    }

    function getContent() {
      if (tinymceReady) {
        return tinymce.get('field-content')?.getContent() || '';
      }
      return '';
    }

    function collectFormData() {
      const tagsRaw = document.getElementById('field-tags').value;
      const tags = tagsRaw
        ? tagsRaw.split(/[,，]/).map(t => t.trim()).filter(Boolean)
        : [];

      let publishedAt = document.getElementById('field-publishedAt').value.trim();
      if (!publishedAt) {
        const today = new Date();
        publishedAt = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
      }

      return {
        slug: document.getElementById('field-slug').value.trim(),
        title: document.getElementById('field-title').value.trim(),
        content: getContent(),
        excerpt: document.getElementById('field-excerpt').value.trim(),
        categoryId: document.getElementById('field-category').value,
        tags,
        coverImage: document.getElementById('field-coverImage').value.trim(),
        publishedAt,
        status: document.getElementById('field-status').value,
      };
    }

    // Slug 自动生成（中文标题 → 时间戳兜底）
    document.getElementById('field-title').addEventListener('blur', function() {
      const slugField = document.getElementById('field-slug');
      if (!slugField.value && !currentSlug) {
        const title = this.value.trim();
        // 简单处理：无中文输入时自动转 slug，中文则留空让用户手动填
        if (title && /^[a-zA-Z0-9\s-]+$/.test(title)) {
          slugField.value = title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
        }
      }
    });

    // ============================================================
    // 保存 / 发布
    // ============================================================
    document.getElementById('save-draft-btn').addEventListener('click', () => savePost('draft'));
    document.getElementById('publish-btn').addEventListener('click', () => savePost('published'));

    async function savePost(status) {
      const data = collectFormData();
      data.status = status;

      // 先从 TinyMCE 获取最新正文内容（必须在校验之前）
      if (tinymceReady) {
        data.content = tinymce.get('field-content')?.getContent() || '';
      }

      // 校验
      if (!data.title || !data.slug || !data.content || !data.categoryId) {
        document.getElementById('save-status').textContent = '请填写标题、Slug 和正文';
        document.getElementById('save-status').className = 'text-xs text-red-500 ml-2';
        return;
      }

      const isUpdate = !!currentSlug && data.slug === currentSlug;
      const url = '/api/posts';
      const method = isUpdate ? 'PUT' : 'POST';

      const statusEl = document.getElementById('save-status');
      statusEl.textContent = '保存中...';
      statusEl.className = 'text-xs text-[#999] ml-2';

      try {
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.status === 401) { window.location.href = '/admin/login'; return; }

        const result = await res.json();
        if (result.error) {
          statusEl.textContent = result.error;
          statusEl.className = 'text-xs text-red-500 ml-2';
        } else {
          statusEl.textContent = status === 'published' ? '✓ 已发布' : '✓ 草稿已保存';
          statusEl.className = 'text-xs text-[#7CB38B] ml-2';
          currentSlug = result.slug || data.slug;

          // 3 秒后返回列表
          setTimeout(() => {
            if (document.getElementById('save-status').textContent.includes('✓')) {
              closeEditor();
            }
          }, 1500);
        }
      } catch (e) {
        statusEl.textContent = '网络错误，请重试';
        statusEl.className = 'text-xs text-red-500 ml-2';
      }
    }

    // ============================================================
    // 删除
    // ============================================================
    function confirmDelete(slug, title) {
      deleteTarget = slug;
      document.getElementById('delete-title-text').textContent = `删除「${title}」？此操作不可撤销。`;
      document.getElementById('delete-modal').classList.remove('hidden');
    }

    document.getElementById('delete-cancel-btn').addEventListener('click', () => {
      document.getElementById('delete-modal').classList.add('hidden');
      deleteTarget = null;
    });

    document.getElementById('delete-confirm-btn').addEventListener('click', async () => {
      if (!deleteTarget) return;
      try {
        const res = await fetch(`/api/posts?slug=${deleteTarget}`, { method: 'DELETE' });
        if (res.status === 401) { window.location.href = '/admin/login'; return; }
        document.getElementById('delete-modal').classList.add('hidden');
        deleteTarget = null;
        loadPosts();
      } catch (e) {
        alert('删除失败，请重试');
      }
    });

    // ============================================================
    // 登出
    // ============================================================
    document.getElementById('logout-btn').addEventListener('click', async () => {
      await fetch('/api/auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'logout' }),
      });
      window.location.href = '/';
    });

    // ============================================================
    // 公开函数（供 onclick 调用）
    // ============================================================
    window.editPost = (slug) => openEditor(slug);
    window.confirmDelete = confirmDelete;

    // ============================================================
    // 工具函数
    // ============================================================
    function escapeHtml(s) {
      if (!s) return '';
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escapeJs(s) {
      if (!s) return '';
      return s.replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/"/g,'\\"');
    }
  </script>
</body>
</html>

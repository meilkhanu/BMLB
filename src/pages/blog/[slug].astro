---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../../config.ts';
import { env as cfEnv } from 'cloudflare:workers';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

// —— 服务端调用内部 API 获取文章数据 ——
// Astro SSR 在 Cloudflare Worker 中运行，fetch 同源 API 无额外延迟

interface ApiPost {
  id: number;
  slug: string;
  title: string;
  content: string;
  excerpt: string;
  categoryId: string;
  tags: string[];
  coverImage: string;
  publishedAt: string;
  createdAt: string;
  updatedAt: string;
  status: string;
}

let postData: ApiPost | null = null;
let allPublished: ApiPost[] = [];

try {
  const db = (cfEnv as any)?.DB;
  if (db) {
    // 获取单篇文章
    const postRow = await db.prepare(
      "SELECT * FROM posts WHERE slug = ? AND status = 'published'"
    ).bind(slug).first();
    if (postRow) {
      postData = {
        id: postRow.id, slug: postRow.slug, title: postRow.title,
        content: postRow.content, excerpt: postRow.excerpt || '',
        categoryId: postRow.category_id, tags: JSON.parse(postRow.tags || '[]'),
        coverImage: postRow.cover_image || '', publishedAt: postRow.published_at || '',
        createdAt: postRow.created_at, updatedAt: postRow.updated_at, status: postRow.status,
      };
    }
    // 获取全部已发布列表（用于上下篇）
    const { results } = await db.prepare(
      "SELECT * FROM posts WHERE status = 'published' ORDER BY published_at DESC LIMIT 50"
    ).all();
    allPublished = (results || []).map((row: any) => ({
      id: row.id, slug: row.slug, title: row.title,
      content: row.content, excerpt: row.excerpt || '',
      categoryId: row.category_id, tags: JSON.parse(row.tags || '[]'),
      coverImage: row.cover_image || '', publishedAt: row.published_at || '',
      createdAt: row.created_at, updatedAt: row.updated_at, status: row.status,
    }));
  }
} catch {
  // 查询失败 → 404
}

if (!postData || !postData.title) {
  return Astro.redirect('/404');
}

// —— 映射到模板变量 ——
const post = postData;

// 计算上下篇（按 publishedAt 降序排列）
const currentIdx = allPublished.findIndex((p: ApiPost) => p.slug === slug);
const prev = currentIdx > 0 ? allPublished[currentIdx - 1] : null;
const next = currentIdx >= 0 && currentIdx < allPublished.length - 1 ? allPublished[currentIdx + 1] : null;

// 计算阅读时间（中文约 400 字/分钟）
function estimateReadingTime(html: string): number {
  const text = html.replace(/<[^>]+>/g, '');
  const chars = text.replace(/\s/g, '').length;
  return Math.max(1, Math.ceil(chars / 400));
}
const readingTime = estimateReadingTime(post.content);

// 分类信息映射
const categoryInfo = SITE_CONFIG.categories.find(c => c.id === post.categoryId);
const catName = categoryInfo?.name ?? post.categoryId;
const catColor = categoryInfo?.color ?? '#8B7CB3';

// —— 智能返回：根据来源决定返回链接 ——
const referer = Astro.request.headers.get('referer') || '';
const siteUrl = Astro.url.origin;
const cameFromArchive = referer.startsWith(siteUrl + '/archive');
const cameFromSite = referer.startsWith(siteUrl);
const backUrl = cameFromArchive ? '/archive' : (cameFromSite ? '/' : '/archive');
const backLabel = backUrl === '/' ? '返回首页' : '返回归档';

// 格式化日期
const dateStr = post.publishedAt || post.createdAt;
const dateObj = new Date(dateStr);
const isValidDate = !isNaN(dateObj.getTime());
const dateFormatted = isValidDate
  ? `${dateObj.getFullYear()}年${dateObj.getMonth() + 1}月${dateObj.getDate()}日`
  : dateStr;

// —— 服务端获取评论（极简版，头像交客户端增强） ——
let comments: any[] = [];

try {
  const db = (cfEnv as any)?.DB;
  if (db) {
    const { results } = await db.prepare(
      "SELECT * FROM comments WHERE target_slug = ? ORDER BY created_at ASC"
    ).bind(slug).all();
    comments = (results || []).map((row: any) => ({
      id: row.id, author: row.author, email: row.email || '',
      content: row.content, targetSlug: row.target_slug, createdAt: row.created_at,
    }));
  }
} catch (e: any) {
  console.error('[blog] D1 comments 查询失败:', e?.message || e);
}
---

<BaseLayout title={`${post.title} — ${SITE_CONFIG.siteName}`}>
  <article class="max-w-[900px] mx-auto px-4 md:px-6 pt-28 pb-16">

    <!-- 返回链接 -->
    <a
      href={backUrl}
      class="inline-flex items-center gap-1.5 text-sm text-[#999] hover:text-[#8B7CB3] transition-colors duration-300 mb-8 group no-underline"
    >
      <svg
        class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1"
        fill="none" stroke="currentColor" viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <span>{backLabel}</span>
    </a>

    <!-- ========== 文章头部 ========== -->
    <header class="mb-12">
      <!-- 分类徽章 + 日期 -->
      <div class="flex items-center gap-3 mb-5 flex-wrap">
        <span
          class="px-3 py-1 rounded-lg text-[11px] font-bold tracking-widest uppercase"
          style={`background-color: ${catColor}18; color: ${catColor}`}
        >
          {catName}
        </span>
        <span class="text-xs font-medium text-[#999] flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {dateFormatted}
        </span>
        <span class="text-xs text-[#999]">· 约 {readingTime} 分钟</span>
      </div>

      <!-- 标题 -->
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] leading-tight tracking-tight mb-6">
        {post.title}
      </h1>

      <!-- 封面图（如果有）或渐变色块 -->
      {
        post.coverImage ? (
          <div class="w-full aspect-[21/9] rounded-3xl overflow-hidden mb-0 shadow-sm">
            <img
              src={post.coverImage}
              alt={post.title}
              class="w-full h-full object-cover"
            />
          </div>
        ) : (
          <div
            class="w-full aspect-[21/9] rounded-3xl mb-0 flex items-center justify-center relative overflow-hidden"
            style={`background: linear-gradient(135deg, ${catColor}20 0%, ${catColor}08 50%, transparent 100%)`}
          >
            <div class="absolute inset-0 bg-[linear-gradient(to_right,#8B7CB310_1px,transparent_1px),linear-gradient(to_bottom,#8B7CB310_1px,transparent_1px)] bg-[size:3rem_3rem] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_50%,#000_20%,transparent_100%)]"></div>
          </div>
        )
      }
    </header>

    <!-- ========== 文章正文 ========== -->
    <div
      class="prose prose-lg dark:prose-invert max-w-none
        prose-headings:text-[#1A1A1A] dark:prose-headings:text-[#EAEAEA]
        prose-headings:font-bold prose-headings:tracking-tight
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-5
        prose-p:text-[#444] dark:prose-p:text-[#AAA]
        prose-p:leading-[1.85] prose-p:mb-5 prose-p:text-[16px]
        prose-strong:text-[#1A1A1A] dark:prose-strong:text-[#EAEAEA]
        prose-a:text-[#8B7CB3] dark:prose-a:text-[#8B7CB3]
        prose-a:no-underline hover:prose-a:underline
        prose-li:text-[#444] dark:prose-li:text-[#AAA]
        prose-li:leading-[1.8] prose-li:mb-1
        prose-code:text-[#8B7CB3] dark:prose-code:text-[#C9BAE5]
        prose-code:bg-[#8B7CB3]/10 dark:prose-code:bg-[#8B7CB3]/15
        prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md
        prose-code:text-sm prose-code:font-medium
        prose-code:before:content-none prose-code:after:content-none
        prose-ul:pl-0 prose-ul:list-none prose-ul:space-y-2
        prose-li:pl-6 prose-li:relative
        [&_ul>li::before]:content-['—']
        [&_ul>li::before]:absolute [&_ul>li::before]:left-0
        [&_ul>li::before]:text-[#CCC] dark:[&_ul>li::before]:text-[#555]"
    >
      <Fragment set:html={post.content} />
    </div>

    <!-- ========== 标签 ========== -->
    {
      post.tags && post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2.5 mt-12 pt-8 border-t border-[#E8E8E8] dark:border-[#2A2A2A]">
          {post.tags.map(tag => (
            <span class="px-3 py-1.5 rounded-xl text-xs font-medium bg-[#F5F5F5] dark:bg-[#252525] text-[#666] dark:text-[#999] hover:bg-[#8B7CB3] hover:text-white dark:hover:bg-[#8B7CB3] dark:hover:text-white transition-all duration-300 cursor-default">
              #{tag}
            </span>
          ))}
        </div>
      )
    }

    <!-- ========== 评论 ========== -->
    <section class="mt-16" id="comments-section">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px flex-1 bg-[#E8E8E8] dark:bg-[#2A2A2A]"></div>
        <span class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest shrink-0">Comments</span>
        <span class="text-[10px] font-medium text-[#999] flex items-center gap-1.5 shrink-0">
          <span class="relative flex h-1.5 w-1.5"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span><span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span></span>
          Open
        </span>
        <div class="h-px flex-1 bg-[#E8E8E8] dark:bg-[#2A2A2A]"></div>
      </div>

      <!-- 评论输入区 -->
      <div class="mb-8" id="comments-input-area">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-2">
          <input type="text" id="cmt-author" placeholder="昵称（选填）" maxlength="20"
            class="px-3 py-2 rounded-xl border border-[#ECECEC] dark:border-[#2B2B2B] bg-white/75 dark:bg-[#141414]/80 text-xs placeholder:text-[#B3B3B3] dark:placeholder:text-[#666] text-[#1A1A1A] dark:text-[#EAEAEA] outline-none focus:border-[#8B7CB3]/45 transition-all" />
          <input type="text" id="cmt-email" placeholder="邮箱（选填，用于头像）"
            class="px-3 py-2 rounded-xl border border-[#ECECEC] dark:border-[#2B2B2B] bg-white/75 dark:bg-[#141414]/80 text-xs placeholder:text-[#B3B3B3] dark:placeholder:text-[#666] text-[#1A1A1A] dark:text-[#EAEAEA] outline-none focus:border-[#8B7CB3]/45 transition-all" />
        </div>
        <div class="group relative flex overflow-hidden rounded-2xl border border-[#ECECEC] bg-white/75 backdrop-blur-xl shadow-[0_8px_24px_rgba(0,0,0,.04)] transition-all duration-300 dark:border-[#2B2B2B] dark:bg-[#141414]/80 focus-within:border-[#8B7CB3]/45 focus-within:shadow-[0_10px_30px_rgba(139,124,179,.10)] focus-within:ring-4 focus-within:ring-[#8B7CB3]/8">
          <textarea id="cmt-content" rows="2" maxlength="500" placeholder="写下你的想法..."
            class="flex-1 resize-none bg-transparent px-5 py-4 text-sm leading-6 text-[#1A1A1A] placeholder:text-[#B3B3B3] outline-none dark:text-[#EAEAEA] dark:placeholder:text-[#666]"></textarea>
          <div class="w-px self-stretch bg-[#EFEFEF] transition-colors duration-300 dark:bg-[#2F2F2F] group-focus-within:bg-[#8B7CB3]/25"></div>
          <button type="button" id="cmt-send-btn"
            class="group/btn relative flex w-[78px] shrink-0 items-center justify-center overflow-hidden bg-[#8B7CB3]/8 text-[#8B7CB3] transition-all duration-300 hover:bg-[#8B7CB3] active:scale-[0.98] border-none cursor-pointer">
            <span class="absolute inset-0 overflow-hidden">
              <span class="animate-sweep absolute top-0 h-full w-10 -skew-x-12 bg-white/20"></span>
            </span>
            <span class="relative z-10 flex items-center gap-1.5 text-xs font-semibold tracking-wide transition-colors duration-300 group-hover/btn:text-white">
              发送
              <svg class="h-4 w-4 transition-transform duration-300 group-hover/btn:translate-x-0.5 group-hover/btn:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
              </svg>
            </span>
          </button>
        </div>
        <div class="mt-2 flex items-center justify-between px-1">
          <span id="cmt-send-status" class="text-[11px] text-[#A0A0A0] dark:text-[#666]">友善交流，理性表达</span>
          <span class="text-[11px] text-[#A0A0A0] dark:text-[#666]">Ctrl + Enter 发送</span>
        </div>
      </div>

      <!-- 评论列表 -->
      <div class="space-y-4" id="comments-list">
        {comments.map((cmt, idx) => {
          const name = (cmt.author || '').trim() || '访客';
          const initial = name.charAt(0).toUpperCase();
          const accentIdx = idx % 3;
          const avatarColors = ['text-[#8B7CB3]', 'text-blue-500', 'text-emerald-500'];
          const borders = ['group-hover:border-[#8B7CB3]/20', 'group-hover:border-blue-500/20', 'group-hover:border-emerald-500/20'];
          const names = ['group-hover:text-[#8B7CB3]', 'group-hover:text-blue-500', 'group-hover:text-emerald-500'];
          const bgColors = ['#8B7CB3','#4A90D9','#7CB38B','#E8913A','#B26A8B','#5BC0BE'];
          let hash = 0;
          for (let i = 0; i < name.length; i++) { hash = name.charCodeAt(i) + hash * 31; }
          const bgColor = bgColors[Math.abs(hash) % bgColors.length];
          const timeStr = cmt.createdAt
            ? new Date(cmt.createdAt + 'Z').toLocaleString('zh-CN', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })
            : '';
          return (
            <div class="group flex gap-3 cursor-default" data-comment-email={(cmt.email || '').trim()}>
              <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 group-hover:scale-110 group-hover:shadow-sm transition-all duration-300 overflow-hidden" style={`background: linear-gradient(135deg, ${bgColor}20, ${bgColor}30)`}>
                <span class={`text-xs font-bold comment-avatar-text ${avatarColors[accentIdx]}`}>{initial}</span>
                <img class="comment-avatar-img hidden w-full h-full object-cover" alt="" loading="lazy" />
              </div>
              <div class="flex flex-col gap-1 w-full">
                <div class="flex items-center justify-between pl-1">
                  <span class={`text-[11px] font-bold text-[#1A1A1A] dark:text-[#EAEAEA] ${names[accentIdx]} transition-colors duration-300`}>{name}</span>
                  <span class="text-[10px] text-[#999] opacity-0 group-hover:opacity-100 transition-opacity duration-300">{timeStr}</span>
                </div>
                <div class={`bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md p-3 rounded-2xl rounded-tl-none text-sm text-[#666] dark:text-[#888] shadow-sm border border-white/20 dark:border-white/10 group-hover:-translate-y-1 group-hover:shadow-md ${borders[accentIdx]} transition-all duration-300`}>
                  {cmt.content}
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <!-- 无评论时的空状态 -->
      {comments.length === 0 && (
        <div id="comments-empty" class="text-center py-8">
          <p class="text-sm text-[#999]">暂无评论，来说点什么吧</p>
        </div>
      )}
    </section>

    <!-- ========== 上下篇导航 ========== -->
    <nav class="mt-16 grid grid-cols-1 sm:grid-cols-2 gap-4">
      {prev ? (
        <a
          href={`/blog/${prev.slug}`}
          class="group flex flex-col gap-2 bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md rounded-2xl p-5 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1 hover:shadow-md hover:border-[#8B7CB3]/20 transition-all duration-300 no-underline"
        >
          <span class="text-[10px] font-bold text-[#999] tracking-widest uppercase flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            上一篇
          </span>
          <span class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors line-clamp-1">
            {prev.title}
          </span>
        </a>
      ) : (
        <div></div>
      )}

      {next ? (
        <a
          href={`/blog/${next.slug}`}
          class="group flex flex-col gap-2 bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md rounded-2xl p-5 border border-white/20 dark:border-white/10 shadow-sm hover:-translate-y-1 hover:shadow-md hover:border-[#8B7CB3]/20 transition-all duration-300 no-underline text-right"
        >
          <span class="text-[10px] font-bold text-[#999] tracking-widest uppercase flex items-center justify-end gap-1">
            下一篇
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
          <span class="text-sm font-bold text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors line-clamp-1">
            {next.title}
          </span>
        </a>
      ) : (
        <div></div>
      )}
    </nav>

    <!-- ========== 底部返回 ========== -->
    <div class="mt-12 text-center">
      <a
        href={backUrl}
        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-white dark:bg-[#252525] shadow-[0_2px_10px_-3px_rgba(0,0,0,0.05)] hover:shadow-md border border-transparent hover:border-[#8B7CB3]/20 transition-all duration-300 text-sm font-medium text-[#666] dark:text-[#999] hover:text-[#1A1A1A] dark:hover:text-[#EAEAEA] no-underline"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {backLabel}
      </a>
    </div>
  </article>

  <script is:inline>
    // —— 文章评论交互 ——
    (function () {
      var slug = window.location.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
      var authorEl = document.getElementById('cmt-author');
      var emailEl = document.getElementById('cmt-email');
      var contentEl = document.getElementById('cmt-content');
      var sendBtn = document.getElementById('cmt-send-btn');
      var statusEl = document.getElementById('cmt-send-status');
      var listEl = document.getElementById('comments-list');
      var emptyEl = document.getElementById('comments-empty');

      // 简单 MD5（客户端 Gravatar 用）
      function md5(str) {
        function r(n, c) { return (n << c) | (n >>> (32 - c)); }
        function q(n, c, t, b, x, s) { return r(n + c + t + b + x, s); }
        function a(i, a, b, c, d, s, t) { return q(b & c | ~b & d, a, b, i, t, s); }
        function m(i, a, b, c, d, s, t) { return q(b & d | c & ~d, a, b, i, t, s); }
        function p(i, a, b, c, d, s, t) { return q(b ^ c ^ d, a, b, i, t, s); }
        function s(i, a, b, c, d, s, t) { return q(c ^ (b | ~d), a, b, i, t, s); }
        var l = str.length, w = [0];
        for (var i = 0; i < l; i++) w[i >> 2] |= str.charCodeAt(i) << ((i % 4) * 8);
        w[l >> 2] |= 0x80 << ((l % 4) * 8);
        w[((l + 8 >> 6) << 4) + 15] = l * 8;
        var va = 0x67452301, vb = 0xEFCDAB89, vc = 0x98BADCFE, vd = 0x10325476;
        for (var i = 0; i < w.length; i += 16) {
          var aa = va, bb = vb, cc = vc, dd = vd;
          for (var j = 0; j < 64; j++) {
            var f;
            if (j < 16) { f = a(w[i+j]||0, aa, bb, cc, dd, [7,12,17,22][j%4], [0xD76AA478,0xE8C7B756,0x242070DB,0xC1BDCEEE,0xF57C0FAF,0x4787C62A,0xA8304613,0xFD469501,0x698098D8,0x8B44F7AF,0xFFFF5BB1,0x895CD7BE,0x6B901122,0xFD987193,0xA679438E,0x49B40821][j]); }
            else if (j < 32) { f = m(w[i+((5*j+1)%16)]||0, aa, bb, cc, dd, [5,9,14,20][j%4], [0xF61E2562,0xC040B340,0x265E5A51,0xE9B6C7AA,0xD62F105D,0x02441453,0xD8A1E681,0xE7D3FBC8,0x21E1CDE6,0xC33707D6,0xF4D50D87,0x455A14ED,0xA9E3E905,0xFCEFA3F8,0x676F02D9,0x8D2A4C8A][j-16]); }
            else if (j < 48) { f = p(w[i+((3*j+5)%16)]||0, aa, bb, cc, dd, [4,11,16,23][j%4], [0xFFFA3942,0x8771F681,0x6D9D6122,0xFDE5380C,0xA4BEEA44,0x4BDECFA9,0xF6BB4B60,0xBEBFBC70,0x289B7EC6,0xEAA127FA,0xD4EF3085,0x04881D05,0xD9D4D039,0xE6DB99E5,0x1FA27CF8,0xC4AC5665][j-32]); }
            else { f = s(w[i+((7*j)%16)]||0, aa, bb, cc, dd, [6,10,15,21][j%4], [0xF4292244,0x432AFF97,0xAB9423A7,0xFC93A039,0x655B59C3,0x8F0CCC92,0xFFEFF47D,0x85845DD1,0x6FA87E4F,0xFE2CE6E0,0xA3014314,0x4E0811A1,0xF7537E82,0xBD3AF235,0x2AD7D2BB,0xEB86D391][j-48]); }
            var tmp = dd;
            dd = cc; cc = bb; bb = bb + r(aa + f, [7,12,17,22,5,9,14,20,4,11,16,23,6,10,15,21][j % 16]); aa = tmp;
          }
          va += aa; vb += bb; vc += cc; vd += dd;
        }
        function h(n) { return (n >>> 0).toString(16).padStart(8, '0'); }
        return h(va) + h(vb) + h(vc) + h(vd);
      }

      function getColor(name) {
        var colors = ['#8B7CB3','#4A90D9','#7CB38B','#E8913A','#B26A8B','#5BC0BE'];
        var hash = 0;
        for (var i = 0; i < name.length; i++) hash = name.charCodeAt(i) + ((hash << 5) - hash);
        return colors[Math.abs(hash) % colors.length];
      }

      function formatTime(isoStr) {
        if (!isoStr) return '';
        var d = new Date(isoStr + 'Z');
        var months = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
        return months[d.getMonth()] + d.getDate() + '日 ' + String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
      }

      var cmtCount = listEl ? listEl.children.length : 0;

      // 增强现有评论：有邮箱的替换为 Gravatar 头像
      function enhanceExistingAvatars() {
        var items = listEl ? listEl.querySelectorAll('[data-comment-email]') : [];
        for (var i = 0; i < items.length; i++) {
          var email = items[i].getAttribute('data-comment-email') || '';
          if (!email) continue;
          var textEl = items[i].querySelector('.comment-avatar-text');
          var imgEl = items[i].querySelector('.comment-avatar-img');
          if (textEl && imgEl) {
            var hash = md5(email.toLowerCase());
            imgEl.src = 'https://www.gravatar.com/avatar/' + hash + '?d=mp&s=64';
            imgEl.classList.remove('hidden');
            textEl.classList.add('hidden');
          }
        }
      }
      enhanceExistingAvatars();
      function renderComment(msg, idx) {
        var name = msg.author || '访客';
        var initial = name.charAt(0).toUpperCase();
        var color = getColor(name);
        var avatarClasses = ['text-[#8B7CB3]','text-blue-500','text-emerald-500'];
        var avatarClass = avatarClasses[(idx + cmtCount) % 3];
        var borderHover = ['group-hover:border-[#8B7CB3]/20','group-hover:border-blue-500/20','group-hover:border-emerald-500/20'][(idx + cmtCount) % 3];
        var nameHover = ['group-hover:text-[#8B7CB3]','group-hover:text-blue-500','group-hover:text-emerald-500'][(idx + cmtCount) % 3];
        var timeStr = formatTime(msg.createdAt);

        var avatarHtml = msg.email
          ? '<img src="https://www.gravatar.com/avatar/' + md5(msg.email.trim().toLowerCase()) + '?d=mp&s=64" alt="" class="w-full h-full object-cover" loading="lazy" />'
          : '<span class="text-xs font-bold ' + avatarClass + '">' + initial + '</span>';

        return '<div class="group flex gap-3 cursor-default">' +
          '<div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 group-hover:scale-110 group-hover:shadow-sm transition-all duration-300 overflow-hidden" style="background: linear-gradient(135deg, ' + color + '20, ' + color + '30)">' +
            avatarHtml +
          '</div>' +
          '<div class="flex flex-col gap-1 w-full">' +
            '<div class="flex items-center justify-between pl-1">' +
              '<span class="text-[11px] font-bold text-[#1A1A1A] dark:text-[#EAEAEA] ' + nameHover + ' transition-colors duration-300">' + name + '</span>' +
              (timeStr ? '<span class="text-[10px] text-[#999] opacity-0 group-hover:opacity-100 transition-opacity duration-300">' + timeStr + '</span>' : '') +
            '</div>' +
            '<div class="bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md p-3 rounded-2xl rounded-tl-none text-sm text-[#666] dark:text-[#888] shadow-sm border border-white/20 dark:border-white/10 group-hover:-translate-y-1 group-hover:shadow-md ' + borderHover + ' transition-all duration-300">' +
              msg.content +
            '</div>' +
          '</div>' +
        '</div>';
      }

      async function submitComment() {
        var author = authorEl.value.trim();
        var email = emailEl.value.trim();
        var content = contentEl.value.trim();

        if (!content) {
          statusEl.textContent = '请输入评论内容';
          statusEl.className = 'text-[11px] text-red-500';
          return;
        }

        sendBtn.disabled = true;
        statusEl.textContent = '发送中...';
        statusEl.className = 'text-[11px] text-[#A0A0A0] dark:text-[#666]';

        try {
          var res = await fetch('/api/comments', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ author: author, email: email, content: content, slug: slug }),
          });
          var result = await res.json();
          if (result.error) {
            statusEl.textContent = result.error;
            statusEl.className = 'text-[11px] text-red-500';
          } else {
            contentEl.value = '';
            statusEl.textContent = '✓ 评论成功';
            statusEl.className = 'text-[11px] text-[#7CB38B]';

            // 隐藏空状态
            if (emptyEl) emptyEl.remove();

            // 追加评论到列表
            if (listEl) {
              var html = renderComment(result, 0);
              listEl.insertAdjacentHTML('beforeend', html);
              cmtCount++;
            }

            setTimeout(function () {
              if (statusEl.textContent.indexOf('✓') === 0) {
                statusEl.textContent = '友善交流，理性表达';
                statusEl.className = 'text-[11px] text-[#A0A0A0] dark:text-[#666]';
              }
            }, 2000);
          }
        } catch (e) {
          statusEl.textContent = '网络错误，请重试';
          statusEl.className = 'text-[11px] text-red-500';
        } finally {
          sendBtn.disabled = false;
        }
      }

      sendBtn.addEventListener('click', submitComment);
      contentEl.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
          e.preventDefault();
          submitComment();
        }
      });
    })();
  </script>
</BaseLayout>


---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../config.ts';
import { getDb } from '../lib/db';

// —— 服务端获取全部已发布文章 ——
interface ApiPost {
  id: number;
  slug: string;
  title: string;
  excerpt: string;
  categoryId: string;
  tags: string[];
  coverImage: string;
  publishedAt: string;
  createdAt: string;
  updatedAt: string;
  status: string;
}

let allPosts: ApiPost[] = [];
try {
  const db = getDb();
  if (db) {
    const { results } = await db.prepare(
      "SELECT id, slug, title, excerpt, category_id, tags, cover_image, published_at, created_at, updated_at, status FROM posts WHERE status = 'published' ORDER BY published_at DESC LIMIT 100"
    ).all();
    allPosts = (results || []).map((row: any) => ({
      id: row.id,
      slug: row.slug,
      title: row.title,
      excerpt: row.excerpt || '',
      categoryId: row.category_id,
      tags: JSON.parse(row.tags || '[]'),
      coverImage: row.cover_image || '',
      publishedAt: row.published_at || '',
      createdAt: row.created_at,
      updatedAt: row.updated_at,
      status: row.status,
    }));
  }
} catch (e: any) {
  console.error('[archive] D1 posts 查询失败:', e?.message || e);
}

// 分类映射
const catMap = Object.fromEntries(
  SITE_CONFIG.categories.map(c => [c.id, { name: c.name, color: c.color }])
);

// 按年月分组
interface MonthGroup {
  month: number;   // 1-12
  label: string;   // "04 月"
  posts: ApiPost[];
}

interface YearGroup {
  year: number;
  months: MonthGroup[];
  total: number;
}

const yearGroups: YearGroup[] = [];
const yearMap = new Map<number, Map<number, ApiPost[]>>();

allPosts.forEach(p => {
  const dateStr = p.publishedAt || p.createdAt;
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return;
  const y = d.getFullYear();
  const m = d.getMonth() + 1;
  if (!yearMap.has(y)) yearMap.set(y, new Map());
  const monthMap = yearMap.get(y)!;
  if (!monthMap.has(m)) monthMap.set(m, []);
  monthMap.get(m)!.push(p);
});

// 按年份降序排
const sortedYears = Array.from(yearMap.keys()).sort((a, b) => b - a);
sortedYears.forEach(y => {
  const monthMap = yearMap.get(y)!;
  const sortedMonths = Array.from(monthMap.keys()).sort((a, b) => b - a);
  const months: MonthGroup[] = sortedMonths.map(m => ({
    month: m,
    label: `${String(m).padStart(2, '0')} 月`,
    posts: monthMap.get(m)!,
  }));
  yearGroups.push({
    year: y,
    months,
    total: months.reduce((sum, mg) => sum + mg.posts.length, 0),
  });
});

// 统计标签（全部文章）
const tagCounts: Record<string, number> = {};
allPosts.forEach(p => {
  (p.tags || []).forEach(t => {
    tagCounts[t] = (tagCounts[t] || 0) + 1;
  });
});
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

// 年份节点颜色轮换
const yearColors = ['#8B7CB3', '#E8913A', '#4A5D8A', '#7CB38B', '#B38B7C', '#8B8B8B'];
---

<BaseLayout title="归档">
	<div class="fixed inset-0 pointer-events-none z-0 overflow-hidden mix-blend-multiply dark:mix-blend-screen">
		<div class="absolute inset-0 bg-[radial-gradient(#d1d5db_1.5px,transparent_1.5px)] dark:bg-[radial-gradient(#2c2c2c_1.5px,transparent_1.5px)] [background-size:32px_32px] opacity-100"></div>
		
		<div class="absolute inset-0">
			<div class="tech-dot bg-[#39C5BB]" style="left: 8%; bottom: -10px; --delay: 0s; --speed: 9s; --size: 3px;"></div>
			<div class="tech-dot bg-[#FF1A4D]" style="left: 18%; bottom: -10px; --delay: 4s; --speed: 12s; --size: 4px;"></div>
			<div class="tech-dot bg-[#39C5BB]" style="left: 28%; bottom: -10px; --delay: 2s; --speed: 7s; --size: 2px;"></div>
			<div class="tech-dot bg-[#FF1A4D]" style="left: 38%; bottom: -10px; --delay: 6s; --speed: 14s; --size: 3px;"></div>
			
			<div class="tech-dot bg-[#39C5BB]" style="left: 48%; bottom: -10px; --delay: 1.5s; --speed: 10s; --size: 4px;"></div>
			<div class="tech-dot bg-[#FF1A4D]" style="left: 58%; bottom: -10px; --delay: 5.5s; --speed: 8s; --size: 2.5px;"></div>
			<div class="tech-dot bg-[#39C5BB]" style="left: 65%; bottom: -10px; --delay: 3.2s; --speed: 13s; --size: 3px;"></div>
			<div class="tech-dot bg-[#FF1A4D]" style="left: 73%; bottom: -10px; --delay: 0.8s; --speed: 11s; --size: 3.5px;"></div>
			
			<div class="tech-dot bg-[#39C5BB]" style="left: 82%; bottom: -10px; --delay: 7s; --speed: 9.5s; --size: 2px;"></div>
			<div class="tech-dot bg-[#FF1A4D]" style="left: 89%; bottom: -10px; --delay: 2.5s; --speed: 15s; --size: 4px;"></div>
			<div class="tech-dot bg-[#39C5BB]" style="left: 94%; bottom: -10px; --delay: 4.8s; --speed: 7.5s; --size: 3px;"></div>
			<div class="tech-dot bg-[#FF1A4D]" style="left: 97%; bottom: -10px; --delay: 1.2s; --speed: 10.5s; --size: 2px;"></div>
		</div>

		<div class="absolute bottom-16 right-16 opacity-30 dark:opacity-25 transition-all duration-500 hover:opacity-100 hidden lg:block hover:scale-110">
			<svg class="w-20 h-20 animate-mascot-float" viewBox="0 0 100 100">
				<circle cx="50" cy="50" r="42" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3,3" class="text-[#39C5BB]" fill="none" />
				<path d="M32,45 Q40,32 48,45 T64,45" stroke="currentColor" stroke-width="2" fill="none" class="text-[#FF1A4D]" />
				<text x="50" y="65" font-family="monospace" font-size="9" text-anchor="middle" font-weight="bold" class="fill-current text-[#999] dark:text-[#666] tracking-wider">SYS.0104</text>
			</svg>
		</div>
	</div>

	<div class="container mx-auto px-4 py-12 relative z-10 mix-blend-normal">

	<div class="max-w-[1400px] mx-auto px-4 md:px-6 pt-32 pb-12">
		<!-- 标题区 -->
		<div class="mb-12" data-animate>
			<div class="mb-16 ml-2 md:ml-0">
				<h1 class="text-4xl md:text-5xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] mb-3 tracking-tight">Archive</h1>
				<p class="text-base md:text-lg text-[#666] dark:text-[#999] tracking-wide">过往，现在，未来。因果能否超脱视界？</p>
		</div>

		<!-- 三栏布局 -->
		<div class="grid grid-cols-1 md:grid-cols-[200px_1fr_260px] gap-8">
			
			<!-- 左侧：年份导航（sticky） -->
			<aside class="hidden md:block">
				<div class="sticky top-24">
					<h3 class="text-xs font-medium text-[#999] uppercase tracking-wider mb-4">年份</h3>
					<nav class="flex flex-col gap-2">
						{yearGroups.length > 0 ? yearGroups.map(yg => (
							<a href={`#year-${yg.year}`} class="text-sm text-[#666] dark:text-[#999] hover:text-[#8B7CB3] transition-colors">{yg.year}</a>
						)) : (
							<span class="text-sm text-[#999]">暂无</span>
						)}
					</nav>
				</div>
			</aside>

			<!-- 中间：主时间轴 -->
			<main class="relative">
				<!-- 时间轴纵向竖线 -->
				<div class="absolute left-[12px] top-0 bottom-0 w-0 border-l-2 border-dashed border-[#E5E5E5] dark:border-[#222]"></div>

				{yearGroups.length > 0 ? yearGroups.map((yg, yi) => (
					<section id={`year-${yg.year}`} class="relative mb-12" data-animate>
						<!-- 年份大节点 -->
						<div class="sticky top-16 z-20 flex items-center gap-4 py-4 -ml-2 px-2 bg-[#FAFAFA] dark:bg-[#0F0F0F] mb-4 relative transition-colors duration-300">
							<div class="w-6 h-6 rounded-full border-4 border-[#FAFAFA] dark:border-[#0F0F0F] z-10" style={`background-color: ${yearColors[yi % yearColors.length]}`}></div>
							<h2 class="text-2xl font-bold">{yg.year}</h2>
							<div class="flex-1 h-[1px] bg-[#E0E0E0] dark:bg-[#2A2A2A]"></div>
						</div>

						{yg.months.map(mg => (
							<div class="ml-8 mb-8 relative">
								<h3 class="text-sm font-medium text-[#999] mb-4 relative">
									<span class="absolute left-[-20px] top-[50%] w-4 h-[2px] rounded-full bg-[#E5E5E5] dark:bg-[#222]"></span>
									{mg.label}
								</h3>

								<div class="flex flex-col gap-3">
									{mg.posts.map(p => {
										const cat = catMap[p.categoryId] || { name: p.categoryId, color: '#8B7CB3' };
										const dateStr = p.publishedAt || '';
										const d = new Date(dateStr);
										const mmdd = isNaN(d.getTime()) ? '' : `${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
										return (
											<a href={`/blog/${p.slug}`} class="group relative block bg-white dark:bg-[#252525] rounded-2xl p-4 shadow-sm hover:shadow-md transition-all">
												<div class="absolute top-1/2 -translate-y-1/2 left-[-25px] w-2 h-2 rounded-full bg-[#D0D0D0] dark:bg-[#3A3A3A] group-hover:bg-[#8B7CB3] group-hover:scale-150 transition-all duration-300 ring-4 ring-[#FAFAFA] dark:ring-[#0F0F0F] group-hover:ring-transparent z-10"></div>
												<div class="flex items-center gap-2 mb-2">
													<span class="px-2 py-0.5 rounded-md text-xs font-medium" style={`background-color:${cat.color}18;color:${cat.color}`}>{cat.name}</span>
													<span class="text-xs text-[#999]">{mmdd}</span>
												</div>
												<h4 class="text-base font-medium text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors">{p.title}</h4>
											</a>
										);
									})}
								</div>
							</div>
						))}
					</section>
				)) : (
					<div class="ml-8 text-sm text-[#999] py-12">暂无已发布文章</div>
				)}
			</main>

			<!-- 右侧：年度摘要卡片 -->
			<aside class="hidden md:block">
				<div class="sticky top-24 space-y-6">
					{yearGroups.slice(0, 1).map(yg => (
						<div class="group bg-white dark:bg-[#1A1A1A] rounded-3xl p-5 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500 border border-transparent hover:border-[#8B7CB3]/20">
							<div class="flex items-center justify-between mb-5">
								<h3 class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest">{yg.year} Overview</h3>
								<span class="relative flex h-2 w-2">
									<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#8B7CB3] opacity-75"></span>
									<span class="relative inline-flex rounded-full h-2 w-2 bg-[#8B7CB3]"></span>
								</span>
							</div>
							
							<div class="grid grid-cols-2 gap-3">
								<div class="p-3.5 rounded-2xl bg-[#FAFAFA] dark:bg-[#252525] group-hover:bg-[#8B7CB3]/5 transition-colors duration-300">
									<div class="text-3xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] mb-1 group-hover:text-[#8B7CB3] transition-colors">{yg.total}</div>
									<div class="text-[10px] font-medium text-[#999]">已发文章</div>
								</div>
								<div class="p-3.5 rounded-2xl bg-[#FAFAFA] dark:bg-[#252525] group-hover:bg-[#8B7CB3]/5 transition-colors duration-300">
									<div class="text-3xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] mb-1 group-hover:text-[#8B7CB3] transition-colors">{yg.months.length}</div>
									<div class="text-[10px] font-medium text-[#999]">活跃月份</div>
								</div>
							</div>
						</div>
					))}

					{topTags.length > 0 && (
						<div class="group bg-white dark:bg-[#1A1A1A] rounded-3xl p-5 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500 border border-transparent hover:border-[#8B7CB3]/20">
							<h3 class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest mb-4">Top Tags</h3>
							<div class="flex flex-wrap gap-2.5">
								{topTags.map(([tag, count]) => (
									<span class="px-3 py-1.5 rounded-xl text-xs font-medium bg-[#FAFAFA] dark:bg-[#252525] text-[#666] dark:text-[#999] hover:bg-[#8B7CB3] hover:text-white dark:hover:bg-[#8B7CB3] dark:hover:text-white transition-all duration-300 cursor-default active:scale-95 shadow-sm border border-transparent hover:shadow-md">
										{tag} <span class="text-[10px] opacity-50 ml-0.5">{count}</span>
									</span>
								))}
							</div>
						</div>
					)}
				</div>
			</aside>
		</div>

		<!-- 底部年度总结入口（保留） -->
		<div class="mt-20 mb-12 text-center">
			<button class="annual-review-btn">
				<span class="relative z-10">2026 Review →</span>
			</button>
		</div>
	</div>
</BaseLayout>

<style is:global>
	/* --- 🌐 极简背景与双歌姬联动动效（粒子强化版） --- */

	/* 挂件优雅浮动 */
	@keyframes mascot-floating {
		0%, 100% { transform: translateY(0) rotate(0deg); }
		50% { transform: translateY(-8px) rotate(3deg); }
	}

	/* 电子粒子缓缓上升 */
	@keyframes tech-pixel-up {
		0% {
			transform: translateY(0) scale(1);
			opacity: 0;
		}
		10% { opacity: 0.6; }
		80% { opacity: 0.4; }
		100% {
			transform: translateY(-105vh) scale(0.5);
			opacity: 0;
		}
	}

	.animate-mascot-float {
		animation: mascot-floating 5s ease-in-out infinite;
	}

	/* 粒子属性 */
	.tech-dot {
		position: absolute;
		width: var(--size);
		height: var(--size);
		border-radius: 50%;
		opacity: 0;
		animation: tech-pixel-up var(--speed) linear infinite;
		animation-delay: var(--delay);
		filter: drop-shadow(0 0 4px currentColor);
	}

	/* Apple 图层感知优化：带有高斯模糊的毛玻璃卡片 */
	.group.bg-white {
		backdrop-filter: blur(16px) saturate(120%) !important;
		background-color: rgba(255, 255, 255, 0.75) !important;
	}
	.dark .group.bg-white, .dark .bg-\[\#1A1A1A\] {
		backdrop-filter: blur(16px) saturate(120%) !important;
		background-color: rgba(26, 26, 26, 0.7) !important;
	}

	/* 让主轴上的文章列表卡片也自然穿透透光 */
	a.group.bg-white {
		background-color: rgba(255, 255, 255, 0.7) !important;
	}
	.dark a.group.bg-white, .dark main [class*="bg-[#252525]"] {
		background-color: rgba(37, 37, 37, 0.6) !important;
		backdrop-filter: blur(10px) !important;
	}
</style>

<script is:inline>
	document.querySelectorAll('a[href^="#"]').forEach(anchor => {
		anchor.addEventListener('click', function (e) {
			e.preventDefault();
			const target = document.querySelector(this.getAttribute('href'));
			if (target) {
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		});
	});
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="归档">
	<div class="max-w-[1400px] mx-auto px-4 md:px-6 pt-32 pb-12">
		<!-- 标题区 -->
		<div class="mb-12">
			<div class="mb-16 ml-2 md:ml-0">
				<h1 class="text-4xl md:text-5xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] mb-3 tracking-tight">Archive</h1>
				<p class="text-base md:text-lg text-[#666] dark:text-[#999] tracking-wide">过往，现在，未来。因果能否超脱视界？</p>
		</div>

		<!-- 三栏布局 -->
		<div class="grid grid-cols-1 md:grid-cols-[200px_1fr_260px] gap-8">
			
			<!-- 左侧：年份导航（sticky） -->
			<aside class="hidden md:block">
				<div class="sticky top-24">
					<h3 class="text-xs font-medium text-[#999] uppercase tracking-wider mb-4">年份</h3>
					<nav class="flex flex-col gap-2">
						<!-- 锚点链接 -->
						<a href="#year-2026" class="text-sm text-[#666] dark:text-[#999] hover:text-[#8B7CB3] transition-colors">2026</a>
						<a href="#year-2025" class="text-sm text-[#666] dark:text-[#999] hover:text-[#8B7CB3] transition-colors">2025</a>
					</nav>
				</div>
			</aside>

			<!-- 中间：主时间轴 -->
			<main class="relative">
				<!-- 时间轴纵向竖线（绝对定位，偏左） -->
				<div class="absolute left-[12px] top-0 bottom-0 w-0 border-l-2 border-dashed border-[#E5E5E5] dark:border-[#222]"></div>

				<!-- 2026 年份节点 -->
				<section id="year-2026" class="relative mb-12">
					<!-- 年份大节点 -->
					<div class="sticky top-16 z-20 flex items-center gap-4 py-4 -ml-2 px-2 bg-[#FAFAFA] dark:bg-[#0F0F0F] mb-4 relative transition-colors duration-300">
						<div class="w-6 h-6 rounded-full bg-[#8B7CB3] border-4 border-[#FAFAFA] dark:border-[#0F0F0F] z-10"></div>
						<h2 class="text-2xl font-bold">2026</h2>
						<div class="flex-1 h-[1px] bg-[#E0E0E0] dark:bg-[#2A2A2A]"></div>
					</div>

					<!-- 月份分组：04月 -->
					<div class="ml-8 mb-8 relative">
						<h3 class="text-sm font-medium text-[#999] mb-4 relative">
							<span class="absolute left-[-20px] top-[50%] w-4 h-[2px] rounded-full bg-[#E5E5E5] dark:bg-[#222]"></span>
							04 月
						</h3>

						<!-- 文章卡片（只显示标题+标签，点击跳转） -->
						<div class="flex flex-col gap-3">
							<a href="/blog/chun-ye-du-shu-ji" class="group relative block bg-white dark:bg-[#252525] rounded-2xl p-4 shadow-sm hover:shadow-md transition-all">
								<div class="absolute top-1/2 -translate-y-1/2 left-[-25px] w-2 h-2 rounded-full bg-[#D0D0D0] dark:bg-[#3A3A3A] group-hover:bg-[#8B7CB3] group-hover:scale-150 transition-all duration-300 ring-4 ring-[#FAFAFA] dark:ring-[#0F0F0F] group-hover:ring-transparent z-10"></div>
								<div class="flex items-center gap-2 mb-2">
									<span class="px-2 py-0.5 rounded-md text-xs font-medium bg-[#8B7CB3]/10 text-[#8B7CB3]">札记</span>
									<span class="text-xs text-[#999]">04-20</span>
								</div>
								<h4 class="text-base font-medium text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors">半封闭景观水体碳酸盐系统与碳汇观测日志</h4>
							</a>

							<a href="/blog/ka-fei-yu-dai-ma" class="group relative block bg-white dark:bg-[#252525] rounded-2xl p-4 shadow-sm hover:shadow-md transition-all">
								<div class="absolute top-1/2 -translate-y-1/2 left-[-25px] w-2 h-2 rounded-full bg-[#D0D0D0] dark:bg-[#3A3A3A] group-hover:bg-[#8B7CB3] group-hover:scale-150 transition-all duration-300 ring-4 ring-[#FAFAFA] dark:ring-[#0F0F0F] group-hover:ring-transparent z-10"></div>
								<div class="flex items-center gap-2 mb-2">
									<span class="px-2 py-0.5 rounded-md text-xs font-medium bg-[#8B7CB3]/10 text-[#8B7CB3]">札记</span>
									<span class="text-xs text-[#999]">04-15</span>
								</div>
								<h4 class="text-base font-medium text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors">咖啡与代码</h4>
							</a>
						</div>
					</div>

					<!-- 月份分组：03月 -->
					<div class="ml-8 mb-8 relative">
						<h3 class="text-sm font-medium text-[#999] mb-4 relative">
							<span class="absolute left-[-20px] top-[50%] w-4 h-[2px] rounded-full bg-[#E5E5E5] dark:bg-[#222]"></span>
							03 月
						</h3>
						<div class="flex flex-col gap-3">
							<a href="/blog/cheng-shi-man-bu-bi-ji" class="group relative block bg-white dark:bg-[#252525] rounded-2xl p-4 shadow-sm hover:shadow-md transition-all">
								<div class="absolute top-1/2 -translate-y-1/2 left-[-25px] w-2 h-2 rounded-full bg-[#D0D0D0] dark:bg-[#3A3A3A] group-hover:bg-[#8B7CB3] group-hover:scale-150 transition-all duration-300 ring-4 ring-[#FAFAFA] dark:ring-[#0F0F0F] group-hover:ring-transparent z-10"></div>
								<div class="flex items-center gap-2 mb-2">
									<span class="px-2 py-0.5 rounded-md text-xs font-medium bg-[#8B7CB3]/10 text-[#8B7CB3]">札记</span>
									<span class="text-xs text-[#999]">03-10</span>
								</div>
								<h4 class="text-base font-medium text-[#1A1A1A] dark:text-[#EAEAEA] group-hover:text-[#8B7CB3] transition-colors">城市漫步笔记</h4>
							</a>
						</div>
					</div>
				</section>

				<!-- 2025 年份节点（占位） -->
				<section id="year-2025" class="relative mb-12">
					<div class="sticky top-16 z-20 flex items-center gap-4 py-4 -ml-2 px-2 bg-[#FAFAFA] dark:bg-[#0F0F0F] mb-4 relative transition-colors duration-300">
						<div class="w-6 h-6 rounded-full bg-[#E8913A] border-4 border-[#FAFAFA] dark:border-[#0F0F0F] z-10"></div>
						<h2 class="text-2xl font-bold">2025</h2>
						<div class="flex-1 h-[1px] bg-[#E0E0E0] dark:bg-[#2A2A2A]"></div>
					</div>
					<div class="ml-8 text-sm text-[#999]">暂无文章</div>
				</section>
			</main>

			<!-- 右侧：年度摘要卡片 -->
			<aside class="hidden md:block">
				<div class="sticky top-24 space-y-6">
					
					<div class="group bg-white dark:bg-[#1A1A1A] rounded-3xl p-5 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500 border border-transparent hover:border-[#8B7CB3]/20">
						<div class="flex items-center justify-between mb-5">
							<h3 class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest">2026 Overview</h3>
							<span class="relative flex h-2 w-2">
								<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#8B7CB3] opacity-75"></span>
								<span class="relative inline-flex rounded-full h-2 w-2 bg-[#8B7CB3]"></span>
							</span>
						</div>
						
						<div class="grid grid-cols-2 gap-3">
							<div class="p-3.5 rounded-2xl bg-[#FAFAFA] dark:bg-[#252525] group-hover:bg-[#8B7CB3]/5 transition-colors duration-300">
								<div class="text-3xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] mb-1 group-hover:text-[#8B7CB3] transition-colors">3</div>
								<div class="text-[10px] font-medium text-[#999]">已发文章</div>
							</div>
							<div class="p-3.5 rounded-2xl bg-[#FAFAFA] dark:bg-[#252525] group-hover:bg-[#8B7CB3]/5 transition-colors duration-300">
								<div class="text-3xl font-black text-[#1A1A1A] dark:text-[#EAEAEA] mb-1 group-hover:text-[#8B7CB3] transition-colors">1</div>
								<div class="text-[10px] font-medium text-[#999]">分类</div>
							</div>
						</div>
					</div>

					<div class="group bg-white dark:bg-[#1A1A1A] rounded-3xl p-5 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500 border border-transparent hover:border-[#8B7CB3]/20">
						<h3 class="text-[10px] font-bold text-[#8B7CB3] uppercase tracking-widest mb-4">Top Tags</h3>
						<div class="flex flex-wrap gap-2.5">
							<span class="px-3 py-1.5 rounded-xl text-xs font-medium bg-[#FAFAFA] dark:bg-[#252525] text-[#666] dark:text-[#999] hover:bg-[#8B7CB3] hover:text-white dark:hover:bg-[#8B7CB3] dark:hover:text-white transition-all duration-300 cursor-pointer active:scale-95 shadow-sm border border-transparent hover:shadow-md">碳汇</span>
							<span class="px-3 py-1.5 rounded-xl text-xs font-medium bg-[#FAFAFA] dark:bg-[#252525] text-[#666] dark:text-[#999] hover:bg-[#8B7CB3] hover:text-white dark:hover:bg-[#8B7CB3] dark:hover:text-white transition-all duration-300 cursor-pointer active:scale-95 shadow-sm border border-transparent hover:shadow-md">阅读</span>
							<span class="px-3 py-1.5 rounded-xl text-xs font-medium bg-[#FAFAFA] dark:bg-[#252525] text-[#666] dark:text-[#999] hover:bg-[#8B7CB3] hover:text-white dark:hover:bg-[#8B7CB3] dark:hover:text-white transition-all duration-300 cursor-pointer active:scale-95 shadow-sm border border-transparent hover:shadow-md">代码</span>
						</div>
					</div>
				</div>
			</aside>
		</div>

		<!-- 底部年度总结入口 -->
		<div class="mt-20 mb-12 text-center">
			<button class="annual-review-btn">
				<span class="relative z-10">2026 Review →</span>
			</button>
		</div>
	</div>
</BaseLayout>

<script is:inline>
	document.querySelectorAll('a[href^="#"]').forEach(anchor => {
		anchor.addEventListener('click', function (e) {
			e.preventDefault();
			const target = document.querySelector(this.getAttribute('href'));
			if (target) {
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		});
	});
</script>

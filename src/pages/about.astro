---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDb } from '../lib/db';
import { getAboutConfig, getAboutSkills, getAboutWorks, getAboutLinks } from '../lib/about';

const db = await getDb();

const [config, skills, works, links] = await Promise.all([
  getAboutConfig(db),
  getAboutSkills(db),
  getAboutWorks(db),
  getAboutLinks(db),
]);

const isEmpty = skills.length === 0 && works.length === 0;
---

<BaseLayout title={config.breadcrumbSub}>
  <main class="bg-[#FAFAFA] dark:bg-[#0F0F0F] text-[#1A1A1A] dark:text-[#EAEAEA]">

    <!-- ================= HERO ================= -->
    <section class="relative h-[70vh] overflow-hidden">
      <img
        src={config.heroImage}
        class="absolute inset-0 w-full h-full object-cover"
        style={`object-position: ${config.aboutHeroPosition}`}
        alt="about hero"
      />

      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/60"></div>

      <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-6">
        <h1 class="text-4xl md:text-6xl font-semibold tracking-tight">
          About
        </h1>
        <p class="mt-4 text-sm md:text-base text-white/80">
          {config.heroSubtitle}
        </p>
      </div>
    </section>

    <!-- ================= BREADCRUMB ================= -->
    <section class="max-w-6xl mx-auto px-6 -mt-10" data-animate>
      <div class="rounded-2xl bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-500">
        <div class="text-sm text-[#666] dark:text-[#999]">
          Home / About
        </div>
        <div class="mt-2 text-xl font-medium text-[#1A1A1A] dark:text-[#EAEAEA]">
          {config.breadcrumbSub}
        </div>
      </div>
    </section>

    {isEmpty ? (
      <!-- ================= EMPTY STATE ================= -->
      <section class="max-w-6xl mx-auto px-6 mt-14 mb-20 text-center">
        <div class="rounded-2xl bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-12 shadow-sm">
          <div class="text-[#8B7CB3] text-lg font-medium mb-3">关于页面暂无内容</div>
          <p class="text-sm text-[#666] dark:text-[#999]">
            请在管理后台填充关于页面数据，或执行 seed_about.sql 初始化种子数据。
          </p>
        </div>
      </section>
    ) : (
      <>
        <!-- ================= INTRO + INFO ================= -->
        <section class="max-w-6xl mx-auto px-6 mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">

          <!-- LEFT: INTRO -->
          <div class="md:col-span-2 rounded-2xl bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-6 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500" data-animate>
            <h2 class="text-lg font-semibold text-[#8B7CB3]">{config.introTitle}</h2>

            <div class="mt-4 space-y-4 text-sm leading-relaxed text-[#666] dark:text-[#999]">
              {config.introParagraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </div>

          <!-- RIGHT: INFO CARDS -->
          <div class="space-y-4">

            <!-- BASIC INFO -->
            <div class="rounded-2xl bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-500 delay-1" data-animate>
              <div class="text-sm text-[#8B7CB3] font-medium">{config.basicTitle}</div>
              <div class="mt-3 space-y-2 text-sm text-[#666] dark:text-[#999]">
                {config.basicItems.map((item) => (
                  <div>{item.label}: {item.value}</div>
                ))}
              </div>
            </div>

            <!-- SKILLS -->
            <div class="rounded-2xl bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-500 delay-2" data-animate>
              <div class="text-sm text-[#8B7CB3] font-medium">{config.skillsTitle}</div>

              <div class="mt-3 flex flex-wrap gap-2 text-xs">
                {skills.map((t) => (
                  <span class="px-2 py-1 rounded-full border border-white/20 dark:border-white/10 hover:text-[#8B7CB3] transition">
                    {t.name}
                  </span>
                ))}
              </div>
            </div>

            <!-- STATUS -->
            <div class="rounded-2xl bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-500 delay-3" data-animate>
              <div class="text-sm text-[#8B7CB3] font-medium">{config.statusTitle}</div>
              <div class="mt-3 text-sm text-[#666] dark:text-[#999]">
                {config.statusText}
              </div>
            </div>

          </div>
        </section>

        <!-- ================= WORKS ================= -->
        <section class="max-w-6xl mx-auto px-6 mt-14" data-animate>
          <h2 class="text-lg font-semibold text-[#8B7CB3] mb-6">
            Works / CAD & Modeling
          </h2>

          <div class="space-y-6">

            {works.map((w) => (
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6 rounded-2xl bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-5 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500">

                <!-- IMAGE -->
                {w.image && (
                  <div class="md:col-span-1">
                    <img
                      src={w.image}
                      class="rounded-xl w-full h-48 object-cover"
                      alt={w.title}
                    />
                  </div>
                )}

                <!-- TEXT -->
                <div class={w.image ? "md:col-span-2" : "md:col-span-3"}>
                  <div class="font-medium text-[#1A1A1A] dark:text-[#EAEAEA]">
                    {w.title}
                  </div>

                  <p class="mt-2 text-sm text-[#666] dark:text-[#999]">
                    {w.description}
                  </p>

                  {w.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2 text-xs">
                      {w.tags.map((t) => (
                        <span class="px-2 py-1 rounded-full border border-white/20 dark:border-white/10 hover:text-[#8B7CB3] transition">
                          {t}
                        </span>
                      ))}
                    </div>
                  )}
                </div>

              </div>
            ))}

          </div>
        </section>

        <!-- ================= CTA LINKS ================= -->
        <section class="max-w-6xl mx-auto px-6 mt-14 grid grid-cols-1 md:grid-cols-2 gap-6" data-animate>

          {links.map((link) => (
            <a href={link.url}
               class="rounded-2xl bg-white/60 dark:bg-[#1A1A1A]/60 backdrop-blur-md border border-white/20 dark:border-white/10 p-8 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-500 group">

              <div class="text-[#8B7CB3] font-medium">{link.title}</div>
              <div class="mt-2 text-sm text-[#666] dark:text-[#999]">
                {link.description}
              </div>

              <div class="mt-4 text-sm group-hover:text-[#8B7CB3] transition">
                {link.actionText}
              </div>
            </a>
          ))}

        </section>

        <!-- ================= ALT SYSTEM ================= -->
        <section class="max-w-6xl mx-auto px-6 mt-14 mb-20" data-animate>
          <div class="rounded-2xl bg-white/40 dark:bg-[#1A1A1A]/40 backdrop-blur-md border border-white/10 p-6 opacity-50">

            <div class="text-sm text-[#8B7CB3] font-medium">
              {config.altTitle}
            </div>

            <div class="mt-2 text-sm text-[#666] dark:text-[#999]">
              {config.altDescription}
            </div>

          </div>
        </section>
      </>
    )}

  </main>
</BaseLayout>
